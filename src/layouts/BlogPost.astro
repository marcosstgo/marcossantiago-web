---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const { title, date, desc, tags, slug } = Astro.props.frontmatter;
const formattedDate = (() => {
  const [y, m, d] = date.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('es-PR', { year: 'numeric', month: 'long', day: 'numeric' });
})();

// Reading time
const rawModules = import.meta.glob('../pages/blog/*.mdx', { eager: true, query: '?raw', import: 'default' });
const rawEntry   = Object.entries(rawModules).find(([path]) => path.endsWith(`/${slug}.mdx`));
const rawContent = rawEntry ? String(rawEntry[1]) : '';
const minRead    = Math.max(1, Math.ceil(
  rawContent.replace(/^---[\s\S]*?---/, '').replace(/<[^>]+>/g, ' ')
    .trim().split(/\s+/).filter(Boolean).length / 220
));

// Prev / Next
const allModules = import.meta.glob('../pages/blog/*.mdx', { eager: true });
const allPosts   = Object.values(allModules)
  .map((p: any) => ({ slug: p.frontmatter.slug, title: p.frontmatter.title, date: p.frontmatter.date }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const idx  = allPosts.findIndex(p => p.slug === slug);
const next = idx > 0                    ? allPosts[idx - 1] : null; // newer
const prev = idx < allPosts.length - 1  ? allPosts[idx + 1] : null; // older
---
<Base title={`${title} — Marcos Santiago`} description={desc}>
  <Nav />
  <main style="padding-top:120px">
    <div class="container">
      <div class="post-header">
        <a href="/blog/" class="back-link">← Blog</a>
        <div class="post-header-meta">
          <span class="post-meta-date">{formattedDate}</span>
          <span class="meta-sep">·</span>
          <span class="post-meta-read">{minRead} min de lectura</span>
          {tags && tags.length > 0 && (
            <>
              <span class="meta-sep">·</span>
              <div class="post-tags">
                {tags.map((t: string) => <span class="tag">{t}</span>)}
              </div>
            </>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
      </div>

      <article class="post-body">
        <slot />
      </article>

      <!-- Author card + CTA -->
      <div class="author-card">
        <div class="author-avatar">MS</div>
        <div class="author-info">
          <span class="author-name">Marcos Santiago</span>
          <span class="author-bio">Diseñador, fotógrafo y desarrollador desde Aibonito, PR. Creando cosas visuales que comunican.</span>
        </div>
        <a href="/contacto/" class="author-cta">¿Trabajamos juntos? <span>→</span></a>
      </div>

      <!-- Prev / Next -->
      {(prev || next) && (
        <nav class="post-nav">
          <div class="post-nav-inner">
            {prev
              ? <a href={`/blog/${prev.slug}/`} class="nav-post nav-prev">
                  <span class="nav-label">← Anterior</span>
                  <span class="nav-title">{prev.title}</span>
                </a>
              : <div />
            }
            {next && (
              <a href={`/blog/${next.slug}/`} class="nav-post nav-next">
                <span class="nav-label">Siguiente →</span>
                <span class="nav-title">{next.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}
    </div>
  </main>
  <Footer />
</Base>

<style>
.post-header {
  max-width: 72ch; margin-bottom: 56px;
}
.back-link {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); display: inline-block; margin-bottom: 24px;
  transition: color .15s;
}
.back-link:hover { color: var(--white) }

.post-header-meta {
  display: flex; align-items: center; flex-wrap: wrap; gap: 8px;
  margin-bottom: 16px;
}
.post-meta-date, .post-meta-read {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase; color: var(--dim);
}
.meta-sep { color: var(--dim); font-size: var(--text-2xs) }
.post-tags { display: flex; gap: 6px; flex-wrap: wrap }
.tag {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 4px;
  background: color-mix(in srgb, var(--white) 4%, transparent); border: 1px solid var(--border);
  color: var(--dim);
}
.post-title {
  font-family: var(--display);
  font-size: clamp(2.5rem, 6vw, 5rem);
  letter-spacing: 2px; line-height: .95;
  margin-top: 8px;
}

/* ── Article body ── */
.post-body {
  max-width: 72ch;
  font-size: .97rem; line-height: 1.85;
  color: color-mix(in srgb, var(--white) 80%, transparent);
}

/* :global() — slot content doesn't inherit Astro scoped classes */
:global(.post-body h2),
:global(.post-body h3) {
  font-family: var(--display);
  letter-spacing: 2px; color: var(--white);
  margin: 48px 0 12px;
}
:global(.post-body h2) { font-size: clamp(1.8rem, 3vw, 2.8rem) }
:global(.post-body h3) { font-size: clamp(1.3rem, 2.2vw, 1.9rem) }
:global(.post-body p)  { margin-bottom: 20px }
:global(.post-body strong) { color: var(--white) }
:global(.post-body em) { color: color-mix(in srgb, var(--white) 70%, transparent) }
:global(.post-body a)  { color: var(--accent); text-decoration: underline; text-underline-offset: 3px }

:global(.post-body ul),
:global(.post-body ol) { list-style: none; padding-left: 0; margin-bottom: 24px }
:global(.post-body li) {
  position: relative; padding-left: 20px;
  margin-bottom: 12px;
  color: color-mix(in srgb, var(--white) 80%, transparent);
  line-height: 1.7;
}
:global(.post-body ul li::before) {
  content: '—'; position: absolute; left: 0;
  color: var(--accent); font-weight: 700;
}
:global(.post-body ol) { counter-reset: ol-counter }
:global(.post-body ol li) { counter-increment: ol-counter }
:global(.post-body ol li::before) {
  content: counter(ol-counter) '.'; position: absolute; left: 0;
  color: var(--accent); font-family: var(--mono); font-size: var(--text-xs);
}
:global(.post-body blockquote) {
  border-left: 2px solid var(--accent);
  padding-left: 20px; margin: 28px 0;
  color: var(--muted); font-style: italic;
}
:global(.post-body hr) {
  border: none; border-top: 1px solid var(--border); margin: 40px 0;
}

/* Code */
:global(.post-body code) {
  font-family: var(--mono); font-size: .85em;
  background: color-mix(in srgb, var(--white) 6%, transparent);
  border: 1px solid var(--border);
  padding: 2px 6px; border-radius: 4px;
  color: color-mix(in srgb, var(--accent) 80%, var(--white));
}
:global(.post-body pre) {
  background: color-mix(in srgb, var(--white) 4%, transparent);
  border: 1px solid var(--border); border-radius: 10px;
  padding: 20px 24px; overflow-x: auto;
  margin-bottom: 24px;
}
:global(.post-body pre code) {
  background: none; border: none; padding: 0;
  font-size: var(--text-base); color: var(--white);
}

/* Tables */
:global(.post-body table) {
  width: 100%; border-collapse: collapse;
  margin-bottom: 24px; font-size: var(--text-base);
}
:global(.post-body th) {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 1.5px; text-transform: uppercase;
  text-align: left; padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  color: var(--muted);
}
:global(.post-body td) {
  padding: 10px 14px; border-bottom: 1px solid var(--border);
  color: color-mix(in srgb, var(--white) 75%, transparent);
  vertical-align: top;
}
:global(.post-body tr:last-child td) { border-bottom: none }
:global(.post-body tr:hover td) { background: color-mix(in srgb, var(--white) 3%, transparent) }

/* ── Author card ── */
.author-card {
  max-width: 72ch;
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  margin-top: 56px; padding: 28px;
  border-radius: var(--radius);
  background: var(--surface); border: 1px solid var(--border);
}
.author-avatar {
  width: 52px; height: 52px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--display); font-size: 1.1rem; letter-spacing: 2px;
  background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 60%, #7c3aed));
  color: #fff;
}
.author-info {
  display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 0;
}
.author-name {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2px; text-transform: uppercase; color: var(--white);
}
.author-bio {
  font-size: var(--text-sm); color: var(--muted); line-height: 1.6;
}
.author-cta {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2px; text-transform: uppercase; font-weight: 700;
  padding: 10px 20px; border-radius: 8px;
  background: var(--accent); color: #080808;
  white-space: nowrap; flex-shrink: 0;
  transition: opacity .2s;
}
.author-cta:hover { opacity: .85 }
.author-cta span { transition: transform .2s ease; display: inline-block }
.author-cta:hover span { transform: translateX(3px) }
@media (max-width: 600px) {
  .author-card { flex-direction: column; align-items: flex-start }
  .author-cta { width: 100%; text-align: center; justify-content: center }
}

/* ── Prev / Next ── */
.post-nav {
  max-width: 72ch;
  border-top: 1px solid var(--border);
  margin-top: 64px; padding-top: 40px; padding-bottom: 80px;
}
.post-nav-inner {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
}
@media (max-width: 600px) { .post-nav-inner { grid-template-columns: 1fr } }
.nav-post {
  display: flex; flex-direction: column; gap: 6px;
  padding: 20px; border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--surface);
  transition: border-color .2s, background .2s;
}
.nav-post:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 6%, var(--surface)) }
.nav-next { text-align: right }
.nav-label {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
}
.nav-title {
  font-family: var(--display); font-size: 1rem;
  letter-spacing: 1px; color: var(--white);
  line-height: 1.2;
}
</style>
