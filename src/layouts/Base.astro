---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  image?: string;
}
const {
  title,
  description = 'Marcos Santiago — Graphic Artist, Photographer, Videographer & Developer. Aibonito, Puerto Rico.',
  image = '/img/og.png'
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="es">
<head>
  <script is:inline>
    const t = localStorage.getItem('ms-theme');
    if (t) document.documentElement.dataset.theme = t;
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- OG -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:site_name" content="Marcos Santiago" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

</head>
<body>
  <slot />

  <!-- ── Chat Widget ── -->
  <div id="ms-chat-widget">
    <button id="ms-chat-btn" aria-label="Abrir chat">
      <i class="fa-solid fa-comment-dots" id="ms-chat-icon-open"></i>
      <i class="fa-solid fa-xmark" id="ms-chat-icon-close"></i>
    </button>

    <div id="ms-chat-panel">
      <div id="ms-chat-header">
        <div class="ms-chat-avatar">MS</div>
        <div>
          <div class="ms-chat-name">Marcos Santiago</div>
          <div class="ms-chat-status">Asistente virtual · En línea</div>
        </div>
      </div>

      <div id="ms-chat-messages">
        <div class="ms-msg ms-msg-bot">
          <p>¡Hola! Soy el asistente virtual de Marcos. ¿En qué puedo ayudarte? 📷</p>
        </div>
      </div>

      <div id="ms-chat-input-row">
        <input id="ms-chat-input" type="text" placeholder="Escribe tu pregunta..." autocomplete="off" />
        <button id="ms-chat-send" aria-label="Enviar">
          <i class="fa-solid fa-paper-plane"></i>
        </button>
      </div>
    </div>
  </div>

  <style>
  #ms-chat-widget {
    position: fixed; bottom: 24px; right: 24px;
    z-index: 9000; display: flex; flex-direction: column;
    align-items: flex-end; gap: 12px;
  }

  #ms-chat-btn {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--accent); border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.3rem;
    box-shadow: 0 4px 24px rgba(74,108,247,.4);
    transition: transform .2s, box-shadow .2s;
  }
  #ms-chat-btn:hover { transform: scale(1.08); box-shadow: 0 6px 32px rgba(74,108,247,.55) }
  #ms-chat-icon-close { display: none }

  #ms-chat-panel {
    width: 340px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    display: none;
    flex-direction: column;
    box-shadow: 0 16px 64px rgba(0,0,0,.4);
    max-height: 520px;
  }
  #ms-chat-panel.open { display: flex }

  #ms-chat-header {
    padding: 16px 20px;
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 12px;
  }
  .ms-chat-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--accent); display: flex;
    align-items: center; justify-content: center;
    font-family: var(--mono); font-size: .55rem;
    letter-spacing: 1px; color: #fff; flex-shrink: 0;
  }
  .ms-chat-name {
    font-family: var(--mono); font-size: .58rem;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--white);
  }
  .ms-chat-status {
    font-size: .72rem; color: var(--muted); margin-top: 2px;
  }

  #ms-chat-messages {
    flex: 1; overflow-y: auto;
    padding: 16px; display: flex;
    flex-direction: column; gap: 10px;
    scrollbar-width: thin;
  }
  .ms-msg { max-width: 85% }
  .ms-msg p {
    font-size: .88rem; line-height: 1.55;
    padding: 10px 14px; border-radius: 14px; margin: 0;
  }
  .ms-msg-bot { align-self: flex-start }
  .ms-msg-bot p {
    background: var(--panel);
    border: 1px solid var(--border);
    color: color-mix(in srgb, var(--white) 85%, transparent);
    border-bottom-left-radius: 4px;
  }
  .ms-msg-user { align-self: flex-end }
  .ms-msg-user p {
    background: var(--accent);
    color: #fff;
    border-bottom-right-radius: 4px;
  }
  .ms-msg-typing p {
    color: var(--muted);
    font-style: italic;
  }

  #ms-chat-input-row {
    padding: 12px 16px;
    border-top: 1px solid var(--border);
    display: flex; gap: 8px; align-items: center;
    background: var(--panel);
  }
  #ms-chat-input {
    flex: 1; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px;
    padding: 9px 14px; font-size: .88rem;
    color: var(--white); font-family: var(--body);
    outline: none; transition: border-color .15s;
  }
  #ms-chat-input:focus { border-color: var(--accent) }
  #ms-chat-input::placeholder { color: var(--muted) }
  #ms-chat-send {
    width: 36px; height: 36px; border-radius: 10px;
    background: var(--accent); border: none;
    color: #fff; cursor: pointer; font-size: .85rem;
    display: flex; align-items: center; justify-content: center;
    transition: opacity .15s; flex-shrink: 0;
  }
  #ms-chat-send:hover { opacity: .85 }
  #ms-chat-send:disabled { opacity: .4; cursor: default }

  @media (max-width: 400px) {
    #ms-chat-panel { width: calc(100vw - 32px) }
    #ms-chat-widget { right: 16px; bottom: 16px }
  }
  </style>

  <script is:inline>
  (function() {
    const btn     = document.getElementById('ms-chat-btn');
    const panel   = document.getElementById('ms-chat-panel');
    const input   = document.getElementById('ms-chat-input');
    const send    = document.getElementById('ms-chat-send');
    const msgs    = document.getElementById('ms-chat-messages');
    const iconO   = document.getElementById('ms-chat-icon-open');
    const iconC   = document.getElementById('ms-chat-icon-close');

    let history = [];
    let isOpen  = false;

    btn.addEventListener('click', () => {
      isOpen = !isOpen;
      panel.classList.toggle('open', isOpen);
      iconO.style.display = isOpen ? 'none'  : '';
      iconC.style.display = isOpen ? ''      : 'none';
      if (isOpen) input.focus();
    });

    function addMsg(role, text) {
      const div = document.createElement('div');
      div.className = 'ms-msg ms-msg-' + (role === 'user' ? 'user' : 'bot');
      const p = document.createElement('p');
      p.textContent = text;
      div.appendChild(p);
      msgs.appendChild(div);
      msgs.scrollTop = msgs.scrollHeight;
      return div;
    }

    async function sendMsg() {
      const text = input.value.trim();
      if (!text) return;
      input.value = '';
      send.disabled = true;

      addMsg('user', text);
      history.push({ role: 'user', content: text });

      const typing = addMsg('bot', '...');
      typing.classList.add('ms-msg-typing');

      try {
        const res = await fetch('/ms-chat/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history }),
        });
        const data = await res.json();
        typing.remove();
        addMsg('bot', data.reply);
        history.push({ role: 'assistant', content: data.reply });
      } catch {
        typing.remove();
        addMsg('bot', 'Hubo un error. Por favor contáctame directamente por WhatsApp: (787) 243-9670');
      }

      send.disabled = false;
      input.focus();
    }

    send.addEventListener('click', sendMsg);
    input.addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg() });
  })();
  </script>
</body>
</html>
