---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const features = [
  {
    label: 'Video 360° automático',
    desc: 'La plataforma gira sola alrededor de tus invitados — sin operador, sin complicaciones. Cada clip queda perfecto.',
  },
  {
    label: 'Entrega inmediata',
    desc: 'Los clips se comparten al instante vía QR o link directo. Tus invitados los tienen en su teléfono antes de salir del evento.',
  },
  {
    label: 'Efectos y overlays',
    desc: 'Slow motion, música de fondo, overlay con el logo o tema del evento. Cada video es único y branded.',
  },
  {
    label: 'Setup profesional',
    desc: 'Llegamos, instalamos y operamos. Tú disfrutas el evento — nosotros nos encargamos del booth.',
  },
  {
    label: 'Iluminación incluida',
    desc: 'Ring light profesional integrado para que cada toma quede nítida sin importar la iluminación del venue.',
  },
  {
    label: 'Galería del evento',
    desc: 'Todos los clips del evento organizados en una galería digital privada, disponible para descargar después.',
  },
];

const events = [
  'Bodas', 'Quinceañeros', 'Cumpleaños', 'Corporativos',
  'Graduaciones', 'Fiestas privadas', 'Activaciones de marca', 'Conciertos y festivales',
];
---
<Base
  title="360 Video Booth — Marcos Santiago · Puerto Rico"
  description="360 Video Booth profesional para eventos en Puerto Rico. Air-39 automático — clips 360 con entrega instantánea, efectos, overlay y galería digital. Bodas, quinceañeros, corporativos."
>
  <Nav />
  <main style="padding-top:120px">
    <div class="container">

      <p class="section-label">Servicio · 360 Video Booth</p>
      <h1 class="section-title">360 Video Booth</h1>
      <p class="section-sub">
        La experiencia que todos quieren en su evento. La plataforma Air-39 gira automáticamente alrededor de tus invitados y genera clips 360° cinematográficos — con entrega instantánea, efectos personalizados y el recuerdo perfecto para cada uno.
      </p>

      <!-- Video recap -->
      <div class="booth-video-wrap">
        <video
          class="booth-video"
          src="/booth-360/360-Recap.mp4"
          autoplay muted loop playsinline
          controls
        ></video>
      </div>

      <!-- Hero visual -->
      <div class="booth-hero">
        <div class="booth-hero-badge">
          <span class="badge-dot"></span>
          Air-39 Automatic 360 Pro
        </div>
        <div class="booth-hero-grid">
          <div class="booth-stat">
            <span class="stat-num">360°</span>
            <span class="stat-lbl">Rotación automática</span>
          </div>
          <div class="booth-stat">
            <span class="stat-num">4K</span>
            <span class="stat-lbl">Calidad de video</span>
          </div>
          <div class="booth-stat">
            <span class="stat-num">QR</span>
            <span class="stat-lbl">Entrega instantánea</span>
          </div>
          <div class="booth-stat">
            <span class="stat-num">∞</span>
            <span class="stat-lbl">Tomas ilimitadas</span>
          </div>
        </div>
      </div>

      <!-- Cómo funciona -->
      <div style="margin-top:80px">
        <p class="section-label">Proceso</p>
        <h2 class="section-title" style="font-size:clamp(2rem,4vw,3.2rem)">Cómo funciona</h2>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">01</div>
          <h3 class="step-title">Súbete a la plataforma</h3>
          <p class="step-desc">Tus invitados se paran en la plataforma circular — solos, en pareja o en grupo.</p>
        </div>
        <div class="step-card">
          <div class="step-num">02</div>
          <h3 class="step-title">La cámara gira sola</h3>
          <p class="step-desc">El brazo motorizado gira 360° alrededor capturando todo desde el ángulo perfecto.</p>
        </div>
        <div class="step-card">
          <div class="step-num">03</div>
          <h3 class="step-title">Efectos al instante</h3>
          <p class="step-desc">Slow motion, música y overlay del evento aplicados automáticamente al clip.</p>
        </div>
        <div class="step-card">
          <div class="step-num">04</div>
          <h3 class="step-title">Comparte en segundos</h3>
          <p class="step-desc">Escanea el QR y el video llega directo al teléfono. Listo para compartir en redes.</p>
        </div>
      </div>

      <!-- Features -->
      <div style="margin-top:80px">
        <p class="section-label">Qué incluye</p>
        <h2 class="section-title" style="font-size:clamp(2rem,4vw,3.2rem)">Todo incluido</h2>
      </div>

      <div class="features-grid">
        {features.map(f => (
          <div class="feature-card">
            <h3 class="feature-label">{f.label}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Eventos -->
      <div class="events-section">
        <p class="section-label">Disponible para</p>
        <h2 class="section-title" style="font-size:clamp(2rem,4vw,3.2rem)">Cualquier evento</h2>
        <div class="events-pills">
          {events.map(e => (
            <span class="event-pill">{e}</span>
          ))}
        </div>
      </div>

      <!-- Galería -->
      <div class="gallery-section">
        <p class="section-label">Galería</p>
        <h2 class="section-title" style="font-size:clamp(2rem,4vw,3.2rem)">En acción</h2>
        <div class="gallery-grid">
          {[1,2,3,4,5,6,7,8,9].map(n => (
            <div class="gallery-item">
              <img src={`/booth-360/360photo${n}.jpg`} alt={`360 Video Booth evento ${n}`} loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="contact-cta">
        <div>
          <h2 class="cta-title">¿Tu evento merece el 360?</h2>
          <p class="cta-sub">Disponible en toda Puerto Rico. Escríbeme para fecha, disponibilidad y cotización.</p>
        </div>
        <a href="https://wa.me/17872439670" target="_blank" rel="noopener" class="btn whatsapp">
          <i class="fab fa-whatsapp"></i> (787) 243-9670
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Base>

<style>
/* ── Video ── */
.booth-video-wrap {
  margin-top: 48px;
  border-radius: 16px; overflow: hidden;
  border: 1px solid var(--border);
  background: #000;
  aspect-ratio: 16/9;
}
.booth-video {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ── Gallery ── */
.gallery-section { margin-top: 80px; padding-top: 56px; border-top: 1px solid var(--border); }
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px; margin-top: 28px;
}
@media (max-width: 600px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
.gallery-item {
  border-radius: 10px; overflow: hidden;
  aspect-ratio: 1/1;
  background: var(--surface);
}
.gallery-item img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform .3s ease;
}
.gallery-item:hover img { transform: scale(1.04); }

/* ── Hero ── */
.booth-hero {
  margin-top: 48px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 48px;
}
.booth-hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--mono); font-size: .65rem;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--page-c); margin-bottom: 40px;
}
.badge-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--page-c); flex-shrink: 0;
}
.booth-hero-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;
}
@media (max-width: 600px) {
  .booth-hero-grid { grid-template-columns: repeat(2, 1fr); }
  .booth-hero { padding: 28px 20px; }
}
.booth-stat {
  display: flex; flex-direction: column; gap: 6px;
}
.stat-num {
  font-family: var(--display);
  font-size: clamp(2.4rem, 5vw, 3.6rem);
  letter-spacing: 2px; color: var(--page-c); line-height: 1;
}
.stat-lbl {
  font-size: .78rem; color: var(--muted); line-height: 1.4;
}

/* ── Steps ── */
.steps-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 12px; margin-top: 32px;
}
@media (max-width: 900px) { .steps-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 500px)  { .steps-grid { grid-template-columns: 1fr; } }
.step-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; padding: 28px 20px;
}
.step-num {
  font-family: var(--display); font-size: 3rem;
  color: var(--page-c); opacity: .35; line-height: 1;
  margin-bottom: 16px;
}
.step-title {
  font-family: var(--mono); font-size: .65rem;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--white); margin-bottom: 10px;
}
.step-desc { font-size: .88rem; color: var(--muted); line-height: 1.65; }

/* ── Features ── */
.features-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 12px; margin-top: 32px;
}
@media (max-width: 600px) { .features-grid { grid-template-columns: 1fr; } }
.feature-card {
  background: var(--surface); border: 1px solid var(--border);
  border-left: 3px solid var(--page-c);
  border-radius: 12px; padding: 28px 24px;
}
.feature-label {
  font-family: var(--mono); font-size: .6rem;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--page-c); margin-bottom: 10px;
}
.feature-desc { font-size: .88rem; color: var(--muted); line-height: 1.65; }

/* ── Events ── */
.events-section { margin-top: 80px; padding-top: 56px; border-top: 1px solid var(--border); }
.events-pills {
  display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px;
}
.event-pill {
  font-family: var(--mono); font-size: .65rem;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 8px 18px; border-radius: 100px;
  border: 1px solid var(--border);
  color: var(--muted);
}

/* ── CTA ── */
.contact-cta {
  margin-top: 64px; padding: 48px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px;
  display: flex; align-items: center;
  justify-content: space-between; gap: 32px; flex-wrap: wrap;
}
.cta-title {
  font-family: var(--display);
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: 2px; margin-bottom: 12px;
}
.cta-sub { color: var(--muted); font-size: .9rem; line-height: 1.7; }
</style>
