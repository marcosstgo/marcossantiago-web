---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const disciplines = [
  {
    label: 'Diseño Gráfico',
    desc:  'Identidades visuales, branding y experiencias digitales.',
    href:  '/portafolio/diseno/',
    color: '#e8c84a',
    path:  'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  },
  {
    label: 'Fotografía',
    desc:  'Eventos, cultura y momentos que definen lo que somos.',
    href:  '/portafolio/foto/',
    color: '#a0c4ff',
    path:  'M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2zM12 17a4 4 0 100-8 4 4 0 000 8z',
  },
  {
    label: 'Videografía',
    desc:  'Producción de video para eventos, cultura y marcas en Puerto Rico.',
    href:  '/portafolio/video/',
    color: '#ff9f7f',
    path:  'M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
  },
  {
    label: 'Desarrollo',
    desc:  'Plataformas web, apps de escritorio y herramientas que la gente usa.',
    href:  '/portafolio/dev/',
    color: '#88e0b0',
    path:  'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
];

const devProjects = [
  {
    name: 'CORILLO',
    desc: 'Plataforma de streaming independiente para Puerto Rico.',
    href: 'https://corillo.live',
    tags: ['HTML', 'JS', 'MediaMTX', 'HLS'],
  },
  {
    name: 'STREAMER PRO',
    desc: 'App de escritorio para streaming RTMP multi-plataforma con FFmpeg.',
    href: 'https://corillo.live/streamer-pro/',
    tags: ['C#', 'WPF', 'FFmpeg'],
  },
  {
    name: 'ANTI-BUFFERBLOAT PRO',
    desc: 'Optimizador de red para Windows: reduce latencia y bufferbloat.',
    href: 'https://corillo.live/antibufferbloat-pro/',
    tags: ['C#', 'WPF', 'Windows'],
  },
];
---
<Base title="Marcos Santiago — Graphic Artist, Developer · Aibonito PR">
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-inner">

        <div class="hero-copy">
          <p class="hero-from">Aibonito, Puerto Rico</p>
          <h1 class="hero-title">
            <span class="name">MARCOS</span>
            <span class="last">SANTIAGO</span>
          </h1>
          <p class="hero-tagline">Artista Gráfico · Fotógrafo · Videógrafo · Desarrollador</p>
          <p class="hero-desc">
            Diseño marcas e identidades visuales, capturo momentos, produzco video y construyo productos digitales. Todo desde Aibonito, Puerto Rico.
          </p>
          <div class="hero-actions">
            <a href="/portafolio/" class="btn primary">Ver portafolio</a>
            <a href="/contacto/" class="btn ghost">Hablemos</a>
          </div>
        </div>

        <div class="hero-photo">
          <div class="photo-placeholder">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            <span>Foto próximamente</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ DISCIPLINAS ═══ -->
  <section class="section">
    <div class="container">
      <p class="section-label">Lo que hago</p>
      <h2 class="section-title">Cuatro disciplinas,<br>una visión</h2>
      <div class="disciplines-grid">
        {disciplines.map(d => (
          <a href={d.href} class="dc-card" style={`--c:${d.color}`}>
            <div class="dc-top">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--c)"
                   stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={d.path}/>
              </svg>
              <span class="dc-arrow">→</span>
            </div>
            <h3 class="dc-title">{d.label}</h3>
            <p class="dc-desc">{d.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ DEV PROJECTS ═══ -->
  <section class="section dev-section">
    <div class="container">
      <p class="section-label">Desarrollo</p>
      <h2 class="section-title">Proyectos destacados</h2>
      <div class="dev-list">
        {devProjects.map(p => (
          <a href={p.href} target="_blank" rel="noopener" class="dev-row">
            <div>
              <div class="dev-name">{p.name}</div>
              <div class="dev-desc">{p.desc}</div>
              <div class="dev-tags">
                {p.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
            <span class="dev-arrow">↗</span>
          </a>
        ))}
      </div>
      <div style="margin-top:32px">
        <a href="/portafolio/dev/" class="btn ghost">Ver todos los proyectos</a>
      </div>
    </div>
  </section>

  <!-- ═══ BLOG CTA ═══ -->
  <section class="section">
    <div class="container">
      <div class="blog-cta">
        <div>
          <p class="section-label">Blog</p>
          <h2 class="blog-cta-title">Escribo sobre lo que hago</h2>
          <p class="blog-cta-sub">Programación, diseño, fotografía, video y lo que me pase por la cabeza.</p>
        </div>
        <a href="/blog/" class="btn primary">Leer el blog</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex; align-items: center;
  padding: 120px 0 80px;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background:
    radial-gradient(ellipse 80% 60% at 70% 40%, rgba(232,200,74,.05), transparent 60%),
    radial-gradient(ellipse 40% 40% at 5% 90%, rgba(255,255,255,.02), transparent 50%);
}
.hero-inner {
  position: relative; z-index: 1;
  display: grid; grid-template-columns: 1.1fr .9fr;
  gap: 64px; align-items: center;
}
@media (max-width: 768px) {
  .hero-inner { grid-template-columns: 1fr; gap: 40px }
  .hero-photo { order: -1 }
}
.hero-from {
  font-family: var(--mono); font-size: .55rem;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 16px;
}
.hero-title {
  font-family: var(--display);
  font-size: clamp(4.5rem, 10vw, 9rem);
  letter-spacing: 2px; line-height: .88;
  margin-bottom: 20px;
}
.hero-title .name { display: block }
.hero-title .last {
  display: block;
  -webkit-text-stroke: 1px rgba(240,237,232,.35);
  color: transparent;
}
.hero-tagline {
  font-family: var(--mono); font-size: .58rem;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--accent); margin-bottom: 18px;
}
.hero-desc {
  color: var(--muted); font-size: .95rem;
  line-height: 1.75; max-width: 48ch; margin-bottom: 28px;
}
.hero-actions { display: flex; gap: 12px; flex-wrap: wrap }

.hero-photo { aspect-ratio: 4/5; border-radius: 16px; overflow: hidden }
.photo-placeholder {
  width: 100%; height: 100%;
  background: var(--surface); border: 2px dashed var(--border);
  border-radius: 16px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 12px;
  color: var(--dim);
  font-family: var(--mono); font-size: .52rem;
  letter-spacing: 2px; text-transform: uppercase;
}

/* ── DISCIPLINES ── */
.disciplines-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 12px; margin-top: 48px;
}
@media (max-width: 900px) { .disciplines-grid { grid-template-columns: repeat(2,1fr) } }
@media (max-width: 480px) { .disciplines-grid { grid-template-columns: 1fr } }

.dc-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 24px 20px;
  display: flex; flex-direction: column; gap: 10px;
  position: relative; overflow: hidden; transition: border-color .2s;
}
.dc-card::after {
  content: ''; position: absolute;
  top: 0; left: 0; right: 0; height: 2px;
  background: var(--c); opacity: 0; transition: opacity .2s;
}
.dc-card:hover { border-color: var(--border-h) }
.dc-card:hover::after { opacity: 1 }
.dc-top { display: flex; align-items: flex-start; justify-content: space-between }
.dc-arrow { font-size: .8rem; color: var(--muted); transition: transform .2s, color .2s }
.dc-card:hover .dc-arrow { transform: translate(3px,-3px); color: var(--white) }
.dc-title {
  font-family: var(--mono); font-size: .65rem;
  letter-spacing: 2px; text-transform: uppercase; color: var(--white);
}
.dc-desc { font-size: .83rem; color: var(--muted); line-height: 1.55 }

/* ── DEV ── */
.dev-section { background: var(--surface) }
.dev-list { display: flex; flex-direction: column; margin-top: 40px }
.dev-row {
  display: flex; align-items: center;
  justify-content: space-between; gap: 24px;
  padding: 24px 0; border-bottom: 1px solid var(--border);
  transition: .2s;
}
.dev-row:first-child { border-top: 1px solid var(--border) }
.dev-row:hover .dev-name { color: var(--accent) }
.dev-row:hover .dev-arrow { transform: translate(4px,-4px) }
.dev-name {
  font-family: var(--display); font-size: 1.6rem;
  letter-spacing: 3px; transition: color .2s;
}
.dev-desc { font-size: .84rem; color: var(--muted); margin-top: 4px }
.dev-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px }
.tag {
  font-family: var(--mono); font-size: .48rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 4px;
  background: rgba(255,255,255,.04); border: 1px solid var(--border);
  color: var(--muted);
}
.dev-arrow { font-size: 1.2rem; color: var(--muted); flex-shrink: 0; transition: transform .2s }

/* ── BLOG CTA ── */
.blog-cta {
  display: flex; align-items: center;
  justify-content: space-between; gap: 32px; flex-wrap: wrap;
  padding: 48px; background: var(--surface);
  border: 1px solid var(--border); border-radius: 20px;
}
.blog-cta-title {
  font-family: var(--display);
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  letter-spacing: 2px; margin-bottom: 8px;
}
.blog-cta-sub { color: var(--muted); font-size: .9rem }
</style>
