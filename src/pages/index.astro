---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const allPosts = await Promise.all(
  Object.values(import.meta.glob('./blog/*.mdx', { eager: true })) as any[]
);
const latestPost = allPosts
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())[0]
  ?.frontmatter;

const disciplines = [
  {
    label: 'Diseño Gráfico',
    desc:  'Identidades visuales, branding y experiencias digitales.',
    href:  '/portafolio/diseno/',
    color: '#e8c84a',
    path:  'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  },
  {
    label: 'Fotografía',
    desc:  'Eventos, cultura y momentos que definen lo que somos.',
    href:  '/portafolio/foto/',
    color: '#a0c4ff',
    path:  'M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2zM12 17a4 4 0 100-8 4 4 0 000 8z',
  },
  {
    label: 'Videografía',
    desc:  'Producción de video para eventos, cultura y marcas en Puerto Rico.',
    href:  '/portafolio/video/',
    color: '#ff9f7f',
    path:  'M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
  },
  {
    label: 'Desarrollo',
    desc:  'Plataformas web, apps de escritorio y herramientas que la gente usa.',
    href:  '/portafolio/dev/',
    color: '#88e0b0',
    path:  'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
];

const featuredProjects = [
  {
    name: 'CORILLO',
    tagline: 'Streaming en vivo para Puerto Rico',
    desc: 'Plataforma independiente de streaming con canal grid en vivo, player HLS, chat en tiempo real y panel de administración.',
    href: 'https://corillo.live',
    tags: ['HTML', 'JS', 'MediaMTX', 'HLS', 'Nginx'],
    status: 'Live',
    color: '#e8c84a',
    year: '2026',
  },
  {
    name: 'KIOSKKO',
    tagline: 'E-commerce para negocios en Puerto Rico',
    desc: 'Plataforma SaaS con tienda online, carrito, pagos con Stripe y ATH Móvil, panel admin completo y configuración sin código.',
    href: 'https://kioskko.com',
    tags: ['Astro', 'PocketBase', 'Stripe', 'ATH Móvil', 'Docker'],
    status: 'Live',
    color: '#4a6cf7',
    year: '2025',
  },
  {
    name: 'PLAKITA',
    tagline: 'Identificación QR para mascotas',
    desc: 'Plaquitas con código QR que permiten reunir mascotas perdidas con sus dueños al instante desde cualquier teléfono.',
    href: 'https://plakita.com',
    tags: ['React', 'Supabase', 'QR', 'Netlify'],
    status: 'Live',
    color: '#f97316',
    year: '2025',
  },
  {
    name: 'FLASHEALO',
    tagline: 'Fotos colaborativas para eventos',
    desc: 'Los asistentes suben y comparten sus fotos en un espacio centralizado por evento. Sin apps, sin cuentas, solo escanear y subir.',
    href: 'https://flashealo.com',
    tags: ['React', 'Supabase', 'Storage', 'QR'],
    status: 'Beta',
    color: '#a855f7',
    year: '2025',
  },
];

---
<Base
  title="Marcos Santiago — Fotógrafo, Videógrafo & Artista Gráfico · Aibonito, Puerto Rico"
  description="Fotógrafo, videógrafo y artista gráfico en Aibonito, Puerto Rico. Bodas, quinceañeros, eventos, video, diseño de marca y 360 Video Booth. Toda la isla."
>
 <div class="home">
  <Nav />

  <!-- ═══ HERO — cuadro de cine ═══ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <video class="hero-video-bg" autoplay muted loop playsinline
             poster="/marcos-photo.webp"
             src="/hero-bg.mp4"></video>
      <div class="hero-grade"></div>
      <div class="hero-leak"></div>
    </div>

    <span class="hero-bar top" aria-hidden="true"></span>
    <span class="hero-bar bottom" aria-hidden="true"></span>

    <div class="container hero-inner">
      <p class="hero-eyebrow">Marcos Santiago — Aibonito, Puerto Rico</p>
      <h1 class="hero-title">
        <span class="verb" id="verb">Capturo</span>
        <span class="obj">lo que importa.</span>
      </h1>
      <p class="hero-desc">
        Fotógrafo, videógrafo y artista gráfico. Bodas, quinceañeros, eventos y marcas — desde Aibonito para toda la isla.
      </p>
      <div class="hero-actions">
        <a href="/portafolio/" class="btn primary">Ver mi trabajo</a>
        <a href="https://wa.me/17872439670" target="_blank" rel="noopener" class="btn whatsapp">
          <i class="fab fa-whatsapp"></i> (787) 243-9670
        </a>
      </div>
    </div>

    <div class="hero-slate" aria-hidden="true">
      <span>MS</span>
      <span class="dot">·</span>
      <span>Puerto Rico</span>
      <span class="dot">·</span>
      <span>desde 2001</span>
    </div>
    <div class="hero-socials" aria-hidden="false">
      <a href="https://www.instagram.com/m4rcos" target="_blank" rel="noopener" class="hero-social-link" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
      <a href="https://www.behance.net/marcossantiago" target="_blank" rel="noopener" class="hero-social-link" aria-label="Behance"><i class="fab fa-behance"></i></a>
      <a href="https://github.com/marcosstgo" target="_blank" rel="noopener" class="hero-social-link" aria-label="GitHub"><i class="fab fa-github"></i></a>
    </div>
  </section>

  <script>
    const verbs = ['Capturo', 'Diseño', 'Produzco', 'Edito'];
    let idx = 0;
    const verbEl = document.getElementById('verb');
    function cycleVerb() {
      if (!verbEl) return;
      verbEl.style.opacity = '0';
      verbEl.style.transform = 'translateY(10px)';
      setTimeout(() => {
        idx = (idx + 1) % verbs.length;
        verbEl.textContent = verbs[idx];
        verbEl.style.opacity = '1';
        verbEl.style.transform = 'translateY(0)';
      }, 320);
    }
    setInterval(cycleVerb, 2800);
  </script>

  <!-- ═══ CLIENTES ═══ -->
  <section class="clients-section">
    <div class="container">
      <p class="clients-label">Logos que he diseñado</p>
      <div class="clients-grid">
        <img src="/logos-home/brava.svg"        alt="Brava"    class="client-logo" />
        <img src="/logos-home/buoyant.svg"      alt="Buoyant"  class="client-logo" />
        <img src="/logos-home/corillo-logo.svg" alt="Corillo"  class="client-logo" />
        <img src="/logos-home/jalda.svg"        alt="Jalda"    class="client-logo" />
      </div>
      <div class="clients-more">
        <a href="/portafolio/logos/" class="btn ghost">Ver todos los logos →</a>
      </div>
    </div>
  </section>

  <!-- ═══ DISCIPLINAS ═══ -->
  <section class="section">
    <div class="container">
      <p class="section-label">Lo que hago</p>
      <h2 class="section-title">Cuatro disciplinas,<br>una visión</h2>
      <div class="disciplines-grid">
        {disciplines.map(d => (
          <a href={d.href} class="dc-card" style={`--c:${d.color}`}>
            <div class="dc-top">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--c)"
                   stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={d.path}/>
              </svg>
              <span class="dc-arrow">→</span>
            </div>
            <h3 class="dc-title">{d.label}</h3>
            <p class="dc-desc">{d.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ DEV PROJECTS ═══ -->
  <section class="section dev-section">
    <div class="container">
      <p class="section-label">Desarrollo</p>
      <h2 class="section-title">Proyectos destacados</h2>

      <!-- Featured -->
      <div class="featured-grid">
        {featuredProjects.map(p => (
          <a href={p.href} target="_blank" rel="noopener" class="featured-card" style={`--c:${p.color}`}>
            <div class="featured-top">
              <div class="featured-meta">
                <span class="featured-year">{p.year}</span>
                <span class:list={['featured-status', p.status.toLowerCase()]}>{p.status}</span>
              </div>
              <span class="featured-arrow">↗</span>
            </div>
            <h3 class="featured-name">{p.name}</h3>
            <p class="featured-tagline">{p.tagline}</p>
            <p class="featured-desc">{p.desc}</p>
            <div class="dev-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>

      <div style="margin-top:32px">
        <a href="/portafolio/dev/" class="btn ghost">Ver todos los proyectos →</a>
      </div>
    </div>
  </section>

  <!-- ═══ 360 BOOTH ═══ -->
  <section class="section booth-section">
    <div class="container">
      <a href="/video-booth-360/" class="booth-card">
        <div class="booth-video-bg">
          <video autoplay muted loop playsinline src="/booth-360/360-Recap.mp4"></video>
          <div class="booth-overlay"></div>
        </div>
        <div class="booth-content">
          <span class="booth-label">Servicio Destacado</span>
          <h2 class="booth-title">360 Video Booth</h2>
          <p class="booth-desc">La plataforma giratoria que crea clips cinematográficos al instante para bodas, eventos corporativos y activaciones.</p>
          <span class="booth-cta">Conocer más →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══ CONTACTO ═══ -->
  <section class="contact-band">
    <div class="container contact-inner">
      <div class="contact-copy">
        <p class="section-label">Hablemos</p>
        <h2 class="contact-title">¿Tienes algo en mente?</h2>
        <p class="contact-sub">Cuéntame de tu boda, tu evento o tu marca. Te respondo el mismo día.</p>
      </div>
      <div class="contact-actions">
        <a href="tel:+17872439670" class="btn primary"><i class="fa-solid fa-phone"></i> (787) 243-9670</a>
        <a href="https://wa.me/17872439670" target="_blank" rel="noopener" class="btn whatsapp"><i class="fab fa-whatsapp"></i> WhatsApp</a>
        <a href="/contacto/" class="btn ghost">Pedir cotización →</a>
      </div>
    </div>
  </section>

  <!-- ═══ BLOG CTA ═══ -->
  <section class="section">
    <div class="container">
      <div class="blog-row">
        <div class="blog-row-copy">
          <p class="section-label">Blog</p>
          <h2 class="blog-cta-title">Escribo sobre lo que hago</h2>
          <p class="blog-cta-sub">Programación, diseño, fotografía, video y lo que me pase por la cabeza.</p>
          <a href="/blog/" class="btn ghost" style="margin-top:24px">Ver todos los artículos →</a>
        </div>
        {latestPost && (
          <a href={`/blog/${latestPost.slug}/`} class="blog-latest-card">
            <span class="blog-latest-label">Último artículo</span>
            <h3 class="blog-latest-title">{latestPost.title}</h3>
            <p class="blog-latest-desc">{latestPost.desc}</p>
            <span class="blog-latest-link">Leer →</span>
          </a>
        )}
      </div>
    </div>
  </section>

  <Footer />
 </div>
</Base>

<style>
/* ══ Acento cinematográfico — scoped SOLO al home ══ */
.home {
  --accent:     #f4a83a;   /* ámbar cálido */
  --accent-2:   #ff6a3d;   /* brasa */
  --accent-dim: rgba(244,168,58,.14);
  --film:       #08080b;   /* negro de cine */
}

/* ── HERO — cuadro de cine ── */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex; align-items: center;
  padding: 120px 0 96px;
  overflow: hidden;
  background: var(--film);
}
.hero-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden }
.hero-video-bg {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(.42) contrast(1.08) saturate(.85);
  transform: scale(1.04);
}
/* Grade cinematográfico: viñeta + oscurecido inferior para el texto */
.hero-grade {
  position: absolute; inset: 0;
  background:
    radial-gradient(120% 90% at 70% 30%, transparent 30%, rgba(8,8,11,.55) 100%),
    linear-gradient(to bottom, rgba(8,8,11,.55) 0%, rgba(8,8,11,.15) 40%, rgba(8,8,11,.85) 88%, var(--film) 100%);
}
/* Light leak ámbar en una esquina — el detalle de firma */
.hero-leak {
  position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(60% 55% at 100% 0%, color-mix(in srgb, var(--accent) 34%, transparent) 0%, transparent 60%);
  mix-blend-mode: screen; opacity: .7;
}
/* Barras de letterbox (widescreen) */
.hero-bar {
  position: absolute; left: 0; right: 0; height: 34px; z-index: 3;
  background: var(--film); pointer-events: none;
}
.hero-bar.top { top: 0; box-shadow: 0 1px 0 color-mix(in srgb, var(--accent) 22%, transparent) }
.hero-bar.bottom { bottom: 0; box-shadow: 0 -1px 0 color-mix(in srgb, var(--accent) 22%, transparent) }
@media (max-width: 768px) { .hero-bar { height: 20px } }

.hero-inner {
  position: relative; z-index: 2;
  color: #f4f1ea;
  max-width: 900px;
}
.hero-eyebrow {
  font-family: var(--mono); font-size: .68rem;
  letter-spacing: 4px; text-transform: uppercase;
  color: color-mix(in srgb, var(--accent) 80%, #fff);
  margin-bottom: 22px;
}
.hero-title {
  font-family: var(--display);
  font-size: clamp(4rem, 13vw, 11rem);
  letter-spacing: 1px; line-height: .82;
  margin-bottom: 26px;
  text-transform: uppercase;
}
.hero-title .verb {
  display: block;
  background: linear-gradient(100deg, var(--accent) 0%, var(--accent-2) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  transition: opacity .32s ease, transform .32s ease;
  will-change: opacity, transform;
}
.hero-title .obj { display: block; color: #f4f1ea }
.hero-desc {
  color: rgba(244,241,234,.72); font-size: 1.15rem;
  line-height: 1.65; max-width: 46ch; margin-bottom: 34px;
}
.hero-actions { display: flex; gap: 12px; flex-wrap: wrap }

/* Film slate — abajo izquierda */
.hero-slate {
  position: absolute; left: 24px; bottom: 46px; z-index: 3;
  display: flex; gap: 9px; align-items: center;
  font-family: var(--mono); font-size: .58rem;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: rgba(244,241,234,.5);
}
.hero-slate .dot { color: var(--accent) }
/* Socials — abajo derecha */
.hero-socials {
  position: absolute; right: 24px; bottom: 42px; z-index: 3;
  display: flex; align-items: center; gap: 10px;
}
.hero-social-link {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid rgba(244,241,234,.16); border-radius: 999px;
  color: rgba(244,241,234,.7); font-size: .95rem;
  transition: .2s ease;
}
.hero-social-link:hover {
  color: var(--film); background: var(--accent); border-color: var(--accent);
}
@media (max-width: 600px) {
  .hero { padding: 108px 0 120px }
  .hero-slate { left: 16px; bottom: 20px; font-size: .52rem; letter-spacing: 1.5px }
  .hero-socials { right: 16px; bottom: 16px }
  .hero-desc { font-size: 1.02rem }
}

/* ── CLIENTS ── */
.clients-section {
  padding: 48px 0;
  border-bottom: 1px solid var(--border);
}
.clients-label {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--accent); text-align: center; margin-bottom: 32px;
}
.clients-grid {
  display: flex; align-items: center; justify-content: center;
  flex-wrap: wrap; gap: 40px 56px;
}
/* Dark mode: normaliza todo a blanco */
.client-logo {
  height: 44px; width: auto;
  filter: brightness(0) invert(1);
}
:global([data-theme="light"]) .client-logo {
  filter: brightness(0);
}
.clients-more {
  margin-top: 36px; text-align: center;
}
@media (max-width: 600px) {
  .clients-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 36px 24px; place-items: center;
  }
  .client-logo { height: 36px }
}

/* ── DISCIPLINES ── */
.disciplines-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 12px; margin-top: 48px;
}
@media (max-width: 900px) { .disciplines-grid { grid-template-columns: repeat(2,1fr) } }
@media (max-width: 480px) { .disciplines-grid { grid-template-columns: 1fr } }

.dc-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 24px 20px;
  display: flex; flex-direction: column; gap: 10px;
  position: relative; overflow: hidden; transition: border-color .2s;
}
.dc-card::after {
  content: ''; position: absolute;
  top: 0; left: 0; right: 0; height: 2px;
  background: var(--c); opacity: 0; transition: opacity .2s;
}
.dc-card:hover { border-color: var(--border-h) }
.dc-card:hover::after { opacity: 1 }
.dc-top { display: flex; align-items: flex-start; justify-content: space-between }
.dc-arrow { font-size: var(--text-sm); color: var(--muted); transition: transform .2s, color .2s }
.dc-card:hover .dc-arrow { transform: translate(3px,-3px); color: var(--white) }
.dc-title {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2px; text-transform: uppercase; color: var(--white);
}
.dc-desc { font-size: var(--text-base); color: var(--muted); line-height: 1.55 }

/* ── DEV ── */
.dev-section { background: var(--surface) }

/* Featured cards */
.featured-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 16px; margin-top: 40px;
}
@media (max-width: 700px) { .featured-grid { grid-template-columns: 1fr } }

.featured-card {
  position: relative;
  background: color-mix(in srgb, var(--c) 6%, var(--bg));
  border: 1px solid color-mix(in srgb, var(--c) 22%, var(--border));
  border-radius: 16px; padding: 24px;
  display: flex; flex-direction: column; gap: 10px;
  transition: border-color .2s, transform .2s, box-shadow .2s;
  overflow: hidden;
}
.featured-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--c); opacity: .7;
}
.featured-card:hover {
  border-color: color-mix(in srgb, var(--c) 50%, transparent);
  transform: translateY(-3px);
  box-shadow: 0 12px 40px color-mix(in srgb, var(--c) 12%, transparent);
}
.featured-top {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 4px;
}
.featured-meta { display: flex; align-items: center; gap: 8px }
.featured-year {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2px; color: var(--muted);
}
.featured-status {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 2px 8px; border-radius: 999px;
  font-weight: 600;
}
.featured-status.live { background: color-mix(in srgb, #22c55e 15%, transparent); color: #4ade80 }
.featured-status.beta { background: color-mix(in srgb, #f59e0b 15%, transparent); color: #fbbf24 }
.featured-arrow {
  font-size: 1rem; color: var(--muted);
  transition: transform .2s, color .2s;
}
.featured-card:hover .featured-arrow {
  transform: translate(3px,-3px);
  color: var(--c);
}
.featured-name {
  font-family: var(--display); font-size: 1.9rem;
  letter-spacing: 3px; color: var(--white);
}
.featured-tagline {
  font-size: .88rem; font-weight: 600;
  color: color-mix(in srgb, var(--c) 80%, var(--white));
  letter-spacing: .3px;
}
.featured-desc {
  font-size: var(--text-base); color: var(--muted);
  line-height: 1.6; flex: 1;
}

/* Other projects list */
.other-label {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--muted); margin-top: 48px; margin-bottom: 0;
}
.dev-list { display: flex; flex-direction: column }
.dev-row {
  display: flex; align-items: center;
  justify-content: space-between; gap: 24px;
  padding: 20px 0; border-bottom: 1px solid var(--border);
  transition: .2s;
}
.dev-row:first-child { border-top: 1px solid var(--border) }
.dev-row:hover .dev-name { color: var(--accent) }
.dev-row:hover .dev-arrow { transform: translate(4px,-4px) }
.dev-row-top { display: flex; align-items: baseline; gap: 12px; margin-bottom: 4px }
.dev-name {
  font-family: var(--display); font-size: 1.25rem;
  letter-spacing: 2px; transition: color .2s;
}
.dev-year {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 1.5px; color: var(--muted);
}
.dev-desc { font-size: var(--text-base); color: var(--muted); line-height: 1.5 }
.dev-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px }
.tag {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 4px;
  background: color-mix(in srgb, var(--white) 4%, transparent);
  border: 1px solid var(--border); color: var(--muted);
}
.dev-arrow { font-size: 1rem; color: var(--muted); flex-shrink: 0; transition: transform .2s }

/* ── CONTACTO ── */
.contact-band {
  padding: 88px 0;
  background:
