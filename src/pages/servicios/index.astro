---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const categories = [
  {
    id: 'fotografia',
    label: 'Fotografía',
    color: '#a0c4ff',
    icon: 'fa-camera',
    tagline: 'Cada momento, eterno.',
    desc: 'Cobertura profesional de eventos con ojo artístico y entrega rápida. Trabajo en toda Puerto Rico.',
    from: 'Desde $450',
    services: [
      {
        name: 'Fotografía para todo tipo de eventos',
        desc: 'Cobertura completa de bodas, celebraciones y eventos privados — desde la preparación hasta el cierre. Estilo documental + retratos artísticos.',
        includes: ['Cobertura completa', 'Galería digital privada', 'Selección editada', 'Derechos de impresión'],
        price: 'Desde $750',
        wa: 'Hola, me interesa cotizar fotografía para un evento.',
      },
      {
        name: 'Quinceañeros',
        desc: 'Sesiones íntimas y cobertura completa del evento. Documentamos cada emoción del día más especial.',
        includes: ['Sesión de retratos', 'Cobertura del evento', 'Galería digital', 'Entrega 4–6 semanas'],
        price: 'Desde $550',
        wa: 'Hola, me interesa cotizar fotografía para un quinceañero.',
      },
      {
        name: 'Eventos Sociales',
        desc: 'Cumpleaños, graduaciones, fiestas privadas y todo tipo de celebración. Cobertura dinámica y discreta.',
        includes: ['Cobertura del evento', 'Galería digital', 'Entrega rápida', 'Edición profesional'],
        price: 'Desde $450',
        wa: 'Hola, me interesa cotizar fotografía para un evento social.',
      },
      {
        name: 'Corporativo & Marca',
        desc: 'Headshots, eventos corporativos, productos y contenido para redes sociales que eleva tu marca.',
        includes: ['Retratos profesionales', 'Fotografía de producto', 'Licencia comercial', 'Entrega express'],
        price: 'Por cotización',
        wa: 'Hola, me interesa cotizar fotografía corporativa.',
      },
      {
        name: 'Retratos',
        desc: 'Sesiones personales, familiares, artísticas. Locaciones en Aibonito y alrededores o tu locación preferida.',
        includes: ['Sesión 1–2 horas', 'Selección editada', 'Galería digital', 'Guía de outfit'],
        price: 'Desde $175',
        wa: 'Hola, me interesa cotizar una sesión de retratos.',
      },
    ],
  },
  {
    id: 'videografia',
    label: 'Videografía',
    color: '#ff9f7f',
    icon: 'fa-video',
    tagline: 'Tu historia, en movimiento.',
    desc: 'Producción de video para eventos, marcas y contenido digital. Desde documentales emocionales hasta reels virales.',
    services: [
      {
        name: 'Video de Boda',
        desc: 'Cinematografía de boda completa — desde la preparación hasta la última canción. Storytelling emocional y auténtico.',
        includes: ['Film completo (4–8 min)', 'Highlights (90s)', 'Teaser para redes', 'Audio profesional'],
        price: 'Desde $1,500',
        wa: 'Hola, me interesa cotizar video para mi boda.',
      },
      {
        name: 'Quinceañeros',
        desc: 'Capturamos cada momento del día en un video cinematográfico que se convierte en un tesoro familiar.',
        includes: ['Film completo', 'Highlights para RRSS', 'Cobertura del evento', 'Música licenciada'],
        price: 'Desde $800',
        wa: 'Hola, me interesa cotizar video para un quinceañero.',
      },
      {
        name: 'Reels & Contenido',
        desc: 'Reels profesionales para Instagram, TikTok y YouTube. Contenido que conecta y convierte seguidores en clientes.',
        includes: ['Hasta 3 reels por sesión', 'Edición con trending audio', 'Formato vertical y horizontal', 'Entrega 48–72h'],
        price: 'Desde $150 por reel',
        wa: 'Hola, me interesa cotizar reels y contenido para redes sociales.',
      },
      {
        name: 'Corporativo & Marca',
        desc: 'Videos institucionales, testimoniales, demos de producto y campañas publicitarias para tu negocio.',
        includes: ['Guión y dirección', 'Múltiples tomas', 'Post-producción completa', 'Licencia comercial'],
        price: 'Desde $1,000',
        wa: 'Hola, me interesa cotizar video corporativo.',
      },
      {
        name: 'Documental',
        desc: 'Proyectos documentales de largo aliento — cultura, comunidad, arte. Contamos historias que importan.',
        includes: ['Pre-producción incluida', 'Producción multicámara', 'Post-producción completa', 'Color grading'],
        price: 'Desde $2,500',
        wa: 'Hola, me interesa cotizar un documental.',
      },
    ],
  },
  {
    id: 'diseno',
    label: 'Diseño Gráfico',
    color: '#e8c84a',
    icon: 'fa-pen-nib',
    tagline: 'Identidad que impacta.',
    desc: 'Diseño gráfico estratégico para marcas que quieren verse profesionales y destacar en Puerto Rico y más allá.',
    services: [
      {
        name: 'Branding & Identidad',
        desc: 'Creación completa de identidad de marca — logo, paleta de colores, tipografía, voz y guía de estilo.',
        includes: ['Logo principal + variantes', 'Paleta de color', 'Tipografía de marca', 'Brand guide PDF'],
        price: 'Desde $500',
        wa: 'Hola, me interesa cotizar branding e identidad visual.',
      },
      {
        name: 'Diseño Digital',
        desc: 'Posts para redes sociales, stories, banners, presentaciones y assets digitales con consistencia de marca.',
        includes: ['Templates editables', 'Formatos para RRSS', 'Entrega en PNG/PDF/SVG', 'Revisiones incluidas'],
        price: 'Desde $50 por pieza',
        wa: 'Hola, me interesa cotizar diseño digital para redes sociales.',
      },
      {
        name: 'Print & Impresión',
        desc: 'Tarjetas de presentación, flyers, menús, señalización y todo material impreso listo para producción.',
        includes: ['Diseño listo para imprenta', 'Archivos CMYK', 'Alta resolución', 'Múltiples formatos'],
        price: 'Desde $50 por pieza',
        wa: 'Hola, me interesa cotizar diseño para imprimir.',
      },
      {
        name: 'Diseño Editorial',
        desc: 'Revistas, catálogos, booklets, anuarios. Diseño editorial con jerarquía visual clara y elegante.',
        includes: ['Maquetación completa', 'Revisiones incluidas', 'Archivo InDesign/PDF', 'Corrección de color'],
        price: 'Desde $250',
        wa: 'Hola, me interesa cotizar diseño editorial.',
      },
    ],
  },
  {
    id: 'booth360',
    label: '360 Booth',
    color: '#d946ef',
    icon: 'fa-rotate',
    tagline: 'La experiencia viral.',
    desc: 'El Air-39 Automatic 360 Pro — la plataforma giratoria que crea clips cinematográficos al instante para cada invitado.',
    services: [
      {
        name: '360 Video Booth — Eventos',
        desc: 'La plataforma Air-39 gira automáticamente 360° alrededor de tus invitados y genera clips con efectos, slow motion y overlay del evento.',
        includes: ['Setup y operación incluidos', 'Ring light profesional', 'Entrega por QR al instante', 'Galería digital del evento'],
        price: 'Desde $350 (2 hrs)',
        wa: 'Hola, me interesa cotizar el 360 Video Booth para mi evento.',
      },
      {
        name: '360 Booth — Bodas',
        desc: 'El momento más viral de tu recepción. Todos tus invitados se llevan un clip 360° con el branding de tu boda.',
        includes: ['Overlay personalizado', 'Música de fondo del evento', 'Tomas ilimitadas', 'Galería privada'],
        price: 'Desde $499 (4 hrs)',
        wa: 'Hola, me interesa el 360 Video Booth para mi boda.',
      },
      {
        name: '360 Booth — Corporativo',
        desc: 'Activaciones de marca, lanzamientos y eventos corporativos con experiencia 360° branded para tu empresa.',
        includes: ['Overlay con logo de empresa', 'Entrega inmediata por QR', 'Informe post-evento', 'Opciones de personalización'],
        price: 'Desde $499',
        wa: 'Hola, me interesa el 360 Video Booth para un evento corporativo.',
      },
    ],
  },
  {
    id: 'desarrollo',
    label: 'Desarrollo',
    color: '#88e0b0',
    icon: 'fa-code',
    tagline: 'Software que funciona.',
    desc: 'Plataformas web, apps y herramientas digitales diseñadas y desarrolladas de principio a fin. Desde la idea hasta el launch.',
    services: [
      {
        name: 'Plataformas Web',
        desc: 'Sitios web y plataformas completas — desde portfolios hasta e-commerce y SaaS. Stack moderno, rápido y mantenible.',
        includes: ['Diseño UI/UX incluido', 'CMS o admin panel', 'SEO técnico', 'Deployment y hosting'],
        price: 'Desde $800',
        wa: 'Hola, me interesa cotizar el desarrollo de una plataforma web.',
      },
      {
        name: 'Apps & Herramientas',
        desc: 'Aplicaciones web, dashboards internos y herramientas a la medida para optimizar procesos de tu negocio.',
        includes: ['Análisis de requerimientos', 'UI/UX incluido', 'APIs e integraciones', 'Soporte post-lanzamiento'],
        price: 'Desde $1,500',
        wa: 'Hola, me interesa cotizar el desarrollo de una app o herramienta.',
      },
      {
        name: 'E-Commerce',
        desc: 'Tiendas online con carrito, pagos (Stripe, ATH Móvil), inventario y panel admin para negocios en Puerto Rico.',
        includes: ['Tienda completa', 'Pagos locales', 'Panel de administración', 'Training incluido'],
        price: 'Desde $1,500',
        wa: 'Hola, me interesa cotizar una tienda en línea (e-commerce).',
      },
    ],
  },
];

const testimonials = [
  {
    quote: 'Marcos capturó nuestra boda en Ponce mejor de lo que imaginamos. Cada foto cuenta una historia. Entregó la galería antes de lo prometido — calidad y profesionalismo totales.',
    name: 'Gabriela M.',
    location: 'Ponce, PR',
    service: 'Fotografía · Boda',
  },
  {
    quote: 'El video de la quinceañera de mi hija nos dejó sin palabras. El highlights para Instagram tuvo más de 8,000 reproducciones en los primeros días. Vale cada centavo.',
    name: 'Carmen R.',
    location: 'Bayamón, PR',
    service: 'Videografía · Quinceañero',
  },
  {
    quote: 'El 360 Booth fue el hit de la recepción. Los invitados hacían fila para grabarse y se fueron con su clip al instante por QR. Lo recomendaría mil veces.',
    name: 'Luis & Andrea P.',
    location: 'San Juan, PR',
    service: '360 Booth · Boda',
  },
  {
    quote: 'Marcos diseñó la identidad completa de nuestra empresa. Logo, paleta, posts — todo consistente y profesional. Nuestros clientes notan el cambio inmediatamente.',
    name: 'Roberto F.',
    location: 'Aibonito, PR',
    service: 'Diseño · Branding',
  },
];
---
<Base
  title="Fotógrafo, Videógrafo & Artista Gráfico en Puerto Rico | Marcos Santiago"
  description="Fotografía de bodas, quinceañeros y eventos · Videografía · Artista gráfico · 360 Video Booth · Desarrollo web. Cobertura en toda Puerto Rico. Cotiza gratis por WhatsApp."
>
  <!-- JSON-LD LocalBusiness + Services -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "name": "Marcos Santiago",
        "url": "https://marcossantiago.com/servicios/",
        "telephone": "+17872439670",
        "image": "https://marcossantiago.com/marcos-photo.jpg",
        "description": "Fotógrafo, videógrafo, artista gráfico y desarrollador web profesional en Puerto Rico.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Aibonito",
          "addressRegion": "PR",
          "addressCountry": "US"
        },
        "areaServed": "Puerto Rico",
        "priceRange": "$$",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicios creativos Puerto Rico",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fotografía de Bodas Puerto Rico" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fotografía de Quinceañeros Puerto Rico" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Videografía de Bodas Puerto Rico" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reels para Redes Sociales Puerto Rico" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "360 Video Booth Puerto Rico" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Artista Gráfico y Branding Puerto Rico" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Desarrollo Web Puerto Rico" } }
          ]
        }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Cuánto cuesta un fotógrafo de bodas en Puerto Rico?",
            "acceptedAnswer": { "@type": "Answer", "text": "El costo varía según la cobertura y duración del evento. Contáctame por WhatsApp para una cotización personalizada gratis." }
          },
          {
            "@type": "Question",
            "name": "¿Trabajan en toda Puerto Rico?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí, cubro eventos en toda la isla — desde Aibonito hasta San Juan, Ponce, Mayagüez y cualquier municipio." }
          },
          {
            "@type": "Question",
            "name": "¿Qué es el 360 Video Booth?",
            "acceptedAnswer": { "@type": "Answer", "text": "El Air-39 Automatic 360 Pro es una plataforma giratoria que graba clips 360° de tus invitados con efectos y entrega instantánea por QR. Ideal para bodas, quinceañeros y eventos corporativos." }
          },
          {
            "@type": "Question",
            "name": "¿Cuánto tiempo tarda la entrega de fotos?",
            "acceptedAnswer": { "@type": "Answer", "text": "La galería digital se entrega entre 4 y 6 semanas después del evento, dependiendo del tipo de cobertura." }
          },
          {
            "@type": "Question",
            "name": "¿Ofrecen paquetes combinados de foto y video?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí, ofrezco paquetes combinados de fotografía y videografía para bodas y eventos. Escríbeme por WhatsApp para ver opciones." }
          }
        ]
      }
    ]
  })} />

  <Nav />
  <main>

    <!-- ── Hero ── -->
    <section class="hero-section">
      <img class="servicios-video-bg servicios-poster" src="/videos/marcos-video-poster.webp" alt="" aria-hidden="true" fetchpriority="high" />
      <video class="servicios-video-bg servicios-video" muted loop playsinline preload="none" data-src-webm="/videos/marcos-video-web.webm" data-src-mp4="/videos/marcos-video-web.mp4"></video>
      <div class="servicios-video-overlay"></div>
      <div class="container hero-content">
        <p class="section-label">Fotógrafo · Videógrafo · Artista Gráfico · Puerto Rico</p>
        <h1 class="hero-title">
          Captura tu<br>
          <span class="hero-title-sub hero-cycle" aria-label="momento, diseño, código">
            <span class="hero-cycle-track" aria-hidden="true">
              <span>momento.</span>
              <span>diseño.</span>
              <span>código.</span>
              <span>momento.</span>
            </span>
          </span>
        </h1>
        <ul class="hero-bullets" aria-label="Lo que ofrezco">
          <li><i class="fa-solid fa-bolt"></i> Cotización en menos de 1 hora</li>
          <li><i class="fa-solid fa-location-dot"></i> Toda Puerto Rico</li>
          <li><i class="fa-solid fa-handshake"></i> Trato directo conmigo</li>
        </ul>

        <!-- Bento chooser: 1 card grande (la primera = fotografía, servicio principal) + 4 chicas -->
        <p class="chooser-prompt">¿Qué te interesa? Escoge y baja directo:</p>
        <div class="hero-chooser hero-chooser-bento" role="tablist" aria-label="Elige un servicio">
          {categories.map((cat, idx) => {
            // Captura el primer $X o $X,XXX en cada price string; ignora "(2 hrs)" etc.
            const minPrice = cat.services
              .map(s => {
                const m = (s.price || '').match(/\$([\d,]+)/);
                return m ? parseFloat(m[1].replace(/,/g, '')) : NaN;
              })
              .filter(n => !isNaN(n) && n > 0);
            const startsAt = cat.from || (minPrice.length ? `Desde $${Math.min(...minPrice).toLocaleString('en-US')}` : 'Por cotización');
            const isFeatured = idx === 0; // primera categoría = card grande (Fotografía)
            return (
              <button
                class={`chooser-card ${isFeatured ? 'chooser-card-featured' : ''}`}
                data-target={cat.id}
                style={`--cat-c: ${cat.color}`}
                role="tab"
                aria-controls={cat.id}
              >
                <span class="chooser-icon"><i class={`fa-solid ${cat.icon}`}></i></span>
                <span class="chooser-label">{cat.label}</span>
                {isFeatured && <span class="chooser-tagline">{cat.tagline}</span>}
                <span class="chooser-price">{startsAt}</span>
                {isFeatured && <span class="chooser-arrow"><i class="fa-solid fa-arrow-right"></i></span>}
              </button>
            );
          })}
        </div>

        <div class="hero-actions">
          <a href="tel:+17872439670" class="hero-cta hero-cta-call" data-track="call">
            <i class="fa-solid fa-phone"></i> Llamar ahora
          </a>
          <a
            href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20conocer%20tus%20servicios."
            target="_blank" rel="noopener"
            class="hero-cta hero-cta-wa"
            data-track="whatsapp"
          >
            <i class="fab fa-whatsapp"></i> WhatsApp
          </a>
          <a href="#cotizar" class="hero-cta hero-cta-form">
            <i class="fa-solid fa-paper-plane"></i> Cotización rápida
          </a>
        </div>
        <div class="hero-meta">
          <span class="meta-pill"><i class="fa-solid fa-location-dot"></i> Puerto Rico</span>
          <span class="meta-pill"><i class="fa-regular fa-clock"></i> Respondo en menos de 1 hora</span>
          <a href="tel:+17872439670" class="meta-pill meta-pill-call" data-track="call">
            <i class="fa-solid fa-phone"></i> (787) 243-9670
          </a>
        </div>
      </div>
    </section>

    <!-- ── Lead form ── -->
    <section class="lead-section" id="cotizar">
      <div class="container">
        <div class="lead-grid">
          <div class="lead-intro">
            <p class="section-label">Cotización Rápida</p>
            <h2 class="lead-title">Te respondo en <span class="accent">menos de 1 hora</span></h2>
            <p class="lead-sub">Tres campos. Sin spam. Sin compromiso. Te contesto directo yo, no un asistente.</p>
            <ul class="lead-trust">
              <li><i class="fa-solid fa-check"></i> Cotización gratis</li>
              <li><i class="fa-solid fa-check"></i> Disponible para toda Puerto Rico</li>
              <li><i class="fa-solid fa-check"></i> Respuesta personal de Marcos</li>
            </ul>
          </div>
          <form class="lead-form" id="leadForm" novalidate>
            <div class="lead-row">
              <input type="text" required class="lead-field" name="nombre" placeholder="Tu nombre *" autocomplete="name" />
              <input type="tel" required class="lead-field" name="contacto" placeholder="Teléfono o WhatsApp *" autocomplete="tel" />
            </div>
            <select required class="lead-field" name="servicio">
              <option value="">Servicio que te interesa *</option>
              <option>Fotografía</option>
              <option>Videografía</option>
              <option>Diseño Gráfico</option>
              <option>360 Booth</option>
              <option>Desarrollo Web</option>
              <option>Paquete combinado</option>
            </select>
            <input type="text" class="lead-field" name="fecha" placeholder="Fecha aproximada (opcional)" />
            <textarea class="lead-field" name="mensaje" rows="2" placeholder="Cuéntame brevemente (opcional)"></textarea>
            <button type="submit" class="lead-submit" data-track="form">
              <i class="fa-solid fa-paper-plane"></i> Enviar cotización
            </button>
            <p class="lead-note">¿Prefieres directo? <a href="tel:+17872439670" data-track="call"><i class="fa-solid fa-phone"></i> Llamar</a> o <a href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto." target="_blank" rel="noopener" data-track="whatsapp"><i class="fab fa-whatsapp"></i> WhatsApp</a>.</p>
            <p class="lead-success" id="leadSuccess" hidden>
              <i class="fa-solid fa-circle-check"></i> Mensaje recibido. Te respondo en menos de 1 hora.
            </p>
            <p class="lead-error" id="leadError" hidden>
              <i class="fa-solid fa-triangle-exclamation"></i> No pude enviar el mensaje. Escríbeme por WhatsApp al (787) 243-9670.
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- ── Quién soy ── -->
    <section class="meet-section">
      <div class="container">
        <div class="meet-grid">
          <div class="meet-photo">
            <img src="/marcos-photo.webp" alt="Marcos Santiago — fotógrafo, videógrafo y artista gráfico en Puerto Rico" loading="lazy" />
            <div class="meet-photo-bg" aria-hidden="true"></div>
          </div>
          <div class="meet-text">
            <p class="section-label">Quién va a contestar tu mensaje</p>
            <h2 class="meet-title">Soy Marcos.</h2>
            <p class="meet-bio">
              Desde 2001 en diseño gráfico y desarrollo web, desde 2012 en fotografía y video. Trabajo desde Aibonito, Puerto Rico — donde nací — pero cubro toda la isla. No soy un equipo: soy yo el que te contesta el teléfono, el que llega al evento, el que edita tus fotos.
            </p>
            <p class="meet-promise">
              <strong>Juntos podemos hacer de tu negocio una ventana abierta al mundo.</strong>
            </p>
            <div class="meet-facts">
              <div class="meet-fact"><span class="meet-fact-num">+24</span><span class="meet-fact-label">años en diseño</span></div>
              <div class="meet-fact"><span class="meet-fact-num">+13</span><span class="meet-fact-label">años en foto y video</span></div>
              <div class="meet-fact"><span class="meet-fact-num">PR</span><span class="meet-fact-label">toda la isla</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Trabajo real (video reel de fondo, contenido encima, marquee de logos edge-to-edge debajo) ── -->
    <section class="proof-section">
      <!-- Video de fondo (full section) -->
      <video class="proof-video-bg" muted loop playsinline preload="none" width="1920" height="1080" poster="/videos/marcos-video-poster.webp" aria-hidden="true">
        <source src="/short-videografy.mp4" type="video/mp4" />
      </video>
      <div class="proof-video-overlay" aria-hidden="true"></div>

      <div class="container proof-content">
        <div class="proof-head">
          <p class="section-label">Trabajo real</p>
          <h2 class="proof-title">Lo que <span class="accent">ya he construido</span> en Puerto Rico</h2>
        </div>
        <p class="proof-logos-count">
          <span class="proof-num">+50</span> marcas confían en mi trabajo
        </p>
      </div>

      <!-- Marquee FUERA del container — edge to edge del viewport -->
      <div class="logos-marquee" aria-hidden="true">
        <div class="logos-track">
          {/* Mismo set que la galería /portafolio/logos/ — preserva el orden y los formatos PNG/SVG curados manualmente */}
          {(() => {
            const logos = [
              'abogo.png','amanda-forastieri.png','amma-club.png','babyabrazo.png',
              'bambu.png','bayuu.png','ber.png','biz-solutions-studio.png',
              'brava.png','buoyant-research.png','candi.svg','celebrate-dogs.png',
