---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const modules    = import.meta.glob('./*.mdx', { eager: true });
const rawModules = import.meta.glob('./*.mdx', { eager: true, query: '?raw', import: 'default' });

function readingTime(raw: string): number {
  const content = raw.replace(/^---[\s\S]*?---/, '').replace(/<[^>]+>/g, ' ');
  const words   = content.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 220));
}

function fmtDate(d: string) {
  const [y, m, day] = d.split('-').map(Number);
  return new Date(y, m - 1, day).toLocaleDateString('es-PR', { year: 'numeric', month: 'short', day: 'numeric' });
}

const posts = Object.entries(modules)
  .map(([path, p]: [string, any]) => {
    const raw = String(rawModules[path] ?? '');
    return {
      title:   p.frontmatter.title,
      date:    p.frontmatter.date,
      tags:    p.frontmatter.tags || [],
      slug:    p.frontmatter.slug,
      desc:    p.frontmatter.desc || '',
      minRead: readingTime(raw),
    };
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const featured = posts[0];
const rest     = posts.slice(1);
const allTags  = [...new Set(posts.flatMap(p => p.tags))].sort();
---
<Base title="Blog — Marcos Santiago" description="Programación, diseño, fotografía, video y lo que me pase por la cabeza. Por Marcos Santiago desde Aibonito, Puerto Rico.">
  <Nav />
  <main style="padding-top:120px">
    <div class="container">

      <div class="blog-header">
        <div>
          <p class="section-label">Blog</p>
          <h1 class="section-title">Escribo sobre<br>lo que hago</h1>
        </div>
        <p class="blog-count">{posts.length} posts</p>
      </div>

      {posts.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <h2 class="empty-title">Próximamente</h2>
          <p class="empty-sub">Los posts están en camino. Vuelve pronto.</p>
        </div>
      ) : (
        <>
          <a href={`/blog/${featured.slug}/`} class="featured-card">
            <div class="featured-top">
              <span class="featured-badge">Último post</span>
              <div class="featured-meta">
                <span>{fmtDate(featured.date)}</span>
                <span class="meta-sep">·</span>
                <span>{featured.minRead} min de lectura</span>
              </div>
            </div>
            <h2 class="featured-title">{featured.title}</h2>
            <p class="featured-desc">{featured.desc}</p>
            <div class="featured-footer">
              <div class="post-tags">
                {featured.tags.map((t: string) => <span class="tag">{t}</span>)}
              </div>
              <span class="featured-arrow">Leer →</span>
            </div>
          </a>

          {allTags.length > 0 && (
            <div class="tag-filters">
              <button class="filter-btn active" data-tag="all">Todos</button>
              {allTags.map(t => (
                <button class="filter-btn" data-tag={t}>{t}</button>
              ))}
            </div>
          )}

          <div class="posts-grid">
            {rest.map(p => (
              <a href={`/blog/${p.slug}/`} class="post-card" data-tags={p.tags.join(',')}>
                <div class="post-card-top">
                  <div class="post-card-meta">
                    <span>{fmtDate(p.date)}</span>
                    <span class="meta-sep">·</span>
                    <span>{p.minRead} min</span>
                  </div>
                  <span class="post-arrow">→</span>
                </div>
                <h2 class="post-card-title">{p.title}</h2>
                <p class="post-card-desc">{p.desc}</p>
                <div class="post-tags">
                  {p.tags.map((t: string) => <span class="tag">{t}</span>)}
                </div>
              </a>
            ))}
          </div>
        </>
      )}

    </div>
  </main>
  <Footer />
</Base>

<script>
  const filters = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
  const cards   = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;
  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      filters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tag = btn.dataset.tag ?? 'all';
      cards.forEach(card => {
        const tags = card.dataset.tags ?? '';
        card.style.display = (tag === 'all' || tags.split(',').includes(tag)) ? '' : 'none';
      });
    });
  });
</script>

<style>
.blog-header {
  display: flex; align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 48px; flex-wrap: wrap; gap: 16px;
}
.blog-count {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); padding-bottom: 8px;
}
.featured-card {
  display: block;
  background: color-mix(in srgb, var(--accent) 6%, var(--surface));
  border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--border));
  border-radius: 20px; padding: 40px;
  margin-bottom: 32px; position: relative; overflow: hidden;
  transition: border-color .2s, box-shadow .2s;
}
.featured-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--accent), transparent);
}
.featured-card:hover {
  border-color: color-mix(in srgb, var(--accent) 50%, transparent);
  box-shadow: 0 8px 40px color-mix(in srgb, var(--accent) 8%, transparent);
}
.featured-top {
  display: flex; align-items: center; gap: 16px;
  margin-bottom: 20px; flex-wrap: wrap;
}
.featured-badge {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase;
  padding: 4px 12px; border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 15%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
  color: var(--accent);
}
.featured-meta {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; color: var(--muted);
}
.featured-title {
  font-family: var(--display);
  font-size: clamp(2rem, 4vw, 3.5rem);
  letter-spacing: 2px; line-height: 1.05;
  color: var(--white); margin-bottom: 16px; transition: color .2s;
}
.featured-card:hover .featured-title { color: var(--accent) }
.featured-desc {
  font-size: var(--text-base); color: var(--muted);
  line-height: 1.7; max-width: 70ch; margin-bottom: 24px;
}
.featured-footer {
  display: flex; align-items: center;
  justify-content: space-between; flex-wrap: wrap; gap: 12px;
}
.featured-arrow {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2px; color: var(--accent); transition: transform .2s;
}
.featured-card:hover .featured-arrow { transform: translateX(4px) }
.tag-filters {
  display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px;
}
.filter-btn {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase;
  padding: 7px 16px; border-radius: 999px;
  border: 1px solid var(--border);
  background: transparent; color: var(--muted);
  cursor: pointer; transition: .2s ease;
}
.filter-btn:hover { border-color: var(--border-h); color: var(--white) }
.filter-btn.active {
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  border-color: color-mix(in srgb, var(--accent) 45%, transparent);
  color: var(--accent);
}
.posts-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 16px; margin-bottom: 80px;
}
@media (max-width: 700px) { .posts-grid { grid-template-columns: 1fr } }
.post-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 16px; padding: 28px;
  display: flex; flex-direction: column; gap: 12px;
  transition: border-color .2s, transform .2s, box-shadow .2s;
}
.post-card:hover {
  border-color: var(--border-h);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(0,0,0,.2);
}
.post-card-top {
  display: flex; align-items: center; justify-content: space-between;
}
.post-card-meta {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; color: var(--muted);
}
.post-arrow { color: var(--muted); font-size: var(--text-sm); transition: transform .2s, color .2s }
.post-card:hover .post-arrow { transform: translateX(4px); color: var(--white) }
.post-card-title {
  font-family: var(--display);
  font-size: clamp(1.3rem, 2.2vw, 1.8rem);
  letter-spacing: 2px; line-height: 1.05;
  color: var(--white); transition: color .2s; flex: 1;
}
.post-card:hover .post-card-title { color: var(--accent) }
.post-card-desc { font-size: var(--text-sm); color: var(--muted); line-height: 1.6 }
.post-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: auto }
.tag {
  font-family: var(--mono); font-size: .6rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 4px;
  background: color-mix(in srgb, var(--white) 4%, transparent);
  border: 1px solid var(--border); color: var(--muted);
}
.meta-sep { opacity: .4 }
.empty-state {
  margin-top: 80px; display: flex; flex-direction: column;
  align-items: center; text-align: center; padding: 80px 40px;
  background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
}
.empty-icon { margin-bottom: 20px; color: var(--muted) }
.empty-title {
  font-family: var(--display); font-size: clamp(2rem, 4vw, 3.5rem);
  letter-spacing: 2px; color: var(--white); margin-bottom: 12px;
}
.empty-sub { color: var(--muted); font-size: var(--text-base) }
</style>
