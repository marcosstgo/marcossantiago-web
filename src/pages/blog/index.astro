---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const modules = import.meta.glob('./*.mdx', { eager: true });
const posts = Object.values(modules)
  .map((p: any) => ({
    title: p.frontmatter.title,
    date: p.frontmatter.date,
    tags: p.frontmatter.tags || [],
    slug: p.frontmatter.slug,
    desc: p.frontmatter.desc || '',
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---
<Base title="Blog — Marcos Santiago" description="Programación, diseño, fotografía, video y lo que me pase por la cabeza. Por Marcos Santiago desde Aibonito, Puerto Rico.">
  <Nav />
  <main style="padding-top:120px">
    <div class="container">
      <p class="section-label">Blog</p>
      <h1 class="section-title">Escribo sobre<br>lo que hago</h1>
      <p class="section-sub">Programación, diseño, fotografía, video y lo que me pase por la cabeza.</p>

      {posts.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h2 class="empty-title">Próximamente</h2>
          <p class="empty-sub">Los posts están en camino. Vuelve pronto.</p>
        </div>
      ) : (
        <div class="posts-list">
          {posts.map(p => (
            <a href={`/blog/${p.slug}/`} class="post-row">
              <div class="post-meta">
                <span class="post-date">{p.date}</span>
                <div class="post-tags">
                  {p.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
              <div>
                <h2 class="post-title">{p.title}</h2>
                <p class="post-desc">{p.desc}</p>
              </div>
              <span class="post-arrow">→</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Base>

<style>
.empty-state {
  margin-top: 80px;
  display: flex; flex-direction: column;
  align-items: center; text-align: center;
  padding: 80px 40px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px; color: var(--dim);
}
.empty-icon { margin-bottom: 20px }
.empty-title {
  font-family: var(--display);
  font-size: clamp(2rem, 4vw, 3.5rem);
  letter-spacing: 2px; color: var(--white); margin-bottom: 12px;
}
.empty-sub { color: var(--muted); font-size: .9rem }

/* Post list — used when posts exist */
.posts-list { display: flex; flex-direction: column; margin-top: 56px }
.post-row {
  display: grid; grid-template-columns: 180px 1fr auto;
  gap: 32px; align-items: start;
  padding: 28px 0; border-bottom: 1px solid var(--border);
  transition: .2s;
}
.post-row:first-child { border-top: 1px solid var(--border) }
@media (max-width: 768px) {
  .post-row { grid-template-columns: 1fr auto; }
  .post-meta { display: none }
}
.post-meta { display: flex; flex-direction: column; gap: 8px; padding-top: 4px }
.post-date {
  font-family: var(--mono); font-size: .5rem;
  letter-spacing: 2px; color: var(--dim);
}
.post-tags { display: flex; gap: 4px; flex-wrap: wrap }
.tag {
  font-family: var(--mono); font-size: .44rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 2px 6px; border-radius: 4px;
  background: rgba(255,255,255,.04); border: 1px solid var(--border);
  color: var(--dim);
}
.post-title {
  font-family: var(--display);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  letter-spacing: 2px; color: var(--white);
  transition: color .2s; margin-bottom: 6px;
}
.post-row:hover .post-title { color: var(--accent) }
.post-desc { font-size: .85rem; color: var(--muted); line-height: 1.6 }
.post-arrow { font-size: 1.1rem; color: var(--muted); padding-top: 4px; transition: transform .2s }
.post-row:hover .post-arrow { transform: translateX(4px); color: var(--white) }
</style>
