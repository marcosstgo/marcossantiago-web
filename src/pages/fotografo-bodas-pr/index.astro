---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
---
<Base
  title="Fotógrafo de Bodas en Puerto Rico | Marcos Santiago"
  description="Fotografía de bodas en Puerto Rico desde $750. Cobertura completa, galería digital, entrega 4-6 semanas. Cotización gratis. Respondo en menos de 1 hora."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "name": "Marcos Santiago — Fotógrafo de Bodas",
        "url": "https://marcossantiago.com/fotografo-bodas-pr/",
        "telephone": "+17872439670",
        "image": "https://marcossantiago.com/marcos-photo.jpg",
        "description": "Fotógrafo de bodas profesional en Puerto Rico. Cobertura de bodas desde $750. Toda la isla.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Aibonito",
          "addressRegion": "PR",
          "addressCountry": "US"
        },
        "areaServed": "Puerto Rico",
        "priceRange": "$$",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Fotografía de Bodas Puerto Rico",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fotografía de Bodas Puerto Rico" }, "price": "750", "priceCurrency": "USD" },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Paquete Foto + Video Boda Puerto Rico" } }
          ]
        }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Cuánto cuesta un fotógrafo de bodas en Puerto Rico?",
            "acceptedAnswer": { "@type": "Answer", "text": "La cobertura de bodas comienza desde $750, dependiendo de la duración y los servicios incluidos. Contáctame por WhatsApp para una cotización personalizada gratis." }
          },
          {
            "@type": "Question",
            "name": "¿Cubres bodas en toda Puerto Rico?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí, cubro bodas en toda la isla — desde Aibonito hasta San Juan, Ponce, Mayagüez, Rincón y cualquier municipio." }
          },
          {
            "@type": "Question",
            "name": "¿Cuándo recibo mis fotos?",
            "acceptedAnswer": { "@type": "Answer", "text": "La galería digital se entrega entre 4 y 6 semanas después de tu boda. Incluye selección editada completa con derechos de impresión." }
          },
          {
            "@type": "Question",
            "name": "¿Ofrecen paquetes de foto y video para bodas?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí, ofrezco paquetes combinados de fotografía y videografía para bodas. Escríbeme por WhatsApp para ver las opciones disponibles." }
          },
          {
            "@type": "Question",
            "name": "¿Cuánto tiempo antes debo reservar?",
            "acceptedAnswer": { "@type": "Answer", "text": "Lo ideal es reservar con 3 a 6 meses de anticipación, especialmente para temporada alta (diciembre–enero y verano). Contáctame para verificar disponibilidad." }
          }
        ]
      }
    ]
  })} />

  <!-- Minimal PPC header — no escape nav -->
  <header class="ppc-header">
    <div class="container ppc-header-inner">
      <a href="/" class="ppc-logo" aria-label="Marcos Santiago — inicio">MARCOS SANTIAGO</a>
      <a href="tel:+17872439670" class="ppc-phone" data-track="call-header">
        <i class="fa-solid fa-phone"></i> (787) 243-9670
      </a>
    </div>
  </header>

  <main>
    <!-- ── Hero ── -->
    <section class="hero-section">
      <img class="hero-bg-img" src="/videos/marcos-video-poster.webp" alt="" aria-hidden="true" fetchpriority="high" />
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="container hero-content">
        <p class="section-label">Fotógrafo de Bodas · Puerto Rico</p>
        <h1 class="hero-title">Tu boda,<br><span class="accent">recordada para siempre.</span></h1>
        <ul class="hero-bullets">
          <li><i class="fa-solid fa-camera"></i> Estilo documental + retratos artísticos</li>
          <li><i class="fa-solid fa-location-dot"></i> Toda Puerto Rico — desde Aibonito</li>
          <li><i class="fa-solid fa-bolt"></i> Cotización gratis en menos de 1 hora</li>
        </ul>
        <div class="hero-price-strip">
          <span class="price-badge">Desde <strong>$750</strong></span>
          <span class="price-note">· Galería digital incluida · Derechos de impresión</span>
        </div>
        <div class="hero-actions">
          <a href="tel:+17872439670" class="hero-cta hero-cta-call" data-track="call">
            <i class="fa-solid fa-phone"></i> Llamar ahora
          </a>
          <a
            href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20cotizar%20fotograf%C3%ADa%20para%20mi%20boda."
            target="_blank" rel="noopener"
            class="hero-cta hero-cta-wa"
            data-track="whatsapp"
          >
            <i class="fab fa-whatsapp"></i> WhatsApp
          </a>
          <a href="#cotizar" class="hero-cta hero-cta-form">
            <i class="fa-solid fa-paper-plane"></i> Cotización rápida
          </a>
        </div>
        <div class="hero-meta">
          <span class="meta-pill"><i class="fa-solid fa-location-dot"></i> Toda Puerto Rico</span>
          <span class="meta-pill"><i class="fa-regular fa-clock"></i> Respondo en &lt;1 hora</span>
          <a href="tel:+17872439670" class="meta-pill meta-pill-call" data-track="call">
            <i class="fa-solid fa-phone"></i> (787) 243-9670
          </a>
        </div>
      </div>
    </section>

    <!-- ── Servicios incluidos ── -->
    <section class="includes-section">
      <div class="container">
        <p class="section-label">Qué incluye</p>
        <h2 class="section-title">Cobertura completa <span class="accent">de tu boda</span></h2>
        <div class="includes-grid">
          <div class="include-card">
            <i class="fa-solid fa-camera include-icon"></i>
            <h3>Boda completa</h3>
            <p>Desde la preparación hasta el baile final. Cobertura documental + retratos artísticos de la pareja.</p>
            <span class="include-price">Desde $750</span>
          </div>
          <div class="include-card">
            <i class="fa-solid fa-heart include-icon"></i>
            <h3>Quinceañeros</h3>
            <p>Sesión de retratos íntimos + cobertura completa del evento. Cada emoción, documentada.</p>
            <span class="include-price">Desde $550</span>
          </div>
          <div class="include-card">
            <i class="fa-solid fa-star include-icon"></i>
            <h3>Foto + Video</h3>
            <p>Paquete combinado de fotografía y videografía para bodas. Todo con un solo profesional de confianza.</p>
            <span class="include-price">Por cotización</span>
          </div>
        </div>
        <div class="includes-checklist">
          <span><i class="fa-solid fa-check"></i> Galería digital privada</span>
          <span><i class="fa-solid fa-check"></i> Selección editada completa</span>
          <span><i class="fa-solid fa-check"></i> Derechos de impresión</span>
          <span><i class="fa-solid fa-check"></i> Entrega 4–6 semanas</span>
          <span><i class="fa-solid fa-check"></i> Backup de archivos</span>
          <span><i class="fa-solid fa-check"></i> Acceso a galería Pixieset</span>
        </div>
      </div>
    </section>

    <!-- ── Lead form ── -->
    <section class="lead-section" id="cotizar">
      <div class="container">
        <div class="lead-grid">
          <div class="lead-intro">
            <p class="section-label">Cotización de Boda</p>
            <h2 class="lead-title">Te respondo en <span class="accent">menos de 1 hora</span></h2>
            <p class="lead-sub">Sin spam. Sin compromiso. Te contesto directo yo, no un asistente.</p>
            <ul class="lead-trust">
              <li><i class="fa-solid fa-check"></i> Cotización gratis</li>
              <li><i class="fa-solid fa-check"></i> Disponible en toda Puerto Rico</li>
              <li><i class="fa-solid fa-check"></i> Respuesta personal de Marcos</li>
            </ul>
          </div>
          <form class="lead-form" id="leadForm" novalidate>
            <div class="lead-row">
              <input type="text" required class="lead-field" name="nombre" placeholder="Tu nombre *" autocomplete="name" />
              <input type="tel" required class="lead-field" name="contacto" placeholder="Teléfono o WhatsApp *" autocomplete="tel" />
            </div>
            <input type="hidden" name="servicio" value="Fotografía de Bodas" />
            <input type="text" class="lead-field" name="fecha" placeholder="Fecha aproximada de la boda (opcional)" />
            <textarea class="lead-field" name="mensaje" rows="2" placeholder="Cuéntame brevemente sobre tu boda (opcional)"></textarea>
            <button type="submit" class="lead-submit" data-track="form">
              <i class="fa-solid fa-paper-plane"></i> Pedir cotización gratis
            </button>
            <p class="lead-note">¿Prefieres directo? <a href="tel:+17872439670" data-track="call"><i class="fa-solid fa-phone"></i> Llamar</a> o <a href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20cotizar%20fotograf%C3%ADa%20para%20mi%20boda." target="_blank" rel="noopener" data-track="whatsapp"><i class="fab fa-whatsapp"></i> WhatsApp</a>.</p>
            <p class="lead-success" id="leadSuccess" hidden>
              <i class="fa-solid fa-circle-check"></i> Mensaje recibido. Te respondo en menos de 1 hora.
            </p>
            <p class="lead-error" id="leadError" hidden>
              <i class="fa-solid fa-triangle-exclamation"></i> No pude enviar el mensaje. Escríbeme por WhatsApp al (787) 243-9670.
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- ── Quién soy ── -->
    <section class="meet-section">
      <div class="container">
        <div class="meet-grid">
          <div class="meet-photo">
            <img src="/marcos-photo.webp" alt="Marcos Santiago — fotógrafo de bodas en Puerto Rico" loading="lazy" />
            <div class="meet-photo-bg" aria-hidden="true"></div>
          </div>
          <div class="meet-text">
            <p class="section-label">Quién va a fotografiar tu boda</p>
            <h2 class="meet-title">Soy Marcos.</h2>
            <p class="meet-bio">
              Desde 2012 cubriendo bodas, quinceañeros y eventos en Puerto Rico. Trabajo desde Aibonito pero cubro toda la isla. No soy un equipo: soy yo el que llega a tu boda, el que edita cada foto, el que te entrega la galería.
            </p>
            <div class="meet-facts">
              <div class="meet-fact"><span class="meet-fact-num">+13</span><span class="meet-fact-label">años fotografiando</span></div>
              <div class="meet-fact"><span class="meet-fact-num">PR</span><span class="meet-fact-label">toda la isla</span></div>
            </div>
            <div class="meet-actions">
              <a href="/portafolio/foto/" class="meet-link">Ver portafolio de foto <i class="fa-solid fa-arrow-right"></i></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="faq-section">
      <div class="container">
        <p class="section-label">Preguntas frecuentes</p>
        <h2 class="section-title">Lo que me preguntan <span class="accent">sobre bodas</span></h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>¿Cuánto cuesta la fotografía de bodas en Puerto Rico?</summary>
            <p>Los paquetes de boda comienzan desde $750 e incluyen cobertura completa, galería digital y derechos de impresión. El precio varía según la duración y los servicios adicionales. Contáctame para una cotización personalizada gratis.</p>
          </details>
          <details class="faq-item">
            <summary>¿Cubres bodas en toda Puerto Rico?</summary>
            <p>Sí — desde Aibonito hasta San Juan, Ponce, Mayagüez, Rincón, Fajardo y cualquier municipio de la isla. No hay cargo adicional por desplazamiento dentro de PR.</p>
          </details>
          <details class="faq-item">
            <summary>¿Cuándo recibo mis fotos?</summary>
            <p>La galería digital se entrega entre 4 y 6 semanas después de tu boda. Recibirás acceso privado a Pixieset con todas las fotos editadas y listas para imprimir.</p>
          </details>
          <details class="faq-item">
            <summary>¿Ofrecen paquetes de foto y video?</summary>
            <p>Sí, ofrezco paquetes combinados de fotografía y videografía para bodas. Es una ventaja tener un solo profesional que conoce tu evento de principio a fin. Pregúntame por las opciones.</p>
          </details>
          <details class="faq-item">
            <summary>¿Con cuánto tiempo de anticipación debo reservar?</summary>
            <p>Lo ideal es reservar con 3 a 6 meses de anticipación, especialmente para temporada alta (diciembre-enero y meses de verano). Contáctame hoy para verificar disponibilidad en tu fecha.</p>
          </details>
        </div>
        <div class="faq-cta">
          <a href="https://wa.me/17872439670?text=Hola%2C%20tengo%20una%20pregunta%20sobre%20fotograf%C3%ADa%20de%20bodas." target="_blank" rel="noopener" class="faq-wa-btn" data-track="whatsapp">
            <i class="fab fa-whatsapp"></i> ¿Otra pregunta? Escríbeme por WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Sticky mobile bar -->
  <div class="sticky-bar" id="stickyBar" aria-hidden="true">
    <a href="tel:+17872439670" class="sticky-btn sticky-call" data-track="call-sticky">
      <i class="fa-solid fa-phone"></i> Llamar
    </a>
    <a href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20cotizar%20fotograf%C3%ADa%20para%20mi%20boda." target="_blank" rel="noopener" class="sticky-btn sticky-wa" data-track="whatsapp-sticky">
      <i class="fab fa-whatsapp"></i> WhatsApp
    </a>
  </div>

  <style>
  /* ── PPC Header ── */
  .ppc-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 800;
    background: rgba(4,13,22,.92); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border); padding: 12px 0;
  }
  .ppc-header-inner {
    display: flex; align-items: center; justify-content: space-between;
  }
  .ppc-logo {
    font-family: var(--display); font-size: .95rem;
    letter-spacing: 4px; color: var(--white); text-decoration: none;
  }
  .ppc-phone {
    font-family: var(--mono); font-size: .65rem; letter-spacing: 1.5px;
    color: var(--accent); text-decoration: none; border: 1px solid var(--accent);
    border-radius: 8px; padding: 6px 14px; transition: .15s;
    display: flex; align-items: center; gap: 6px;
  }
  .ppc-phone:hover { background: var(--accent); color: #fff }

  /* ── Hero ── */
  .hero-section {
    position: relative; min-height: 100svh;
    display: flex; align-items: center;
    padding: 140px 0 60px; overflow: hidden;
  }
  .hero-bg-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; z-index: 0;
  }
  .hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(160deg, rgba(4,13,22,.82) 40%, rgba(4,13,22,.6) 100%);
  }
  .hero-content { position: relative; z-index: 2; max-width: 780px }
  .hero-title {
    font-family: var(--display);
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: .92; letter-spacing: 3px;
    margin: 8px 0 24px; color: var(--white);
  }
  .hero-bullets {
    list-style: none; padding: 0; margin: 0 0 24px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .hero-bullets li {
    display: flex; align-items: center; gap: 10px;
    font-size: 1rem; color: color-mix(in srgb, var(--white) 85%, transparent);
  }
  .hero-bullets li i { color: var(--accent); width: 16px; flex-shrink: 0 }
  .hero-price-strip {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 28px; flex-wrap: wrap;
  }
  .price-badge {
    background: var(--accent); color: #040d16;
    padding: 6px 16px; border-radius: 20px;
    font-family: var(--mono); font-size: .75rem; letter-spacing: 1px;
  }
  .price-badge strong { font-size: .95rem }
  .price-note {
    font-size: .82rem; color: var(--muted);
    font-family: var(--mono); letter-spacing: .5px;
  }
  .hero-actions {
    display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 10px;
    font-family: var(--mono); font-size: .65rem;
    letter-spacing: 1.5px; text-transform: uppercase;
    text-decoration: none; font-weight: 700; transition: .15s;
  }
  .hero-cta-call { background: var(--white); color: #040d16 }
  .hero-cta-call:hover { background: var(--accent) }
  .hero-cta-wa { background: #25d366; color: #fff }
  .hero-cta-wa:hover { opacity: .88 }
  .hero-cta-form { background: transparent; color: var(--white); border: 1px solid rgba(255,255,255,.25) }
  .hero-cta-form:hover { border-color: var(--accent); color: var(--accent) }
  .hero-meta {
    display: flex; flex-wrap: wrap; gap: 8px; align-items: center;
  }
  .meta-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--mono); font-size: .55rem; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted);
    border: 1px solid var(--border); border-radius: 20px; padding: 5px 12px;
    text-decoration: none; transition: .15s;
  }
  .meta-pill-call { color: var(--accent); border-color: var(--accent) }
  .meta-pill-call:hover { background: var(--accent); color: #040d16 }

  /* ── Includes ── */
  .includes-section { padding: 80px 0 }
  .section-title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin: 8px 0 32px; color: var(--white);
  }
  .includes-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px; margin-bottom: 32px;
  }
  .include-card {
    background: color-mix(in srgb, var(--white) 3%, transparent);
    border: 1px solid var(--border); border-radius: 16px;
    padding: 28px 24px; display: flex; flex-direction: column; gap: 8px;
  }
  .include-icon {
    font-size: 1.4rem; color: var(--accent); margin-bottom: 4px;
  }
  .include-card h3 {
    font-family: var(--mono); font-size: .72rem;
    letter-spacing: 2px; text-transform: uppercase; color: var(--white); margin: 0;
  }
  .include-card p { font-size: .88rem; color: var(--muted); margin: 0; line-height: 1.55 }
  .include-price {
    font-family: var(--mono); font-size: .68rem; letter-spacing: 1px;
    color: var(--accent); margin-top: auto; padding-top: 8px;
  }
  .includes-checklist {
    display: flex; flex-wrap: wrap; gap: 12px;
    padding: 20px 24px; border-radius: 12px;
    background: color-mix(in srgb, var(--white) 2%, transparent);
    border: 1px solid var(--border);
  }
  .includes-checklist span {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: .6rem; letter-spacing: 1px;
    text-transform: uppercase; color: var(--muted);
  }
  .includes-checklist span i { color: #25d366 }

  /* ── Lead form ── */
  .lead-section { padding: 80px 0; background: color-mix(in srgb, var(--white) 1.5%, transparent) }
  .lead-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 48px; align-items: start;
  }
  .lead-title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin: 8px 0 12px; color: var(--white);
  }
  .lead-sub { font-size: .9rem; color: var(--muted); margin: 0 0 20px }
  .lead-trust { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px }
  .lead-trust li {
    display: flex; align-items: center; gap: 8px;
    font-size: .85rem; color: color-mix(in srgb, var(--white) 75%, transparent);
  }
  .lead-trust li i { color: #25d366 }
  .lead-form {
    background: color-mix(in srgb, var(--white) 3%, transparent);
    border: 1px solid var(--border); border-radius: 20px; padding: 32px;
    display: flex; flex-direction: column; gap: 12px;
  }
  .lead-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px }
  .lead-field {
    width: 100%; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px;
    padding: 12px 16px; font-size: .88rem;
    color: var(--white); font-family: var(--body);
    outline: none; transition: border-color .15s; box-sizing: border-box;
    resize: none;
  }
  .lead-field:focus { border-color: var(--accent) }
  .lead-field::placeholder { color: var(--muted) }
  .lead-submit {
    background: var(--accent); color: #040d16; border: none;
    border-radius: 10px; padding: 14px; cursor: pointer;
    font-family: var(--mono); font-size: .65rem;
    letter-spacing: 1.5px; text-transform: uppercase; font-weight: 700;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: opacity .15s;
  }
  .lead-submit:hover { opacity: .88 }
  .lead-note { font-size: .78rem; color: var(--muted); text-align: center; margin: 0 }
  .lead-note a { color: var(--accent); text-decoration: none }
  .lead-success { color: #25d366; font-size: .85rem; text-align: center; margin: 0 }
  .lead-error { color: #ff6b6b; font-size: .85rem; text-align: center; margin: 0 }

  /* ── Meet ── */
  .meet-section { padding: 80px 0 }
  .meet-grid {
    display: grid; grid-template-columns: 1fr 1.4fr;
    gap: 48px; align-items: center;
  }
  .meet-photo { position: relative }
  .meet-photo img {
    width: 100%; border-radius: 20px; display: block;
    aspect-ratio: 4/5; object-fit: cover;
    position: relative; z-index: 1;
  }
  .meet-photo-bg {
    position: absolute; inset: 12px -12px -12px 12px;
    background: var(--accent); border-radius: 20px; z-index: 0; opacity: .12;
  }
  .meet-title {
    font-family: var(--display); font-size: clamp(2.5rem, 6vw, 5rem);
    margin: 8px 0 16px; color: var(--white);
  }
  .meet-bio { font-size: .95rem; color: var(--muted); line-height: 1.7; margin: 0 0 20px }
  .meet-facts { display: flex; gap: 24px; margin: 20px 0 }
