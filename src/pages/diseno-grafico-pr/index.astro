---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
---
<Base
  title="Diseño Gráfico y Branding en Puerto Rico | Marcos Santiago"
  description="Diseño gráfico, logos e identidad de marca en Puerto Rico desde $50. Branding, redes sociales, imprenta y editorial. Cotización gratis. Respondo en menos de 1 hora."
  businessSchema={false}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "name": "Marcos Santiago — Diseño Gráfico y Branding",
        "url": "https://marcossantiago.com/diseno-grafico-pr/",
        "telephone": "+17872439670",
        "image": "https://marcossantiago.com/marcos-photo.jpg",
        "description": "Artista gráfico en Puerto Rico. Diseño de logos, identidad de marca, redes sociales, imprenta y editorial. Toda la isla.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Aibonito",
          "addressRegion": "PR",
          "addressCountry": "US"
        },
        "areaServed": "Puerto Rico",
        "priceRange": "$$",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Diseño Gráfico y Branding Puerto Rico",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Branding e Identidad de Marca Puerto Rico" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diseño para Redes Sociales Puerto Rico" }, "price": "50", "priceCurrency": "USD" },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diseño para Imprenta y Editorial Puerto Rico" } }
          ]
        }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Cuánto cuesta un logo o una identidad de marca en Puerto Rico?",
            "acceptedAnswer": { "@type": "Answer", "text": "El diseño gráfico comienza desde $50 para piezas individuales. Un paquete completo de branding (logo, paleta, tipografía y guía de marca) se cotiza según el alcance. Escríbeme por WhatsApp para una cotización gratis." }
          },
          {
            "@type": "Question",
            "name": "¿Qué incluye un paquete de branding?",
            "acceptedAnswer": { "@type": "Answer", "text": "Un paquete de identidad incluye logo principal con variantes, paleta de colores, tipografía de marca y una guía de estilo en PDF para que tu marca se vea consistente en todo." }
          },
          {
            "@type": "Question",
            "name": "¿Entregas los archivos editables?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí. Recibes los archivos en los formatos que necesites — vectoriales para imprenta y web (SVG, PDF), además de PNG en alta resolución para redes sociales." }
          },
          {
            "@type": "Question",
            "name": "¿Diseñas contenido para redes sociales?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí. Diseño posts, stories, banners, portadas y plantillas con consistencia de marca para Instagram, Facebook y demás plataformas." }
          },
          {
            "@type": "Question",
            "name": "¿Trabajas con negocios fuera de Aibonito?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí. El diseño se trabaja de forma remota, así que atiendo clientes de toda Puerto Rico y fuera de la isla sin problema." }
          }
        ]
      }
    ]
  })} />

  <!-- Minimal PPC header — no escape nav -->
  <header class="ppc-header">
    <div class="container ppc-header-inner">
      <a href="/" class="ppc-logo" aria-label="Marcos Santiago — inicio">MARCOS SANTIAGO</a>
      <a href="tel:+17872439670" class="ppc-phone" data-track="call-header">
        <i class="fa-solid fa-phone"></i> (787) 243-9670
      </a>
    </div>
  </header>

  <main id="main">
    <!-- ── Hero ── -->
    <section class="hero-section">
      <img class="hero-bg-img" src="/videos/marcos-video-poster.webp" alt="" aria-hidden="true" fetchpriority="high" />
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="container hero-content">
        <p class="section-label">Artista Gráfico · Puerto Rico</p>
        <h1 class="hero-title">Tu marca,<br><span class="accent">con identidad propia.</span></h1>
        <ul class="hero-bullets">
          <li><i class="fa-solid fa-pen-nib"></i> Logo, identidad y guía de marca completa</li>
          <li><i class="fa-solid fa-location-dot"></i> Clientes en toda Puerto Rico — 100% remoto</li>
          <li><i class="fa-solid fa-bolt"></i> Cotización gratis en menos de 1 hora</li>
        </ul>
        <div class="hero-price-strip">
          <span class="price-badge">Desde <strong>$50</strong></span>
          <span class="price-note">· Branding · Redes · Imprenta · Editorial</span>
        </div>
        <div class="hero-actions">
          <a href="tel:+17872439670" class="hero-cta hero-cta-call" data-track="call">
            <i class="fa-solid fa-phone"></i> Llamar ahora
          </a>
          <a
            href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20cotizar%20dise%C3%B1o%20gr%C3%A1fico%20para%20mi%20marca."
            target="_blank" rel="noopener"
            class="hero-cta hero-cta-wa"
            data-track="whatsapp"
          >
            <i class="fab fa-whatsapp"></i> WhatsApp
          </a>
          <a href="#cotizar" class="hero-cta hero-cta-form">
            <i class="fa-solid fa-paper-plane"></i> Cotización rápida
          </a>
        </div>
        <div class="hero-meta">
          <span class="meta-pill"><i class="fa-solid fa-location-dot"></i> Toda Puerto Rico</span>
          <span class="meta-pill"><i class="fa-regular fa-clock"></i> Respondo en &lt;1 hora</span>
          <a href="tel:+17872439670" class="meta-pill meta-pill-call" data-track="call">
            <i class="fa-solid fa-phone"></i> (787) 243-9670
          </a>
        </div>
      </div>
    </section>

    <!-- ── Servicios incluidos ── -->
    <section class="includes-section">
      <div class="container">
        <p class="section-label">Qué diseño</p>
        <h2 class="section-title">Diseño que hace <span class="accent">ver profesional</span> tu marca</h2>
        <div class="includes-grid">
          <div class="include-card">
            <i class="fa-solid fa-shapes include-icon"></i>
            <h3>Branding & Identidad</h3>
            <p>Logo principal con variantes, paleta de colores, tipografía y guía de estilo. La base para que tu marca se vea consistente en todo.</p>
            <span class="include-price">Por cotización</span>
          </div>
          <div class="include-card">
            <i class="fa-solid fa-mobile-screen include-icon"></i>
            <h3>Diseño Digital & Redes</h3>
            <p>Posts, stories, banners, portadas y plantillas para Instagram, Facebook y más — con la identidad de tu marca.</p>
            <span class="include-price">Desde $50</span>
          </div>
          <div class="include-card">
            <i class="fa-solid fa-print include-icon"></i>
            <h3>Imprenta & Editorial</h3>
            <p>Tarjetas, brochures, menús, revistas y catálogos. Archivos listos para imprenta en CMYK y alta resolución.</p>
            <span class="include-price">Por cotización</span>
          </div>
        </div>
        <div class="includes-checklist">
          <span><i class="fa-solid fa-check"></i> Archivos vectoriales editables</span>
          <span><i class="fa-solid fa-check"></i> Formatos para web e imprenta</span>
          <span><i class="fa-solid fa-check"></i> Alta resolución (300 DPI)</span>
          <span><i class="fa-solid fa-check"></i> CMYK y RGB</span>
          <span><i class="fa-solid fa-check"></i> Múltiples variantes de logo</span>
          <span><i class="fa-solid fa-check"></i> Guía de marca en PDF</span>
        </div>
      </div>
    </section>

    <!-- ── Testimonio ── -->
    <section class="testimonials-section">
      <div class="container">
        <div class="testi-single">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-quote">"Marcos diseñó la identidad completa de nuestra empresa. Logo, paleta, posts — todo consistente y profesional. Nuestros clientes notan el cambio inmediatamente."</p>
          <div class="testi-single-footer">
            <span class="testi-name">Roberto F.</span>
            <span class="testi-loc">Branding & Identidad · Aibonito, PR</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Lead form ── -->
    <section class="lead-section" id="cotizar">
      <div class="container">
        <div class="lead-grid">
          <div class="lead-intro">
            <p class="section-label">Cotización de Diseño</p>
            <h2 class="lead-title">Te respondo en <span class="accent">menos de 1 hora</span></h2>
            <p class="lead-sub">Sin spam. Sin compromiso. Te contesto directo yo, no un asistente.</p>
            <ul class="lead-trust">
              <li><i class="fa-solid fa-check"></i> Cotización gratis</li>
              <li><i class="fa-solid fa-check"></i> Trabajo 100% remoto en toda PR</li>
              <li><i class="fa-solid fa-check"></i> Respuesta personal de Marcos</li>
            </ul>
          </div>
          <form class="lead-form" id="leadForm" novalidate>
            <div class="lead-row">
              <input type="text" required class="lead-field" name="nombre" placeholder="Tu nombre *" autocomplete="name" />
              <input type="tel" required class="lead-field" name="contacto" placeholder="Teléfono o WhatsApp *" autocomplete="tel" />
            </div>
            <input type="hidden" name="servicio" value="Diseño Gráfico" />
            <input type="text" class="lead-field" name="proyecto" placeholder="Tipo de proyecto: logo, branding, redes... (opcional)" />
            <textarea class="lead-field" name="mensaje" rows="2" placeholder="Cuéntame brevemente sobre tu proyecto (opcional)"></textarea>
            <button type="submit" class="lead-submit" data-track="form">
              <i class="fa-solid fa-paper-plane"></i> Pedir cotización gratis
            </button>
            <p class="lead-note">¿Prefieres directo? <a href="tel:+17872439670" data-track="call"><i class="fa-solid fa-phone"></i> Llamar</a> o <a href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20cotizar%20dise%C3%B1o%20gr%C3%A1fico%20para%20mi%20marca." target="_blank" rel="noopener" data-track="whatsapp"><i class="fab fa-whatsapp"></i> WhatsApp</a>.</p>
            <p class="lead-success" id="leadSuccess" hidden>
              <i class="fa-solid fa-circle-check"></i> Mensaje recibido. Te respondo en menos de 1 hora.
            </p>
            <p class="lead-error" id="leadError" hidden>
              <i class="fa-solid fa-triangle-exclamation"></i> No pude enviar el mensaje. Escríbeme por WhatsApp al (787) 243-9670.
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- ── Quién soy ── -->
    <section class="meet-section">
      <div class="container">
        <div class="meet-grid">
          <div class="meet-photo">
            <img src="/marcos-photo.webp" alt="Marcos Santiago — artista gráfico en Puerto Rico" loading="lazy" />
            <div class="meet-photo-bg" aria-hidden="true"></div>
          </div>
          <div class="meet-text">
            <p class="section-label">Quién va a diseñar tu marca</p>
            <h2 class="meet-title">Soy Marcos.</h2>
            <p class="meet-bio">
              Desde 2001 diseñando marcas, logos e identidad visual en Puerto Rico. Trabajo desde Aibonito pero atiendo clientes de toda la isla de forma remota. No soy un equipo: soy yo el que diseña, el que revisa contigo y el que te entrega los archivos listos.
            </p>
            <div class="meet-facts">
              <div class="meet-fact"><span class="meet-fact-num">+24</span><span class="meet-fact-label">años en diseño</span></div>
              <div class="meet-fact"><span class="meet-fact-num">PR</span><span class="meet-fact-label">toda la isla</span></div>
            </div>
            <div class="meet-actions">
              <a href="/portafolio/logos/" class="meet-link">Ver portafolio de logos <i class="fa-solid fa-arrow-right"></i></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="faq-section">
      <div class="container">
        <p class="section-label">Preguntas frecuentes</p>
        <h2 class="section-title">Lo que me preguntan <span class="accent">sobre diseño</span></h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>¿Cuánto cuesta un logo o una identidad de marca?</summary>
            <p>El diseño comienza desde $50 para piezas individuales. Un paquete completo de branding (logo, paleta, tipografía y guía de marca) se cotiza según el alcance de tu proyecto. Escríbeme para una cotización gratis y personalizada.</p>
          </details>
          <details class="faq-item">
            <summary>¿Qué incluye un paquete de branding?</summary>
            <p>Logo principal con sus variantes, paleta de colores, tipografía de marca y una guía de estilo en PDF. Todo lo que necesitas para que tu marca se vea consistente en redes, imprenta y web.</p>
          </details>
          <details class="faq-item">
            <summary>¿Entregas los archivos editables?</summary>
            <p>Sí. Recibes los archivos vectoriales (SVG, PDF, AI) para imprenta y web, además de PNG en alta resolución para redes sociales. Los archivos son tuyos.</p>
          </details>
          <details class="faq-item">
            <summary>¿Diseñas contenido para redes sociales?</summary>
            <p>Sí — posts, stories, banners, portadas y plantillas reutilizables con la identidad de tu marca, para Instagram, Facebook y demás plataformas.</p>
          </details>
          <details class="faq-item">
            <summary>¿Trabajas con negocios fuera de Aibonito?</summary>
            <p>Sí. El diseño se trabaja de forma remota, así que atiendo clientes de toda Puerto Rico y fuera de la isla sin ningún problema.</p>
          </details>
        </div>
        <div class="faq-cta">
          <a href="https://wa.me/17872439670?text=Hola%2C%20tengo%20una%20pregunta%20sobre%20dise%C3%B1o%20gr%C3%A1fico." target="_blank" rel="noopener" class="faq-wa-btn" data-track="whatsapp">
            <i class="fab fa-whatsapp"></i> ¿Otra pregunta? Escríbeme por WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Sticky mobile bar -->
  <div class="sticky-bar" id="stickyBar" aria-hidden="true">
    <a href="tel:+17872439670" class="sticky-btn sticky-call" data-track="call-sticky">
      <i class="fa-solid fa-phone"></i> Llamar
    </a>
    <a href="https://wa.me/17872439670?text=Hola%2C%20me%20interesa%20cotizar%20dise%C3%B1o%20gr%C3%A1fico%20para%20mi%20marca." target="_blank" rel="noopener" class="sticky-btn sticky-wa" data-track="whatsapp-sticky">
      <i class="fab fa-whatsapp"></i> WhatsApp
    </a>
  </div>

  <style>
  /* Accent local de esta landing (verde esmeralda) */
  main { --accent: #10b981 }

  /* ── PPC Header ── */
  .ppc-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 800;
    background: rgba(4,13,22,.92); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border); padding: 12px 0;
  }
  .ppc-header-inner { display: flex; align-items: center; justify-content: space-between }
  .ppc-logo {
    font-family: var(--display); font-size: .95rem;
    letter-spacing: 4px; color: var(--white); text-decoration: none;
  }
  .ppc-phone {
    font-family: var(--mono); font-size: .65rem; letter-spacing: 1.5px;
    color: #10b981; text-decoration: none; border: 1px solid #10b981;
    border-radius: 8px; padding: 6px 14px; transition: .15s;
    display: flex; align-items: center; gap: 6px;
  }
  .ppc-phone:hover { background: #10b981; color: #fff }

  /* ── Hero ── */
  .hero-section {
    position: relative; min-height: 100svh;
    display: flex; align-items: center;
    padding: 140px 0 60px; overflow: hidden;
  }
  .hero-bg-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0 }
  .hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(160deg, rgba(4,13,22,.82) 40%, rgba(4,13,22,.6) 100%);
  }
  .hero-content { position: relative; z-index: 2; max-width: 780px }
  .hero-title {
    font-family: var(--display);
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: .92; letter-spacing: 3px;
    margin: 8px 0 24px; color: var(--white);
  }
  .hero-bullets {
    list-style: none; padding: 0; margin: 0 0 24px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .hero-bullets li {
    display: flex; align-items: center; gap: 10px;
    font-size: 1rem; color: color-mix(in srgb, var(--white) 85%, transparent);
  }
  .hero-bullets li i { color: var(--accent); width: 16px; flex-shrink: 0 }
  .hero-price-strip { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; flex-wrap: wrap }
  .price-badge {
    background: var(--accent); color: #040d16;
    padding: 6px 16px; border-radius: 20px;
    font-family: var(--mono); font-size: .75rem; letter-spacing: 1px;
  }
  .price-badge strong { font-size: .95rem }
  .price-note { font-size: .82rem; color: var(--muted); font-family: var(--mono); letter-spacing: .5px }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 10px;
    font-family: var(--mono); font-size: .65rem;
    letter-spacing: 1.5px; text-transform: uppercase;
    text-decoration: none; font-weight: 700; transition: .15s;
  }
  .hero-cta-call { background: var(--white); color: #040d16 }
  .hero-cta-call:hover { background: var(--accent) }
  .hero-cta-wa { background: #25d366; color: #fff }
  .hero-cta-wa:hover { opacity: .88 }
  .hero-cta-form { background: transparent; color: var(--white); border: 1px solid rgba(255,255,255,.25) }
  .hero-cta-form:hover { border-color: var(--accent); color: var(--accent) }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 8px; align-items: center }
  .meta-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--mono); font-size: .55rem; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted);
    border: 1px solid var(--border); border-radius: 20px; padding: 5px 12px;
    text-decoration: none; transition: .15s;
  }
  .meta-pill-call { color: var(--accent); border-color: var(--accent) }
  .meta-pill-call:hover { background: var(--accent); color: #040d16 }

  /* ── Includes ── */
  .includes-section { padding: 80px 0 }
  .section-title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin: 8px 0 32px; color: var(--white);
  }
  .includes-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px; margin-bottom: 32px;
  }
  .include-card {
    background: color-mix(in srgb, var(--white) 3%, transparent);
    border: 1px solid var(--border); border-radius: 16px;
    padding: 28px 24px; display: flex; flex-direction: column; gap: 8px;
  }
  .include-icon { font-size: 1.4rem; color: var(--accent); margin-bottom: 4px }
  .include-card h3 {
    font-family: var(--mono); font-size: .72rem;
    letter-spacing: 2px; text-transform: uppercase; color: var(--white); margin: 0;
  }
  .include-card p { font-size: .88rem; color: var(--muted); margin: 0; line-height: 1.55 }
  .include-price {
    font-family: var(--mono); font-size: .68rem; letter-spacing: 1px;
    color: var(--accent); margin-top: auto; padding-top: 8px;
  }
  .includes-checklist {
    display: flex; flex-wrap: wrap; gap: 12px;
    padding: 20px 24px; border-radius: 12px;
    background: color-mix(in srgb, var(--white) 2%, transparent);
    border: 1px solid var(--border);
  }
  .includes-checklist span {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: .6rem; letter-spacing: 1px;
    text-transform: uppercase; color: var(--muted);
  }
  .includes-checklist span i { color: var(--accent) }

  /* ── Testimonio ── */
  .testimonials-section {
    padding: 72px 0;
    background: color-mix(in srgb, var(--white) 1.5%, transparent);
  }
  .testi-single {
    max-width: 680px; margin: 0 auto; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 18px;
  }
  .testi-single .testi-stars { color: #facc15; font-size: 1rem; letter-spacing: 4px }
  .testi-single .testi-quote {
    font-size: clamp(1.1rem, 2.4vw, 1.5rem); line-height: 1.6;
    color: var(--white); margin: 0; max-width: 620px;
  }
  .testi-single-footer { display: flex; flex-direction: column; gap: 4px }
  .testi-single .testi-name {
    font-family: var(--mono); font-size: .8rem; font-weight: 700;
    color: var(--accent); letter-spacing: 1px;
  }
  .testi-single .testi-loc {
    font-family: var(--mono); font-size: .62rem; color: var(--muted);
    letter-spacing: 1.5px; text-transform: uppercase;
  }

  /* ── Lead form ── */
  .lead-section { padding: 80px 0; background: color-mix(in srgb, var(--white) 1.5%, transparent) }
  .lead-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start }
  .lead-title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin: 8px 0 12px; color: var(--white);
  }
  .lead-sub { font-size: .9rem; color: var(--muted); margin: 0 0 20px }
  .lead-trust { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px }
  .lead-trust li {
    display: flex; align-items: center; gap: 8px;
    font-size: .85rem; color: color-mix(in srgb, var(--white) 75%, transparent);
  }
  .lead-trust li i { color: var(--accent) }
  .lead-form {
    background: color-mix(in srgb, var(--white) 3%, transparent);
    border: 1px solid var(--border); border-radius: 20px; padding: 32px;
    display: flex; flex-direction: column; gap: 12px;
  }
  .lead-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px }
  .lead-field {
    width: 100%; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px;
    padding: 12px 16px; font-size: .88rem;
    color: var(--white); font-family: var(--body);
    outline: none; transition: border-color .15s; box-sizing: border-box; resize: none;
  }
  .lead-field:focus { border-color: var(--accent) }
  .lead-field::placeholder { color: var(--muted) }
  .lead-submit {
    background: var(--accent); color: #040d16; border: none;
    border-radius: 10px; padding: 14px; cursor: pointer;
    font-family: var(--mono); font-size: .65rem;
    letter-spacing: 1.5px; text-transform: uppercase; font-weight: 700;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: opacity .15s;
  }
  .lead-submit:hover { opacity: .88 }
  .lead-note { font-size: .78rem; color: var(--muted); text-align: center; margin: 0 }
  .lead-note a { color: var(--accent); text-decoration: none }
  .lead-success { color: #25d366; font-size: .85rem; text-align: center; margin: 0 }
  .lead-error { color: #ff6b6b; font-size: .85rem; text-align: center; margin: 0 }

  /* ── Meet ── */
  .meet-section { padding: 80px 0 }
  .meet-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; align-items: center }
  .meet-photo { position: relative }
  .meet-photo img {
    width: 100%; border-radius: 20px; display: block;
    aspect-ratio: 4/5; object-fit: cover; position: relative; z-index: 1;
  }
  .meet-photo-bg {
    position: absolute; inset: 12px -12px -12px 12px;
    background: var(--accent); border-radius: 20px; z-index: 0; opacity: .12;
  }
  .meet-title {
    font-family: var(--display); font-size: clamp(2.5rem, 6vw, 5rem);
    margin: 8px 0 16px; color: var(--white);
  }
  .meet-bio { font-size: .95rem; color: var(--muted); line-height: 1.7; margin: 0 0 20px }
  .meet-facts { display: flex; gap: 24px; margin: 20px 0 }
  .meet-fact { display: flex; flex-direction: column }
  .meet-fact-num { font-family: var(--display); font-size: 2.2rem; color: var(--accent); line-height: 1 }
  .meet-fact-label { font-family: var(--mono); font-size: .55rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted) }
  .meet-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px }
  .meet-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: .6rem; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--accent); text-decoration: none; transition: gap .15s;
  }
  .meet-link:hover { gap: 12px }

  /* ── FAQ ── */
  .faq-section { padding: 80px 0 }
  .faq-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 32px }
  .faq-item {
    border: 1px solid var(--border); border-radius: 12px;
    background: color-mix(in srgb, var(--white) 2%, transparent); overflow: hidden;
  }
  .faq-item summary {
    padding: 18px 24px; cursor: pointer; font-size: .95rem;
    color: var(--white); list-style: none; display: flex;
    align-items: center; justify-content: space-between; gap: 12px; transition: color .15s;
  }
  .faq-item summary:hover { color: var(--accent) }
  .faq-item summary::after {
    content: '+'; font-family: var(--mono); font-size: 1rem;
    color: var(--muted); flex-shrink: 0; transition: transform .2s;
  }
  .faq-item[open] summary::after { transform: rotate(45deg) }
  .faq-item p { padding: 0 24px 18px; font-size: .88rem; color: var(--muted); line-height: 1.65; margin: 0 }
  .faq-cta { text-align: center }
  .faq-wa-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: #25d366; color: #fff; text-decoration: none;
    padding: 12px 24px; border-radius: 10px;
    font-family: var(--mono); font-size: .65rem; letter-spacing: 1.5px;
    text-transform: uppercase; font-weight: 700; transition: opacity .15s;
  }
  .faq-wa-btn:hover { opacity: .88 }

  /* ── Sticky bar ── */
  .sticky-bar {
    display: none; position: fixed; bottom: 0; left: 0; right: 0;
    z-index: 700; padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
    background: rgba(4,13,22,.96); backdrop-filter: blur(8px);
    border-top: 1px solid var(--border); gap: 10px;
  }
  .sticky-btn {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 13px; border-radius: 10px; text-decoration: none;
    font-family: var(--mono); font-size: .65rem; letter-spacing: 1.5px;
    text-transform: uppercase; font-weight: 700; transition: opacity .15s;
  }
  .sticky-call { background: var(--white); color: #040d16 }
  .sticky-wa { background: #25d366; color: #fff }
  .sticky-call:hover, .sticky-wa:hover { opacity: .88 }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .lead-grid { grid-template-columns: 1fr }
    .lead-row { grid-template-columns: 1fr }
    .meet-grid { grid-template-columns: 1fr }
    .meet-photo { max-width: 320px; margin: 0 auto }
    .sticky-bar { display: flex }
    main { padding-bottom: 80px }
  }
  @media (max-width: 480px) {
    .hero-actions { flex-direction: column }
    .hero-cta { justify-content: center }
  }
  </style>

  <script is:inline>
  // Lead form submit
  (function() {
    const form    = document.getElementById('leadForm');
    const success = document.getElementById('leadSuccess');
    const error   = document.getElementById('leadError');
    if (!form) return;
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        const r = await fetch('/ms-chat/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        if (!r.ok) throw new Error();
        form.reset();
        success.hidden = false;
        error.hidden   = true;
        if (typeof gtag === 'function') gtag('event', 'form_submit', { event_category: 'engagement', event_label: 'diseno-grafico-pr' });
      } catch {
        error.hidden   = false;
        success.hidden = true;
      }
    });
  })();

  // Sticky bar on scroll
  (function() {
    const bar = document.getElementById('stickyBar');
    if (!bar) return;
    bar.setAttribute('aria-hidden', 'false');
    let shown = false;
    window.addEventListener('scroll', function() {
      const past = window.scrollY > 300;
      if (past !== shown) { shown = past; bar.style.display = past ? 'flex' : 'none'; }
    }, { passive: true });
  })();

  // GA4 CTA tracking
  document.querySelectorAll('[data-track]').forEach(function(el) {
    el.addEventListener('click', function() {
      if (typeof gtag === 'function') gtag('event', 'cta_click', { event_category: 'engagement', event_label: el.dataset.track });
    });
  });
  </script>
</Base>
