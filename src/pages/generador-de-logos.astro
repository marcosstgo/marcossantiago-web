      font-family: var(--mono); font-size: var(--text-2xs);
      letter-spacing: 2px; text-transform: uppercase; color: #10b981;
    }
    .ai-canvas {
      aspect-ratio: 1; background: #fff; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      padding: 18px; overflow: hidden;
    }
    .ai-canvas svg { width: 100%; height: 100%; display: block }
    .ai-canvas img { width: 100%; height: 100%; object-fit: contain; display: block }
    .ai-skeleton {
      width: 100%; height: 100%; border-radius: 8px;
      background: linear-gradient(100deg, #ececec 30%, #f7f7f7 50%, #ececec 70%);
      background-size: 200% 100%; animation: aiShimmer 1.3s linear infinite;
    }
    @keyframes aiShimmer { to { background-position: -200% 0 } }
    .ai-card.err .ai-canvas { background: var(--surface); border: 1px dashed var(--border) }
    .ai-retry {
      font-family: var(--mono); font-size: var(--text-xs); color: var(--muted);
      border: 1px solid var(--border); background: none;
      padding: 9px 16px; border-radius: 8px; cursor: pointer; transition: .2s;
    }
    .ai-retry:hover { color: var(--white) }
    .ai-pick {
      font-family: var(--mono); font-size: var(--text-2xs);
      letter-spacing: 1.5px; text-transform: uppercase;
      padding: 11px 12px; border-radius: 9px; cursor: pointer;
      background: none; color: var(--white);
      border: 1px solid var(--border); transition: .18s;
    }
    .ai-pick:hover { border-color: #10b981; color: #10b981 }
    .ai-card.selected { border-color: #10b981; box-shadow: 0 0 0 1px #10b981 }
    .ai-card.selected .ai-pick { background: #10b981; color: #040d16; border-color: #10b981 }

    /* ── Brand board (inyectado por JS) ── */
    .ai-board { margin-top: 26px }
    .board-inner {
      border: 1px solid color-mix(in srgb, #10b981 25%, var(--border));
      border-radius: 18px; overflow: hidden;
      background: color-mix(in srgb, #10b981 4%, var(--surface));
    }
    .board-top {
      display: flex; align-items: flex-end; justify-content: space-between; gap: 12px;
      padding: 20px 22px; border-bottom: 1px solid var(--border);
