  <!-- Estilos de las tarjetas generadas por JS (innerHTML) — deben ser globales
       porque no reciben el atributo de scope de Astro. Todo va con prefijo .ai-* -->
  <style is:global>
    .ai-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; padding: 14px;
      display: flex; flex-direction: column; gap: 12px;
