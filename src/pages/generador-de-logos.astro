---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Generador de Logos Gratis con IA | Marcos Santiago — Puerto Rico"
  description="Genera 3 conceptos de logo gratis con inteligencia artificial en segundos. Escribe el nombre de tu negocio y míralo hoy. Diseñador gráfico en Puerto Rico para convertirlo en marca real desde $50."
  image="/marcos-photo.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebApplication",
        "name": "Generador de Logos con IA — Marcos Santiago",
        "url": "https://marcossantiago.com/generador-de-logos/",
        "applicationCategory": "DesignApplication",
        "operatingSystem": "Web",
        "inLanguage": "es",
        "description": "Herramienta gratuita que genera 3 conceptos de logo con inteligencia artificial a partir del nombre y rubro de tu negocio.",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "author": { "@id": "https://marcossantiago.com/#persona" },
        "provider": { "@id": "https://marcossantiago.com/#negocio" }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿El generador de logos es realmente gratis?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí. Escribes el nombre de tu negocio y la inteligencia artificial te muestra 3 conceptos de logo sin costo, sin registrarte y sin tarjeta de crédito. Yo pago la generación; si te gusta alguno y quieres convertirlo en marca de verdad, ahí es donde entro a trabajar." }
          },
          {
            "@type": "Question",
            "name": "¿Puedo usar el logo de la IA tal cual para mi negocio?",
            "acceptedAnswer": { "@type": "Answer", "text": "Te lo digo honesto: no te lo recomiendo. Lo que genera la IA es una imagen de referencia, no un archivo de marca. No viene vectorizado, la tipografía no es una fuente real que puedas editar, y no sirve para imprenta ni para rotulación. Es un excelente punto de partida para ver hacia dónde va tu marca — el trabajo fino lo hago yo a mano." }
          },
          {
            "@type": "Question",
            "name": "¿En qué formato me entregas el logo final?",
            "acceptedAnswer": { "@type": "Answer", "text": "Cuando trabajamos el logo de verdad recibes los archivos vectoriales editables (SVG y PDF) más PNG en alta resolución con fondo transparente, en versiones a color, en negro y en blanco. Eso es lo que necesitas para imprenta, rotulación, redes sociales y web." }
          },
          {
            "@type": "Question",
            "name": "¿Cuánto cuesta convertir el concepto en un logo profesional?",
            "acceptedAnswer": { "@type": "Answer", "text": "El diseño gráfico comienza desde $50 para piezas individuales. Un paquete completo de identidad de marca (logo con variantes, paleta de colores, tipografía y guía de estilo) se cotiza según el alcance del proyecto. La cotización es gratis y respondo en menos de una hora." }
          },
          {
            "@type": "Question",
            "name": "¿Cuánto tardan en salir los conceptos?",
            "acceptedAnswer": { "@type": "Answer", "text": "El primer concepto aparece en unos 15 segundos y los tres están listos en menos de un minuto y medio. Van apareciendo uno por uno según se van dibujando." }
          },
          {
            "@type": "Question",
            "name": "¿Trabajas con negocios de toda Puerto Rico?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí. Estoy en Aibonito y el diseño se trabaja de forma remota, así que atiendo negocios de toda la isla — y fuera de ella — sin problema." }
          }
        ]
      }
    ]
  })} />

  <!-- Minimal PPC header — no escape nav -->
  <header class="ppc-header">
    <div class="container ppc-header-inner">
      <a href="/" class="ppc-logo" aria-label="Marcos Santiago — inicio">MARCOS SANTIAGO</a>
      <a href="tel:+17872439670" class="ppc-phone" data-track="call-header">
        <i class="fa-solid fa-phone"></i> (787) 243-9670
      </a>
    </div>
  </header>

  <main id="main">
    <!-- ── Hero + herramienta (la herramienta va arriba del fold a propósito) ── -->
    <section class="tool-hero">
      <div class="container">
        <p class="section-label">Herramienta gratis · Sin registro</p>
        <h1 class="tool-title">Generador de logos<br><span class="accent">con inteligencia artificial</span></h1>
        <p class="tool-sub">
          Escribe el nombre de tu negocio y mira <strong>3 conceptos de logo en segundos</strong>.
          Gratis, sin cuenta y sin tarjeta. La IA pone la chispa;
          <strong>yo la convierto en una marca de verdad</strong>.
        </p>

        <div class="tool-panel">
          <div class="tool-panel-head">
            <span class="tp-step">Paso 1</span>
            <span class="tp-head-label">Describe y personaliza tu logo</span>
          </div>

          <form class="ai-form" id="aiForm">
            <div class="ai-essentials">
              <div class="ai-field">
                <label for="aiName">Nombre del negocio</label>
                <input id="aiName" type="text" maxlength="40" placeholder="Ej: Café Lola" autocomplete="off" required />
              </div>
              <div class="ai-field">
                <label for="aiIndustry">Rubro <span>(opcional)</span></label>
                <input id="aiIndustry" type="text" maxlength="40" placeholder="Ej: cafetería" autocomplete="off" />
              </div>
            </div>

            <div class="ai-control">
              <span class="ai-control-label">Estilo</span>
              <div class="chips" id="styleChips" role="group" aria-label="Estilo del logo">
                <button type="button" class="chip is-on" data-style="moderno">Moderno</button>
                <button type="button" class="chip" data-style="minimalista">Minimalista</button>
                <button type="button" class="chip" data-style="elegante">Elegante</button>
                <button type="button" class="chip" data-style="divertido">Divertido</button>
                <button type="button" class="chip" data-style="clasico">Clásico</button>
                <button type="button" class="chip" data-style="tecnologico">Tecnológico</button>
                <button type="button" class="chip" data-style="organico">Orgánico</button>
              </div>
            </div>

            <div class="ai-control">
              <span class="ai-control-label">Tipografía</span>
              <div class="chips" id="typoChips" role="group" aria-label="Tipografía">
                <button type="button" class="chip is-on" data-typo="auto">Automática</button>
                <button type="button" class="chip" data-typo="sans">Sans moderna</button>
                <button type="button" class="chip" data-typo="serif">Serif elegante</button>
                <button type="button" class="chip" data-typo="script">Manuscrita</button>
                <button type="button" class="chip" data-typo="display">Display fuerte</button>
                <button type="button" class="chip" data-typo="mono">Mono tech</button>
                <button type="button" class="chip" data-typo="redondeada">Redondeada</button>
              </div>
            </div>
            <div class="ai-control">
              <span class="ai-control-label">Color</span>
              <div class="swatches" id="paletteSwatches" role="group" aria-label="Paleta de color">
                <button type="button" class="swatch is-on" data-palette="mono" style="--sw:#111827"><span class="sw-dot"></span>Monocromo</button>
                <button type="button" class="swatch" data-palette="azul" style="--sw:#2563eb"><span class="sw-dot"></span>Azul</button>
                <button type="button" class="swatch" data-palette="verde" style="--sw:#16a34a"><span class="sw-dot"></span>Verde</button>
                <button type="button" class="swatch" data-palette="terracota" style="--sw:#ea580c"><span class="sw-dot"></span>Terracota</button>
                <button type="button" class="swatch" data-palette="purpura" style="--sw:#7c3aed"><span class="sw-dot"></span>Púrpura</button>
                <button type="button" class="swatch" data-palette="dorado" style="--sw:#d4a017"><span class="sw-dot"></span>Dorado</button>
                <button type="button" class="swatch" data-palette="vibrante" style="--sw:#e11d48"><span class="sw-dot"></span>Vibrante</button>
              </div>
            </div>

            <button type="submit" class="btn primary ai-go" id="aiGo" data-track="generar">Generar mis 3 logos gratis</button>
          </form>
        </div>

        <p class="tool-trust">
          <span><i class="fa-solid fa-bolt"></i> El primero sale en ~15 segundos</span>
          <span><i class="fa-solid fa-lock-open"></i> Sin registro ni tarjeta</span>
          <span><i class="fa-solid fa-location-dot"></i> Diseñador real en Puerto Rico</span>
        </p>

        <p class="ai-status" id="aiStatus" hidden></p>

        <div class="ai-results" id="aiResults" hidden></div>

        <div class="ai-board" id="aiBoard" hidden></div>

        <div class="ai-lead-box" id="aiLeadBox" hidden>
          <div class="ai-lead-copy">
            <h3>¿Te gustó alguno?</h3>
            <p>Toca <strong>"Elegir este"</strong> en tu favorito, déjame tu contacto y te lo envío en <strong>alta resolución, editable y refinado a mano</strong> — listo para tu marca.</p>
            <p class="ai-liked-hint" id="aiLikedHint" hidden>Concepto elegido: <span></span></p>
          </div>
          <form class="ai-lead-form" id="aiLeadForm">
            <input id="leadName" type="text" placeholder="Tu nombre" maxlength="60" autocomplete="name" />
            <input id="leadContact" type="text" placeholder="Teléfono o email" maxlength="80" autocomplete="tel" required />
            <button type="submit" class="btn primary" id="leadGo">Quiero mis conceptos →</button>
          </form>
          <p class="ai-lead-ok" id="aiLeadOk" hidden>✓ ¡Listo! Te escribo hoy mismo con tus conceptos.</p>
          <a class="ai-wa" href="https://wa.me/17872439670" target="_blank" rel="noopener" data-track="whatsapp-lead">o escríbeme directo por WhatsApp →</a>
        </div>

        <p class="ai-gallery-link"><a href="/galeria-logos/">Ver galería de logos ya generados →</a></p>
      </div>
    </section>

    <!-- ── Cómo funciona ── -->
    <section class="steps-section">
      <div class="container">
        <p class="section-label">Cómo funciona</p>
        <h2 class="section-title">Tres pasos, <span class="accent">cero compromiso</span></h2>
        <div class="steps-grid">
          <div class="step-card">
            <span class="step-num">01</span>
            <h3>Escribe tu negocio</h3>
            <p>Nombre, rubro y el estilo que tienes en mente. Nada más — no pido correo ni cuenta para generar.</p>
          </div>
          <div class="step-card">
            <span class="step-num">02</span>
            <h3>Mira 3 conceptos</h3>
            <p>Un símbolo, un wordmark y una versión combinada. Aparecen uno por uno según se van dibujando.</p>
          </div>
          <div class="step-card">
            <span class="step-num">03</span>
            <h3>Yo lo hago marca</h3>
            <p>Eliges el que te llegó, me dejas tu contacto y te lo devuelvo vectorizado, refinado y listo para usar.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── De concepto a marca real (el pitch honesto) ── -->
    <section class="real-section">
      <div class="container">
        <div class="real-grid">
          <div class="real-copy">
            <p class="section-label">La parte que la IA no hace</p>
            <h2 class="section-title">Un concepto bonito<br>no es <span class="accent">una marca</span></h2>
            <p class="real-text">
              Te lo digo claro porque prefiero un cliente informado que una venta rápida:
              lo que sale del generador es una <strong>imagen de referencia</strong>. No viene
              vectorizada, la tipografía no es editable y no sirve para imprenta ni rotulación.
            </p>
            <p class="real-text">
              Sirve para algo valiosísimo: <strong>ver hacia dónde va tu marca antes de gastar un peso</strong>.
              Cuando ya sabes qué te gusta, yo lo redibujo a mano y te entrego lo que un negocio
              de verdad necesita.
            </p>
            <ul class="real-list">
              <li><i class="fa-solid fa-check"></i> Logo vectorizado a mano (SVG y PDF editables)</li>
              <li><i class="fa-solid fa-check"></i> Variantes: color, negro, blanco y versión compacta</li>
              <li><i class="fa-solid fa-check"></i> PNG en alta resolución con fondo transparente</li>
              <li><i class="fa-solid fa-check"></i> Paleta de colores y tipografía de marca</li>
              <li><i class="fa-solid fa-check"></i> Listo para imprenta, rotulación, redes y web</li>
            </ul>
            <div class="real-price">
              <span class="price-badge">Desde <strong>$50</strong></span>
              <span class="price-note">· Cotización gratis · Respondo en &lt;1 hora</span>
            </div>
            <div class="real-actions">
              <a href="https://wa.me/17872439670?text=Hola%2C%20gener%C3%A9%20unos%20conceptos%20de%20logo%20en%20tu%20p%C3%A1gina%20y%20quiero%20trabajarlos."
                 target="_blank" rel="noopener" class="hero-cta hero-cta-wa" data-track="whatsapp">
                <i class="fab fa-whatsapp"></i> Hablemos por WhatsApp
              </a>
              <a href="/diseno-grafico-pr/" class="hero-cta hero-cta-form">
                <i class="fa-solid fa-pen-nib"></i> Ver servicio de branding
              </a>
            </div>
          </div>
          <div class="real-photo">
            <div class="real-photo-bg" aria-hidden="true"></div>
            <img src="/marcos-photo.jpg" alt="Marcos Santiago, diseñador gráfico en Puerto Rico" width="640" height="800" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="faq-section">
      <div class="container">
        <p class="section-label">Preguntas</p>
        <h2 class="section-title">Lo que todo el mundo <span class="accent">pregunta</span></h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>¿El generador de logos es realmente gratis?</summary>
            <p>Sí. Escribes el nombre de tu negocio y la IA te muestra 3 conceptos sin costo, sin registrarte y sin tarjeta de crédito. Yo pago la generación; si te gusta alguno y quieres convertirlo en marca de verdad, ahí es donde entro a trabajar.</p>
          </details>
          <details class="faq-item">
            <summary>¿Puedo usar el logo de la IA tal cual para mi negocio?</summary>
            <p>Te lo digo honesto: no te lo recomiendo. Lo que genera la IA es una imagen de referencia, no un archivo de marca. No viene vectorizado, la tipografía no es una fuente real que puedas editar, y no sirve para imprenta ni rotulación. Es un excelente punto de partida — el trabajo fino lo hago yo a mano.</p>
          </details>
          <details class="faq-item">
            <summary>¿En qué formato me entregas el logo final?</summary>
            <p>Recibes los archivos vectoriales editables (SVG y PDF) más PNG en alta resolución con fondo transparente, en versiones a color, en negro y en blanco. Eso es lo que necesitas para imprenta, rotulación, redes sociales y web.</p>
          </details>
          <details class="faq-item">
            <summary>¿Cuánto cuesta convertirlo en un logo profesional?</summary>
            <p>El diseño gráfico comienza desde $50 para piezas individuales. Un paquete completo de identidad de marca (logo con variantes, paleta, tipografía y guía de estilo) se cotiza según el alcance. La cotización es gratis y respondo en menos de una hora.</p>
          </details>
          <details class="faq-item">
            <summary>¿Cuánto tardan en salir los conceptos?</summary>
            <p>El primero aparece en unos 15 segundos y los tres están listos en menos de minuto y medio. Van apareciendo uno por uno según se van dibujando, así que no te quedas mirando una pantalla en blanco.</p>
          </details>
          <details class="faq-item">
            <summary>¿Trabajas con negocios de toda Puerto Rico?</summary>
            <p>Sí. Estoy en Aibonito y el diseño se trabaja de forma remota, así que atiendo negocios de toda la isla — y fuera de ella — sin problema.</p>
          </details>
        </div>
        <div class="faq-cta">
          <a href="https://wa.me/17872439670?text=Hola%2C%20tengo%20una%20pregunta%20sobre%20el%20dise%C3%B1o%20de%20mi%20logo."
             target="_blank" rel="noopener" class="faq-wa-btn" data-track="whatsapp">
            <i class="fab fa-whatsapp"></i> ¿Otra pregunta? Escríbeme por WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Sticky mobile bar -->
  <div class="sticky-bar" id="stickyBar" aria-hidden="true">
    <a href="tel:+17872439670" class="sticky-btn sticky-call" data-track="call-sticky">
      <i class="fa-solid fa-phone"></i> Llamar
    </a>
    <a href="https://wa.me/17872439670?text=Hola%2C%20quiero%20trabajar%20el%20logo%20de%20mi%20negocio."
       target="_blank" rel="noopener" class="sticky-btn sticky-wa" data-track="whatsapp-sticky">
      <i class="fab fa-whatsapp"></i> WhatsApp
    </a>
  </div>

  <style>
  /* Accent local — mismo verde esmeralda que /diseno-grafico-pr/ (misma campaña) */
  main { --accent: #10b981 }

  /* ── PPC Header ── */
  .ppc-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 800;
    background: rgba(4,13,22,.92); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border); padding: 12px 0;
  }
  .ppc-header-inner { display: flex; align-items: center; justify-content: space-between }
  .ppc-logo {
    font-family: var(--display); font-size: .95rem;
    letter-spacing: 4px; color: var(--white); text-decoration: none;
  }
  .ppc-phone {
    font-family: var(--mono); font-size: .65rem; letter-spacing: 1.5px;
    color: #10b981; text-decoration: none; border: 1px solid #10b981;
    border-radius: 8px; padding: 6px 14px; transition: .15s;
    display: flex; align-items: center; gap: 6px;
  }
  .ppc-phone:hover { background: #10b981; color: #fff }

  /* ── Hero + herramienta ── */
  .tool-hero { padding: 120px 0 70px; border-bottom: 1px solid var(--border) }
  .tool-title {
    font-family: var(--display);
    font-size: clamp(2.6rem, 8vw, 5.4rem);
    line-height: .94; letter-spacing: 2px;
    margin: 8px 0 20px; color: var(--white);
  }
  .tool-sub {
    color: var(--muted); font-size: 1.08rem; line-height: 1.75; max-width: 62ch;
  }
  .tool-sub strong { color: var(--white); font-weight: 600 }
  .tool-trust {
    display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px;
  }
  .tool-trust span {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--mono); font-size: .55rem; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted);
    border: 1px solid var(--border); border-radius: 20px; padding: 6px 13px;
  }
  .tool-trust i { color: var(--accent) }

  /* ── Panel de la herramienta ── */
  .tool-panel {
    margin-top: 34px;
    background: color-mix(in srgb, var(--white) 3%, var(--surface));
    border: 1px solid var(--border); border-radius: 20px;
    padding: 4px 22px 22px;
  }
  .tool-panel-head {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 2px; border-bottom: 1px solid var(--border); margin-bottom: 20px;
  }
  .tp-step {
    font-family: var(--mono); font-size: .55rem; letter-spacing: 1.5px;
    text-transform: uppercase; color: #040d16;
    background: var(--accent); padding: 4px 9px; border-radius: 6px;
  }
  .tp-head-label {
    font-family: var(--mono); font-size: var(--text-2xs);
    letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
  }

  .ai-form { display: flex; flex-direction: column; gap: 20px }
  .ai-essentials { display: flex; flex-wrap: wrap; gap: 14px }
  .ai-field { display: flex; flex-direction: column; gap: 8px; flex: 1; min-width: 190px }
  .ai-field label {
    font-family: var(--mono); font-size: var(--text-2xs);
    letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
  }
  .ai-field label span { text-transform: none; letter-spacing: 0; opacity: .7 }
  .ai-field input {
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    padding: 13px 15px; color: var(--white); font-size: 1rem;
    font-family: inherit; transition: border-color .2s;
  }
  .ai-field input::placeholder { color: color-mix(in srgb, var(--muted) 80%, transparent) }
  .ai-field input:focus { outline: none; border-color: var(--accent) }

  /* Controles (chips / swatches) */
  .ai-control { display: flex; flex-direction: column; gap: 10px }
  .ai-control-label {
    font-family: var(--mono); font-size: var(--text-2xs);
    letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
  }
  .chips { display: flex; flex-wrap: wrap; gap: 8px }
  .chip {
    font-family: var(--mono); font-size: .62rem; letter-spacing: 1px;
    text-transform: uppercase; padding: 9px 15px; border-radius: 999px;
    border: 1px solid var(--border); background: transparent;
    color: var(--muted); cursor: pointer; transition: .16s ease;
  }
  .chip:hover { border-color: var(--border-h); color: var(--white) }
  .chip.is-on {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    color: color-mix(in srgb, var(--accent) 90%, var(--white));
  }

  .swatches { display: flex; flex-wrap: wrap; gap: 8px }
  .swatch {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: .62rem; letter-spacing: 1px;
    text-transform: uppercase; padding: 8px 14px 8px 10px; border-radius: 999px;
    border: 1px solid var(--border); background: transparent;
    color: var(--muted); cursor: pointer; transition: .16s ease;
  }
  .swatch .sw-dot {
    width: 14px; height: 14px; border-radius: 50%; background: var(--sw);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.2); flex-shrink: 0;
  }
  .swatch:hover { border-color: var(--border-h); color: var(--white) }
  .swatch.is-on { border-color: var(--sw); color: var(--white);
    background: color-mix(in srgb, var(--sw) 14%, transparent) }

  .ai-go { width: 100%; height: 52px }

  @media (max-width: 700px) {
    .ai-essentials { flex-direction: column }
    .tool-panel { padding: 4px 15px 18px }
  }

  .ai-status {
    font-family: var(--mono); font-size: var(--text-xs);
    letter-spacing: .5px; color: var(--muted); margin-top: 22px; line-height: 1.6;
  }
  .ai-results {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px; margin-top: 22px;
  }
  @media (max-width: 760px) { .ai-results { grid-template-columns: 1fr } }

  .ai-lead-box {
    margin-top: 28px; padding: 26px; border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border));
