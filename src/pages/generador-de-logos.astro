    }
    .board-preview img { max-width: 100%; max-height: 100%; object-fit: contain; display: block }
    .board-preview[data-bg="light"] { background: #ffffff }
    .board-preview[data-bg="dark"]  { background: #0e1116 }
    .board-preview[data-bg="trans"],
    .bv-thumb.checker {
      background-color: #e6e6ec;
      background-image:
        linear-gradient(45deg,#c4c4cf 25%,transparent 25%),
        linear-gradient(-45deg,#c4c4cf 25%,transparent 25%),
        linear-gradient(45deg,transparent 75%,#c4c4cf 75%),
        linear-gradient(-45deg,transparent 75%,#c4c4cf 75%);
      background-size: 18px 18px;
      background-position: 0 0, 0 9px, 9px -9px, -9px 0;
    }
    .bv-thumb.checker { background-size: 10px 10px; background-position: 0 0, 0 5px, 5px -5px, -5px 0 }

    .board-side { display: flex; flex-direction: column; gap: 16px }
    .board-variants { display: flex; gap: 8px }
    .bvar {
      flex: 1; display: flex; flex-direction: column; align-items: center; gap: 7px;
      background: none; border: 1px solid var(--border); border-radius: 10px; padding: 8px 5px;
      cursor: pointer; transition: .16s;
      font-family: var(--mono); font-size: .5rem; letter-spacing: 1px; text-transform: uppercase; color: var(--muted);
    }
    .bvar:hover { border-color: var(--border-h); color: var(--white) }
    .bvar.is-on { border-color: #10b981; color: var(--white) }
    .bv-thumb {
      width: 100%; aspect-ratio: 1; border-radius: 6px; overflow: hidden;
      display: flex; align-items: center; justify-content: center; padding: 6px;
    }
    .bv-thumb img { max-width: 100%; max-height: 100%; object-fit: contain }
    .bv-thumb.light { background: #fff }
    .bv-thumb.dark  { background: #0e1116 }

    .board-block { display: flex; flex-direction: column; gap: 9px }
    .board-block-label {
      font-family: var(--mono); font-size: .5rem; letter-spacing: 2px;
      text-transform: uppercase; color: var(--muted);
    }
    .board-palette { display: flex; gap: 6px }
    .board-sw { width: 30px; height: 30px; border-radius: 7px; box-shadow: inset 0 0 0 1px rgba(255,255,255,.14) }
    .board-type { font-family: var(--body); font-size: .92rem; color: var(--white) }

    .board-mockups { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px }
    @media (max-width: 700px) { .board-mockups { grid-template-columns: repeat(2, 1fr) } }
    .mock { display: flex; flex-direction: column; gap: 8px }
    .mock-label {
      font-family: var(--mono); font-size: .5rem; letter-spacing: 1px;
      text-transform: uppercase; color: var(--muted); text-align: center;
    }
    .mock-frame {
      aspect-ratio: 1; border-radius: 12px; overflow: hidden; position: relative;
      display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border);
    }
    .mock-frame img { max-width: 100%; max-height: 100%; object-fit: contain }
    .mock-app .mock-frame  { padding: 24% }
    .mock-sign .mock-frame { background: radial-gradient(circle at 50% 32%, #262b33, #0d1015); padding: 22% }
    .mock-sign img { filter: drop-shadow(0 0 10px rgba(255,255,255,.22)) }
    .mock-tote .mock-frame { padding: 26% }
    .mock-card .mock-frame { background: #f4f2ec; padding: 14%; align-items: stretch }
    .mock-card-face { width: 100%; display: flex; flex-direction: column; justify-content: space-between }
    .mock-card-face img { height: 38%; object-position: left center; align-self: flex-start }
    .mc-name { font-family: var(--display); font-size: .82rem; letter-spacing: 1px; line-height: 1 }
    .mc-sub { display: block; height: 3px; width: 55%; border-radius: 2px; margin-top: 6px; opacity: .55 }

    .board-foot {
      margin: 0; padding: 16px 22px; border-top: 1px solid var(--border);
      font-size: .82rem; color: var(--muted); line-height: 1.55;
    }
    .board-foot strong { color: var(--white) }
  </style>

  <script>
    (() => {
      const API = '/logo-api';
      const LABELS = ['Símbolo', 'Wordmark', 'Combinado'];
      const $ = (id) => document.getElementById(id);
      const form = $('aiForm');
      if (!form) return;
      const nameEl = $('aiName'), industryEl = $('aiIndustry');
      const goBtn = $('aiGo'), statusEl = $('aiStatus'), results = $('aiResults');
      const board = $('aiBoard');
      const leadBox = $('aiLeadBox'), leadForm = $('aiLeadForm'), leadOk = $('aiLeadOk');
      const waLink = document.querySelector('.ai-wa');

      // Etiquetas + paletas para el brand board (deben empatar con PALETTE_MAP del backend)
      const TYPOS = {
        auto: 'Automática', sans: 'Sans moderna', serif: 'Serif elegante', script: 'Manuscrita',
        display: 'Display fuerte', mono: 'Mono tech', redondeada: 'Redondeada',
      };
      const PALETTES = {
        mono:      { primary: '#111827', swatches: ['#111827', '#4b5563', '#9ca3af', '#e5e7eb'] },
        azul:      { primary: '#1e40af', swatches: ['#1e3a8a', '#2563eb', '#93c5fd', '#0f172a'] },
        verde:     { primary: '#15803d', swatches: ['#166534', '#22c55e', '#86efac', '#052e16'] },
        terracota: { primary: '#c2410c', swatches: ['#9a3412', '#ea580c', '#fdba74', '#431407'] },
        purpura:   { primary: '#6d28d9', swatches: ['#5b21b6', '#8b5cf6', '#c4b5fd', '#2e1065'] },
        dorado:    { primary: '#b45309', swatches: ['#a16207', '#eab308', '#fde68a', '#1c1917'] },
        vibrante:  { primary: '#e11d48', swatches: ['#ef4444', '#f59e0b', '#3b82f6', '#10b981'] },
      };

      const conceptStore = [null, null, null];   // {id, url} por variant
      const sel = { style: 'moderno', typo: 'auto', palette: 'mono' };
      let ctx = { name: '', industry: '', style: 'moderno', typo: 'auto', palette: 'mono' };
      let picked = null;   // variant elegido por el usuario

      const track = (event, params) => {
        const g = window.gtag;
        if (typeof g === 'function') g('event', event, params);
      };
      const esc = (s) => (s || '').replace(/[<>&"]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' }[c]));
      function shade(hex, pct) {   // pct<0 oscurece, pct>0 aclara
        const n = parseInt(hex.slice(1), 16);
        let r = (n >> 16) & 255, g = (n >> 8) & 255, b = n & 255;
        const f = pct < 0 ? 0 : 255, p = Math.abs(pct);
        r = Math.round((f - r) * p + r); g = Math.round((f - g) * p + g); b = Math.round((f - b) * p + b);
        return '#' + ((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1);
      }

      // ── Chips / swatches ──
      function wireGroup(containerId, dataKey, stateKey) {
        const c = $(containerId);
        if (!c) return;
        c.addEventListener('click', (e) => {
          const b = e.target.closest('[data-' + dataKey + ']');
          if (!b) return;
          c.querySelectorAll('.is-on').forEach((x) => x.classList.remove('is-on'));
          b.classList.add('is-on');
          sel[stateKey] = b.dataset[dataKey];
        });
      }
      wireGroup('styleChips', 'style', 'style');
      wireGroup('typoChips', 'typo', 'typo');
      wireGroup('paletteSwatches', 'palette', 'palette');

      // ── Brand board ──
      function renderBoard(i) {
        const c = conceptStore[i];
        if (!c || !board) return;
        const pal = PALETTES[ctx.palette] || PALETTES.mono;
        const primary = pal.primary, dark = shade(primary, -0.35);
        const colorUrl = c.url + '?v=transparent';   // tinta original, fondo transparente
        const whiteUrl = c.url + '?v=white';          // knockout blanco
        const biz = esc(ctx.name);
        const sw = pal.swatches.map((s) => '<span class="board-sw" style="background:' + s + '"></span>').join('');

        board.innerHTML =
          '<div class="board-inner">' +
            '<div class="board-top">' +
              '<div><span class="board-kicker">Tablero de marca</span>' +
              '<span class="board-name">' + biz + '</span></div>' +
              '<span class="board-concept">' + LABELS[i] + '</span>' +
            '</div>' +
            '<div class="board-body">' +
              '<div class="board-main">' +
                '<div class="board-preview" id="boardPreview" data-bg="light"><img id="boardHero" src="' + colorUrl + '" alt="Logo ' + biz + '"></div>' +
                '<div class="board-side">' +
                  '<div class="board-variants" id="boardVars">' +
                    '<button type="button" class="bvar is-on" data-bg="light" data-src="' + colorUrl + '"><span class="bv-thumb light"><img src="' + colorUrl + '" alt=""></span>Color</button>' +
                    '<button type="button" class="bvar" data-bg="dark" data-src="' + whiteUrl + '"><span class="bv-thumb dark"><img src="' + whiteUrl + '" alt=""></span>Negativo</button>' +
                    '<button type="button" class="bvar" data-bg="trans" data-src="' + colorUrl + '"><span class="bv-thumb checker"><img src="' + colorUrl + '" alt=""></span>Transp.</button>' +
                  '</div>' +
                  '<div class="board-block"><span class="board-block-label">Paleta</span><div class="board-palette">' + sw + '</div></div>' +
                  '<div class="board-block"><span class="board-block-label">Tipografía</span><span class="board-type">' + (TYPOS[ctx.typo] || 'Automática') + '</span></div>' +
                '</div>' +
              '</div>' +
              '<span class="board-block-label" style="display:block;margin-bottom:12px">Cómo se vería tu marca</span>' +
              '<div class="board-mockups">' +
                '<div class="mock mock-app"><div class="mock-frame" style="background:linear-gradient(135deg,' + primary + ',' + dark + ')"><img src="' + whiteUrl + '" alt=""></div><span class="mock-label">Ícono de app</span></div>' +
                '<div class="mock mock-card"><div class="mock-frame"><div class="mock-card-face"><img src="' + colorUrl + '" alt=""><div><span class="mc-name" style="color:' + primary + '">' + biz + '</span><span class="mc-sub" style="background:' + primary + '"></span></div></div></div><span class="mock-label">Tarjeta</span></div>' +
                '<div class="mock mock-sign"><div class="mock-frame"><img src="' + whiteUrl + '" alt=""></div><span class="mock-label">Rótulo</span></div>' +
                '<div class="mock mock-tote"><div class="mock-frame" style="background:' + primary + '"><img src="' + whiteUrl + '" alt=""></div><span class="mock-label">Tote / camiseta</span></div>' +
              '</div>' +
            '</div>' +
            '<p class="board-foot"><strong>Es una simulación automática.</strong> El logo vectorizado de verdad, la paleta afinada y estas piezas listas para imprenta te las entrego yo — déjame tu contacto abajo.</p>' +
          '</div>';
        board.hidden = false;
      }

      // Switch de variante en el preview grande (delegado, el contenedor no se re-crea)
      if (board) {
        board.addEventListener('click', (e) => {
          const b = e.target.closest('.bvar');
          if (!b) return;
          board.querySelectorAll('.bvar').forEach((x) => x.classList.remove('is-on'));
          b.classList.add('is-on');
          const prev = $('boardPreview'), hero = $('boardHero');
          if (prev) prev.dataset.bg = b.dataset.bg;
          if (hero) hero.src = b.dataset.src;
        });
      }

      const slotMarkup = () => LABELS.map((lb, i) => (
        '<div class="ai-card" data-slot="' + i + '">' +
          '<div class="ai-card-head">' +
            '<span class="ai-card-label">' + lb + '</span>' +
          '</div>' +
          '<div class="ai-canvas"><div class="ai-skeleton"></div></div>' +
          '<button class="ai-pick" data-pick="' + i + '" hidden>Elegir este</button>' +
        '</div>'
      )).join('');

      function selectVariant(i) {
        picked = i;
        results.querySelectorAll('.ai-card').forEach((el) => {
          const on = +el.dataset.slot === i;
          el.classList.toggle('selected', on);
          const btn = el.querySelector('.ai-pick');
          if (btn) btn.textContent = on ? '✓ Elegido' : 'Elegir este';
        });
        const hint = document.getElementById('aiLikedHint');
        if (hint) { hint.hidden = false; hint.querySelector('span').textContent = LABELS[i]; }
        renderBoard(i);
        const c = document.getElementById('leadContact');
        if (c) c.focus({ preventScroll: true });
        track('logo_concept_picked', { event_category: 'engagement', event_label: LABELS[i] });
      }

      async function genVariant(i) {
        const card = results.querySelector('[data-slot="' + i + '"]');
        const canvas = card.querySelector('.ai-canvas');
        card.classList.remove('err');
        canvas.innerHTML = '<div class="ai-skeleton"></div>';
        try {
          const r = await fetch(API + '/generate', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: ctx.name, industry: ctx.industry, style: ctx.style, typography: ctx.typo, palette: ctx.palette, variant: i }),
          });
          const data = await r.json();
          if (!r.ok || !data.concept || !data.concept.url) throw new Error((data && data.message) || 'error');
          conceptStore[i] = { id: data.concept.id, url: data.concept.url };
          canvas.innerHTML = '<img src="' + data.concept.url + '" alt="Concepto de logo generado con IA para ' + ctx.name + '">';
          card.querySelector('.ai-pick').hidden = false;
        } catch (e) {
          card.classList.add('err');
          canvas.innerHTML = '<button class="ai-retry" data-retry="' + i + '">Reintentar</button>';
          track('logo_generate_error', { event_category: 'engagement', event_label: 'variant_' + i });
        }
      }

      async function run() {
        const name = nameEl.value.trim();
        if (!name) { nameEl.focus(); return; }
        ctx = { name, industry: industryEl.value.trim(), style: sel.style, typo: sel.typo, palette: sel.palette };
        goBtn.disabled = true; goBtn.textContent = 'Generando…';
        statusEl.hidden = false;
        statusEl.textContent = 'La IA está dibujando tus conceptos… (unos segundos cada uno)';
        picked = null;
        results.hidden = false; results.innerHTML = slotMarkup();
        if (board) board.hidden = true;
        const hint0 = document.getElementById('aiLikedHint'); if (hint0) hint0.hidden = true;
        leadBox.hidden = true; leadOk.hidden = true; if (leadForm) leadForm.hidden = false;
        track('logo_generate_start', { event_category: 'engagement', event_label: ctx.style });
        for (let i = 0; i < 3; i++) { await genVariant(i); }
        goBtn.disabled = false; goBtn.textContent = 'Generar otra vez';
        statusEl.textContent = 'Estos son puntos de partida — yo los perfecciono a mano hasta que queden perfectos.';
        if (waLink) {
          const msg = 'Hola Marcos, generé unos conceptos de logo para "' + ctx.name + '" en tu página y me gustaría trabajarlos.';
          waLink.href = 'https://wa.me/17872439670?text=' + encodeURIComponent(msg);
        }
        leadBox.hidden = false;
        track('logo_generate_done', { event_category: 'engagement', event_label: ctx.style });
      }

      form.addEventListener('submit', (e) => { e.preventDefault(); run(); });

      results.addEventListener('click', (e) => {
        const rt = e.target.closest('[data-retry]');
        if (rt) { genVariant(+rt.dataset.retry); return; }
        const pk = e.target.closest('[data-pick]');
        if (pk) { selectVariant(+pk.dataset.pick); return; }
      });

      leadForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const contact = $('leadContact').value.trim();
        if (!contact) return;
        const btn = $('leadGo');
        btn.disabled = true; btn.textContent = 'Enviando…';
        let liked = '', likedId = '';
        if (picked !== null && conceptStore[picked]) {
          liked = LABELS[picked];
          likedId = conceptStore[picked].id;
        }
        try {
          await fetch(API + '/lead', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contact, name: $('leadName').value.trim(),
              business: ctx.name, style: ctx.style, industry: ctx.industry,
              liked, liked_id: likedId,
              source: 'generador-de-logos',
            }),
          });
          leadForm.hidden = true; leadOk.hidden = false;
          track('generate_lead', { event_category: 'engagement', event_label: 'generador-de-logos' });
        } catch (e2) {
          btn.disabled = false; btn.textContent = 'Quiero mis conceptos →';
        }
      });
    })();
  </script>

  <script is:inline>
  // Sticky bar on scroll
  (function() {
    const bar = document.getElementById('stickyBar');
    if (!bar) return;
    bar.setAttribute('aria-hidden', 'false');
    let shown = false;
    window.addEventListener('scroll', function() {
      const past = window.scrollY > 300;
      if (past !== shown) { shown = past; bar.style.display = past ? 'flex' : 'none'; }
    }, { passive: true });
  })();

  // GA4 CTA tracking
  document.querySelectorAll('[data-track]').forEach(function(el) {
    el.addEventListener('click', function() {
      if (typeof gtag === 'function') gtag('event', 'cta_click', { event_category: 'engagement', event_label: el.dataset.track });
    });
  });
  </script>
</Base>
