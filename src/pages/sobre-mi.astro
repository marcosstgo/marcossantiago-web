---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

/* La secuencia es cronológica de verdad: el año es el dato, no un adorno. */
const capitulos = [
  {
    anio: '2001',
    meta: ['Univ. Interamericana', 'Ciencias de Computadoras'],
    titulo: 'El código primero',
    parrafos: [
      `Mi carrera comenzó desde la tecnología. Estudié Ciencias de Computadoras con
       concentración en Programación Comercial y luego completé una maestría en Comercio
       Electrónico en la Universidad Interamericana de Puerto Rico.`,
      `Esa formación me enseñó a combinar estrategia, diseño y programación para convertir
       ideas en soluciones útiles, funcionales y visualmente atractivas.`,
    ],
  },
  {
    anio: '2012',
    meta: ['Sony NEX-3', 'Fines de semana'],
    titulo: 'Aprender a mirar',
    parrafos: [
      `Una Sony NEX-3 despertó mi interés por la fotografía. Lo que comenzó fotografiando
       durante los fines de semana fue creciendo con cada proyecto y terminó abriéndome
       las puertas al video.`,
      `Desde entonces, la imagen dejó de ser un complemento y se convirtió en una parte
       esencial de mi manera de comunicar y contar historias.`,
    ],
  },
  {
    anio: 'Hoy',
    meta: ['Negocios', 'Municipios', 'Organizaciones'],
    titulo: 'Una visión completa',
    parrafos: [
      `Hoy colaboro con negocios, municipios, profesionales y organizaciones de toda la isla
       en proyectos de identidad visual, fotografía, video y desarrollo web.`,
      `La ventaja para el cliente es sencilla: una sola visión de principio a fin,
       comunicación directa y una identidad coherente en todos sus puntos de contacto.
       Sigo aprendiendo, experimentando y buscando nuevas formas de contar mejor cada
       historia.`,
    ],
  },
];

/* Dos públicos, no cuatro disciplinas: el visitante reconoce de inmediato
   si trabajo el tipo de proyecto que necesita. */
const ficha = [
  {
    cat: 'Para marcas y organizaciones',
    items: [
      'Logos e identidad visual',
      'Fotografía y video corporativo',
      'Reels y contenido para redes',
      'Diseño gráfico y materiales impresos',
      'Sitios web, tiendas y plataformas',
      'Documentales y cobertura institucional',
    ],
  },
  {
    cat: 'Para eventos y personas',
    items: [
      'Bodas y quinceañeros',
      'Eventos sociales',
      'Retratos y headshots',
      'Video de eventos',
      'Galerías digitales',
      '360 Video Booth',
    ],
  },
];
---
<Base
  title="Sobre mí — Marcos Santiago"
  description="Marcos Santiago, artista visual y desarrollador en Aibonito, Puerto Rico. Más de 20 años integrando diseño, fotografía, video y programación para negocios, municipios y organizaciones de toda la isla."
>
  <!-- Serif editorial solo para esta página: la narrativa pide otra voz tipográfica -->
  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
    rel="stylesheet"
  />

  <Nav />

  <main id="main">
    <!-- ── Apertura ── -->
    <header class="ap">
      <div class="container ap-grid">
        <div class="ap-titular">
          <p class="eyebrow">Sobre mí</p>
          <h1 class="ap-title" data-focus>Aprendiendo<br><em>a ver</em></h1>
        </div>

        <div class="ap-resto">
          <p class="ap-sub" data-focus style="--d:120ms">
            Soy Marcos Santiago, artista visual y desarrollador con base en Aibonito,
            Puerto Rico. Integro diseño, fotografía, video y programación para ayudar a
            negocios, profesionales y organizaciones a proyectarse con claridad y
            coherencia, desde el logo y el contenido hasta el sitio web.
          </p>
          <dl class="ap-ficha" data-focus style="--d:220ms">
            <div><dt>Base</dt><dd>Aibonito, Puerto Rico</dd></div>
            <div><dt>Experiencia</dt><dd>Más de 20 años</dd></div>
            <div><dt>Alcance</dt><dd>Toda Puerto Rico</dd></div>
          </dl>
        </div>

        <figure class="ap-retrato" data-focus style="--d:80ms">
          <img
            src="/marcos-photo.webp" width="1080" height="1080"
            alt="Marcos Santiago, diseñador y fotógrafo en Aibonito, Puerto Rico"
            fetchpriority="high" decoding="async"
          />
          <figcaption>Marcos Santiago · Aibonito</figcaption>
        </figure>
      </div>
    </header>

    <!-- ── Capítulos: cada uno entra fuera de foco y el scroll lo enfoca ── -->
    <section class="cronologia" aria-label="Trayectoria">
      <div class="container">
        {capitulos.map((c, i) => (
          <article class="cap" data-focus>
            <p class="cap-anio" aria-hidden="true" style="--d:90ms">{c.anio}</p>
            <div class="cap-cuerpo">
              <h2 class="cap-titulo">
                <span class="cap-anio-sr">{c.anio} — </span>{c.titulo}
              </h2>
              <p class="cap-meta">
                {c.meta.map((m, j) => (
                  <>{j > 0 && <span class="sep" aria-hidden="true">·</span>}<span>{m}</span></>
                ))}
              </p>
              <div class="cap-texto">
                {c.parrafos.map(t => <p>{t}</p>)}
              </div>
            </div>
            {i < capitulos.length - 1 && <hr class="cap-regla" />}
          </article>
        ))}
      </div>
    </section>

    <!-- ── Ficha técnica ── -->
    <section class="ficha-sec">
      <div class="container">
        <p class="eyebrow" data-focus>Servicios</p>
        <h2 class="ficha-h" data-focus style="--d:80ms">Lo que te llevas</h2>
        <div class="ficha-grid">
          {ficha.map((f, i) => (
            <div class="ficha-col" data-focus style={`--d:${100 + i * 70}ms`}>
              <h3>{f.cat}</h3>
              <ul>{f.items.map(it => <li>{it}</li>)}</ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Cierre ── -->
    <section class="cierre">
      <div class="container">
        <blockquote class="cierre-cita" data-focus>
          Una buena imagen no solamente se ve bien:<br>
          <em>comunica, se reconoce y deja una impresión.</em>
        </blockquote>

        <h2 class="cierre-h" data-focus style="--d:120ms">
          ¿Tienes un proyecto o evento en mente?
        </h2>
        <p class="cierre-texto" data-focus style="--d:180ms">
          Cuéntame qué quieres lograr. Puedo ayudarte con una necesidad específica o
          desarrollar una solución completa que combine diseño, imagen y tecnología.
        </p>
        <div class="cierre-acciones" data-focus style="--d:240ms">
          <a href="/contacto/" class="btn primary">Solicitar una cotización</a>
          <a href="/portafolio/" class="btn ghost">Ver proyectos</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <style>
  /* ═══════════════════════════════════════════════════════════════
     "Aprendiendo a ver" — la página entra fuera de foco y el scroll
     la enfoca. El efecto es la única licencia; todo lo demás calla.
     ═══════════════════════════════════════════════════════════════ */
  main {
    --serif: 'Instrument Serif', Georgia, serif;
    --rule: color-mix(in srgb, var(--white) 14%, transparent);
  }

  /* ── El enfoque ──
     El desenfoque solo existe si hay JS (la clase la pone el script).
     Sin JS, o con reduced-motion, todo nace nítido. */
  :global(html.js-focus) [data-focus] {
    filter: blur(14px);
    opacity: .18;
    transform: translateY(18px) scale(1.012);
    transition:
      filter    1.05s cubic-bezier(.16,.84,.24,1) var(--d, 0ms),
      opacity    .8s  cubic-bezier(.16,.84,.24,1) var(--d, 0ms),
      transform 1.05s cubic-bezier(.16,.84,.24,1) var(--d, 0ms);
    will-change: filter, opacity, transform;
  }
  :global(html.js-focus) [data-focus].nitido {
    filter: blur(0); opacity: 1; transform: none;
    will-change: auto;
  }

  .eyebrow {
    font-family: var(--mono); font-size: var(--text-2xs);
    letter-spacing: 3px; text-transform: uppercase; color: var(--muted);
  }

  /* ── Apertura ── */
  .ap { padding: 120px 0 96px }
  .ap-grid {
    display: grid;
    grid-template-columns: 1.35fr .65fr;
    grid-template-areas: "titular foto" "resto foto";
    column-gap: clamp(32px, 6vw, 88px); row-gap: 0;
    align-items: center;
  }
  .ap-titular { grid-area: titular }
  .ap-resto   { grid-area: resto }
  .ap-retrato { grid-area: foto }
  .ap-title {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(3.4rem, 11vw, 8.5rem);
    line-height: .88; letter-spacing: -.02em;
    color: var(--white); margin: 18px 0 0;
  }
  .ap-title em { font-style: italic; color: var(--muted) }
  .ap-sub {
    font-size: clamp(1rem, 1.5vw, 1.22rem); line-height: 1.65;
    color: var(--muted); max-width: 46ch; margin-top: 26px;
  }
  .ap-ficha {
    display: flex; flex-wrap: wrap; gap: 10px 44px; margin-top: 40px;
    padding-top: 24px; border-top: 1px solid var(--rule);
  }
  .ap-ficha dt {
    font-family: var(--mono); font-size: var(--text-2xs);
    letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
    margin-bottom: 6px;
  }
  .ap-ficha dd { font-size: var(--text-sm); color: var(--white) }

  .ap-retrato { position: relative }
  .ap-retrato img {
    width: 100%; height: auto; display: block; border-radius: 2px;
    filter: grayscale(1) contrast(1.06);
  }
  .ap-retrato figcaption {
    font-family: var(--mono); font-size: var(--text-2xs);
    letter-spacing: 1.6px; text-transform: uppercase; color: var(--muted);
    margin-top: 12px; padding-left: 1px;
  }

  /* ── Cronología ── */
  .cronologia { padding: 40px 0 20px }
  .cap { padding: clamp(56px, 8vw, 104px) 0 0 }
  .cap:first-child { padding-top: 0 }
  .cap-anio {
    font-family: var(--display);
    font-size: clamp(4.5rem, 15vw, 12rem);
    line-height: .82; letter-spacing: .06em;
    color: var(--white); opacity: .12;
    margin-bottom: .06em;
    user-select: none;
  }
  /* Izquierda: título + metadatos. Derecha: el relato, alineado al título. */
  .cap-cuerpo {
    display: grid; grid-template-columns: .92fr 1.08fr;
    column-gap: clamp(24px, 5vw, 72px); row-gap: 16px;
    align-items: start;
  }
  .cap-titulo { grid-column: 1; grid-row: 1 }
  .cap-meta   { grid-column: 1; grid-row: 2 }
  .cap-texto  { grid-column: 2; grid-row: 1 / span 2 }
  .cap-anio-sr {
    position: absolute; width: 1px; height: 1px;
    overflow: hidden; clip-path: inset(50%); white-space: nowrap;
  }
  .cap-titulo {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(1.9rem, 4.2vw, 3.2rem);
    line-height: 1.02; letter-spacing: -.01em; color: var(--white);
  }
  .cap-meta {
    font-family: var(--mono); font-size: var(--text-2xs);
    letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
  }
  .cap-meta .sep { margin: 0 10px; opacity: .55 }
  .cap-texto {
    font-size: clamp(.98rem, 1.3vw, 1.1rem); line-height: 1.78;
    color: var(--muted); max-width: 58ch;
  }
  .cap-texto p + p { margin-top: 1.15em }
  .cap-regla { border: 0; border-top: 1px solid var(--rule); margin-top: clamp(48px, 7vw, 88px) }

  /* ── Ficha técnica ── */
  .ficha-sec { padding: clamp(80px, 11vw, 140px) 0 }
  .ficha-h {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.05;
    color: var(--white); margin: 14px 0 46px;
  }
  /* Dos bloques, uno por público. Más anchos que las 4 columnas de antes
     porque cada línea es una frase, no una palabra suelta. */
  .ficha-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: clamp(28px, 5vw, 72px);
  }
  .ficha-col { border-top: 1px solid var(--rule); padding-top: 20px }
  .ficha-col h3 {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(1.15rem, 2vw, 1.5rem); line-height: 1.2;
    color: var(--white); margin-bottom: 18px;
  }
  .ficha-col ul { list-style: none }
  .ficha-col li {
    font-size: var(--text-sm); color: var(--muted);
    padding: 7px 0; border-bottom: 1px solid color-mix(in srgb, var(--white) 6%, transparent);
  }
  .ficha-col li:last-child { border-bottom: 0 }

  /* ── Cierre ── */
  .cierre { padding: 0 0 clamp(90px, 12vw, 150px); text-align: center }
  .cierre-cita {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(1.7rem, 4.6vw, 3.4rem);
    line-height: 1.16; letter-spacing: -.01em;
    color: var(--white); max-width: 34ch; margin: 0 auto;
    text-wrap: balance;
  }
  .cierre-cita em { font-style: italic; color: var(--muted) }
  .cierre-h {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(1.4rem, 3vw, 2.1rem); line-height: 1.2;
    color: var(--white); margin: clamp(48px, 7vw, 72px) auto 0; max-width: 30ch;
    text-wrap: balance;
  }
  .cierre-texto {
    font-size: var(--text-base); color: var(--muted); line-height: 1.7;
    margin: 16px auto 0; max-width: 52ch;
  }
  .cierre-acciones {
    display: flex; gap: 12px; justify-content: center;
    flex-wrap: wrap; margin-top: 32px;
  }

  /* ── Responsive ── */
  /* ── Móvil: el retrato es PORTADA a sangre completa ──
     La foto y el titular comparten la misma celda del grid, así que el título
     se apoya sobre la imagen sin posicionamiento absoluto. El nav es
     transparente hasta que hay scroll, por eso la foto puede pasar por detrás. */
  @media (max-width: 900px) {
    .ap { padding: 0 0 clamp(48px, 10vw, 72px) }
    .ap-grid {
      grid-template-columns: 1fr;
      grid-template-areas: "portada" "resto";
      padding-inline: 0;          /* el .container deja de recortar: full-bleed */
    }
    .ap-retrato { grid-area: portada; margin: 0 }
    .ap-retrato img {
      height: 78svh; min-height: 420px; width: 100%;
      object-fit: cover; object-position: 50% 22%;
      border-radius: 0;
    }
    /* Oscurecido inferior para que el titular se lea. Va a negro fijo —no a
       var(--ink)— porque la foto es oscura en los dos temas. */
    .ap-retrato::after {
      content: ''; position: absolute; inset: 0; pointer-events: none;
      background:
        linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.45) 30%, transparent 62%),
        linear-gradient(to bottom, rgba(0,0,0,.5) 0%, transparent 24%);
    }
    /* El nav flota sobre la portada. Mientras no hay scroll (umbral: 20px, muy
       por debajo del alto de la foto) sus colores se fuerzan a claros: si no,
       en tema claro quedaban oscuros sobre foto oscura y el botón de menú se
       volvía invisible. Al hacer scroll el header recupera fondo y colores. */
    :global(header:not(.scrolled)) {
      --white: #f0ede8;
      --muted: rgba(240,237,232,.75);
      --dim:   rgba(240,237,232,.55);
    }
    /* En tema claro global.css le pone fondo sólido al header SIEMPRE (con
       !important), lo que tapaba la portada. Aquí se destapa hasta que scrollea. */
    :global([data-theme="light"] header:not(.scrolled)) {
      background: transparent !important;
      border-color: transparent !important;
      backdrop-filter: none;
    }
    /* Y el logo, que en tema claro se invierte a oscuro: sobre la foto tiene
       que quedarse en su versión clara. */
    :global([data-theme="light"] header:not(.scrolled) .nav-logo-img) { filter: none }
    .ap-retrato figcaption { display: none }

    .ap-titular {
      grid-area: portada; align-self: end; z-index: 2;
      padding: 0 24px clamp(24px, 5vw, 40px);
    }
    /* Sobre la foto el texto siempre va claro, aunque el tema sea claro. */
    .ap-titular .eyebrow { color: rgba(255,255,255,.72) }
    .ap-title { color: #fff; margin-top: 10px; text-shadow: 0 2px 30px rgba(0,0,0,.5) }
    .ap-title em { color: rgba(255,255,255,.72) }

    .ap-resto { grid-area: resto; padding: clamp(28px, 6vw, 40px) 24px 0 }
    .ap-sub { margin-top: 0 }

    .ficha-grid { grid-template-columns: 1fr; gap: 36px }
  }
  @media (max-width: 600px) {
    .ap-titular, .ap-resto { padding-inline: 16px }
  }
  @media (max-width: 640px) {
    .cap-cuerpo { grid-template-columns: 1fr; row-gap: 14px }
    .cap-titulo, .cap-meta, .cap-texto { grid-column: 1; grid-row: auto }
    .cap-anio { font-size: clamp(4rem, 22vw, 7rem); margin-bottom: -.1em }
    .ficha-grid { grid-template-columns: 1fr }
    .cierre-cita { max-width: 100% }
  }

  /* ── Sin movimiento ── */
  @media (prefers-reduced-motion: reduce) {
    :global(html.js-focus) [data-focus],
    :global(html.js-focus) [data-focus].nitido {
      filter: none; opacity: 1; transform: none; transition: none;
    }
  }
  </style>

  <script>
    /* El desenfoque se activa solo si hay JS: sin él la página nace nítida
       y perfectamente legible. Con reduced-motion el CSS anula el efecto. */
    (() => {
      const targets = document.querySelectorAll('[data-focus]');
      if (!targets.length) return;

      const quieto = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (quieto) return;

      document.documentElement.classList.add('js-focus');

      const enfocar = (el) => el.classList.add('nitido');

      if (!('IntersectionObserver' in window)) {
        targets.forEach(enfocar);
        return;
      }

      const io = new IntersectionObserver((entradas) => {
        entradas.forEach((e) => {
          if (!e.isIntersecting) return;
          enfocar(e.target);
          io.unobserve(e.target);
        });
      }, { rootMargin: '0px 0px -12% 0px', threshold: 0.15 });

      targets.forEach((t) => io.observe(t));

      /* Lo que ya está en pantalla al cargar enfoca de una, sin esperar scroll. */
      requestAnimationFrame(() => {
        targets.forEach((t) => {
          if (t.getBoundingClientRect().top < window.innerHeight * 0.9) {
            enfocar(t); io.unobserve(t);
          }
        });
      });
    })();
  </script>
</Base>
