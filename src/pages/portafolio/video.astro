---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const services = [
  {
    label: 'Bodas',
    desc: 'Video cinematográfico de tu boda — desde los preparativos hasta la última pieza de baile. Film destacado + cobertura completa del día.',
  },
  {
    label: 'Quinceañeros',
    desc: 'Video profesional del gran día: vals, court, sorpresas y celebración. Un recuerdo cinematográfico para siempre.',
  },
  {
    label: 'Eventos y Conciertos',
    desc: 'Cobertura multicámara de conciertos, festivales, activaciones y celebraciones. Entrega de highlight reel y cobertura completa.',
  },
  {
    label: 'Video Corporativo',
    desc: 'Videos institucionales, lanzamientos de producto, testimoniales y contenido para entrenar equipos. Calidad profesional lista para presentaciones.',
  },
  {
    label: 'Reels y Redes Sociales',
    desc: 'Contenido vertical y horizontal para Instagram, TikTok y YouTube. Cortos, dinámicos y optimizados para cada plataforma.',
  },
  {
    label: 'Documental',
    desc: 'Historias cortas sobre personas, proyectos y cultura puertorriqueña. Entrevistas, b-roll narrativo y edición de autor.',
  },
  {
    label: 'Marcas y Publicidad',
    desc: 'Spots publicitarios, videos de producto y campañas para negocios locales. Concepto, producción y entrega final.',
  },
  {
    label: 'Color Grading y Post',
    desc: 'Solo edición y color: corrección, grading cinematográfico, sound design y entrega en el formato que necesites.',
  },
];
---
<Base
  title="Videografía — Marcos Santiago"
  description="Videografía profesional en Puerto Rico — bodas, quinceañeros, eventos, video corporativo, reels y producción audiovisual. Basado en Aibonito, PR."
>
  <Nav />
  <main style="padding-top:120px">
    <div class="container">

      <p class="section-label">Portafolio · Videografía</p>
      <h1 class="section-title">Videografía</h1>
      <p class="section-sub">
        Producción audiovisual para eventos, marcas y proyectos en Puerto Rico. Desde el concepto hasta la entrega final — con la narrativa y el cuidado visual que cada historia merece.
      </p>

      <!-- Showreel -->
      <div class="showreel-wrap">
        <video
          class="showreel-video"
          src="/short-videografy.mp4"
          autoplay muted loop playsinline
          controls
        ></video>
      </div>

      <div class="portfolio-ctas">
        <div class="portfolio-cta">
          <div class="cta-icon">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
            </svg>
          </div>
          <p class="cta-tag">Producción profesional</p>
          <h2 class="cta-title">Ver en Vimeo</h2>
          <p class="cta-sub">
            Portafolio completo de bodas, eventos, documentales y producción de marca en <strong>vimeo.com/marcosstgo</strong>.
          </p>
          <a href="https://vimeo.com/marcosstgo" target="_blank" rel="noopener" class="btn primary">
            Abrir Vimeo →
          </a>
        </div>

        <div class="portfolio-cta">
          <div class="cta-icon">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9"/>
              <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none"/>
              <line x1="12" y1="3" x2="12" y2="5"/>
              <line x1="12" y1="19" x2="12" y2="21"/>
              <line x1="3" y1="12" x2="5" y2="12"/>
              <line x1="19" y1="12" x2="21" y2="12"/>
            </svg>
          </div>
          <p class="cta-tag">Streams y contenido en vivo</p>
          <h2 class="cta-title">Archivo CORILLO</h2>
          <p class="cta-sub">
            Transmisiones pasadas y videos del canal <strong>marcos</strong> en CORILLO — plataforma de streaming independiente desde Puerto Rico.
          </p>
          <a href="https://corillo.live/vods/?ch=marcos" target="_blank" rel="noopener" class="btn primary">
            Ver transmisiones →
          </a>
        </div>
      </div>

      <div style="margin-top:80px">
        <p class="section-label">Servicios</p>
        <h2 class="section-title" style="font-size:clamp(2rem,4vw,3.2rem)">Qué produzco</h2>
      </div>

      <div class="services-grid">
        {services.map(s => (
          <div class="service-card">
            <h3 class="service-label">{s.label}</h3>
            <p class="service-desc">{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="includes-section">
        <p class="section-label">Qué incluye</p>
        <div class="includes-grid">
          {[
            'Reunión de pre-producción para entender tu visión',
            'Grabación con equipo profesional 4K',
            'Edición completa y color grading cinematográfico',
            'Sound design y música licenciada',
            'Revisiones incluidas hasta tu aprobación',
            'Entrega en múltiples formatos y resoluciones',
          ].map(item => (
            <div class="include-item">
              <span class="include-check">✓</span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="contact-cta">
        <div>
          <h2 class="cta-title">¿Tienes un proyecto?</h2>
          <p class="cta-sub">Escríbeme para disponibilidad, paquetes y cotizaciones. Disponible en toda Puerto Rico.</p>
        </div>
        <a href="https://wa.me/17872439670" target="_blank" rel="noopener" class="btn whatsapp">
          <i class="fab fa-whatsapp"></i> (787) 243-9670
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Base>

<style>
.portfolio-ctas {
  margin-top: 56px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (max-width: 720px) { .portfolio-ctas { grid-template-columns: 1fr } }
.portfolio-cta {
  display: flex; flex-direction: column;
  padding: 36px; background: var(--surface);
  border: 1px solid var(--border); border-radius: 20px;
  transition: border-color .2s, transform .2s;
}
.portfolio-cta:hover {
  border-color: color-mix(in srgb, var(--page-c) 45%, transparent);
  transform: translateY(-3px);
}
:root { --page-c: var(--page-c) }
.cta-icon { color: var(--page-c); margin-bottom: 22px }
.cta-tag {
  font-family: var(--mono); font-size: .62rem;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--page-c); margin-bottom: 10px;
}
.cta-title {
  font-family: var(--display);
  font-size: clamp(1.8rem, 3.5vw, 2.4rem);
  letter-spacing: 2px; margin-bottom: 12px;
}
.cta-sub {
  color: var(--muted); font-size: .9rem; line-height: 1.7;
  margin-bottom: 22px;
}
.cta-sub strong { color: var(--white) }
.portfolio-cta .btn { align-self: flex-start; margin-top: auto }

.services-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 12px; margin-top: 32px;
}
@media (max-width: 768px) { .services-grid { grid-template-columns: 1fr } }

.service-card {
  background: var(--surface); border: 1px solid var(--border);
  border-left: 3px solid var(--page-c);
  border-radius: 12px; padding: 28px 24px;
}
.service-label {
  font-family: var(--mono); font-size: .6rem;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--page-c); margin-bottom: 10px;
}
.service-desc { font-size: .88rem; color: var(--muted); line-height: 1.65 }

.includes-section {
  margin-top: 72px; padding-top: 56px;
  border-top: 1px solid var(--border);
}
.includes-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 16px; margin-top: 28px;
}
@media (max-width: 600px) { .includes-grid { grid-template-columns: 1fr } }
.include-item {
  display: flex; gap: 12px; align-items: flex-start;
  font-size: .9rem; color: var(--muted);
}
.include-check {
  color: var(--page-c); font-family: var(--mono);
  font-size: .75rem; flex-shrink: 0; margin-top: 2px;
}

.contact-cta {
  margin-top: 64px; padding: 48px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px;
  display: flex; align-items: center;
  justify-content: space-between; gap: 32px; flex-wrap: wrap;
}

.showreel-wrap {
  margin-top: 48px;
  border-radius: 16px; overflow: hidden;
  border: 1px solid var(--border);
  background: #000;
  aspect-ratio: 16/9;
}
.showreel-video {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
</style>
