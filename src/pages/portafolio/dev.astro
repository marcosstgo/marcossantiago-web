---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const projects = [
  {
    name: 'CORILLO',
    desc: 'Plataforma de streaming independiente para Puerto Rico. Canal grid en vivo, player HLS, chat en tiempo real, notificaciones Discord/Telegram y panel de administración.',
    href: 'https://corillo.live',
    tags: ['HTML', 'JS', 'MediaMTX', 'HLS', 'Nginx', 'Raspberry Pi'],
    year: '2024',
    status: 'live',
  },
  {
    name: 'STREAMER PRO',
    desc: 'App de escritorio para streaming RTMP multi-plataforma. Soporte NVENC, modos de captura y highlights, logo overlay, watchdog con auto-recovery y auto-update.',
    href: 'https://corillo.live/streamer-pro/',
    tags: ['C#', 'WPF', 'FFmpeg', '.NET'],
    year: '2025',
    status: 'live',
  },
  {
    name: 'ANTI-BUFFERBLOAT PRO',
    desc: 'Optimizador de red para Windows: reduce latencia y bufferbloat con perfiles Gaming/Reset, 8 acciones TCP, PC Gaming Boost y monitoreo en tiempo real.',
    href: 'https://corillo.live/antibufferbloat-pro/',
    tags: ['C#', 'WPF', 'Windows', '.NET'],
    year: '2025',
    status: 'live',
  },
];
---
<Base title="Desarrollo — Marcos Santiago">
  <Nav />
  <main style="padding-top:120px">
    <div class="container">
      <p class="section-label">Portafolio · Desarrollo</p>
      <h1 class="section-title">Proyectos</h1>
      <p class="section-sub">Plataformas web, aplicaciones de escritorio y herramientas que la gente realmente usa — desde streaming en vivo hasta optimización de redes en Windows.</p>

      <div class="projects-list">
        {projects.map(p => (
          <a href={p.href} target="_blank" rel="noopener" class="project-card">
            <div class="project-top">
              <div>
                <span class="project-year">{p.year}</span>
                {p.status === 'live' && <span class="project-live">● LIVE</span>}
              </div>
              <span class="project-arrow">↗</span>
            </div>
            <h2 class="project-name">{p.name}</h2>
            <p class="project-desc">{p.desc}</p>
            <div class="project-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>

      <div class="dev-services">
        <p class="section-label">Servicios</p>
        <h2 class="section-title" style="font-size:clamp(2rem,4vw,3.2rem)">¿Necesitas algo construido?</h2>
        <div class="dev-services-grid">
          {[
            { label: 'Sitios Web', desc: 'Sitios rápidos, responsivos y bien diseñados. HTML estático, Astro o CMS según lo que necesites.' },
            { label: 'Web Apps', desc: 'Aplicaciones web con backend, autenticación, bases de datos y APIs. Desde MVPs hasta sistemas completos.' },
            { label: 'Apps de Escritorio', desc: 'Aplicaciones Windows en C# / WPF. Integración con hardware, automatización y herramientas internas.' },
            { label: 'Herramientas y Scripts', desc: 'Automatización, scripts de servidor, bots y herramientas que te ahorran tiempo y trabajo manual.' },
          ].map(s => (
            <div class="dev-service-card">
              <h3 class="service-label">{s.label}</h3>
              <p class="service-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="contact-cta">
        <div>
          <h2 class="cta-title">¿Tienes un proyecto?</h2>
          <p class="cta-sub">Escríbeme con tu idea — te doy una evaluación honesta de alcance, tiempo y costo.</p>
        </div>
        <a href="https://wa.me/17872439670" target="_blank" rel="noopener" class="btn whatsapp">
          <i class="fab fa-whatsapp"></i> (787) 243-9670
        </a>
      </div>

      <div class="github-cta">
        <p class="section-label">Código abierto</p>
        <h2 class="github-title">Ver más en GitHub</h2>
        <p class="github-sub">Repos públicos, contribuciones y experimentos.</p>
        <a href="https://github.com/marcosstgo" target="_blank" rel="noopener" class="btn primary" style="margin-top:20px">
          github.com/marcosstgo →
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
.projects-list {
  display: grid; grid-template-columns: repeat(2,1fr);
  gap: 12px; margin-top: 56px;
}
@media (max-width: 700px) { .projects-list { grid-template-columns: 1fr } }

.project-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 16px; padding: 32px;
  display: flex; flex-direction: column; gap: 14px;
  position: relative; overflow: hidden;
  transition: border-color .2s, transform .2s;
}
.project-card:hover { border-color: color-mix(in srgb, var(--white) 20%, transparent); transform: translateY(-3px) }
.project-top { display: flex; align-items: center; justify-content: space-between }
.project-year {
  font-family: var(--mono); font-size: .5rem;
  letter-spacing: 2px; color: var(--dim);
}
:root { --page-c: var(--page-c) }
.project-live {
  font-family: var(--mono); font-size: .62rem;
  letter-spacing: 2px; color: var(--page-c); margin-left: 10px;
}
.project-arrow { font-size: 1.1rem; color: var(--muted); transition: transform .2s }
.project-card:hover .project-arrow { transform: translate(3px,-3px); color: var(--white) }
.project-name {
  font-family: var(--display);
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: 3px; color: var(--white);
}
.project-desc { font-size: .85rem; color: var(--muted); line-height: 1.7 }
.project-tags { display: flex; gap: 6px; flex-wrap: wrap }
.tag {
  font-family: var(--mono); font-size: .62rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 4px;
  background: color-mix(in srgb, var(--white) 4%, transparent); border: 1px solid var(--border);
  color: var(--muted);
}

.github-cta {
  margin-top: 80px; padding: 48px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px;
}
.github-title {
  font-family: var(--display);
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: 2px; margin-top: 8px;
}
.github-sub { color: var(--muted); font-size: .9rem; margin-top: 6px }

.dev-services { margin-top: 80px; padding-top: 64px; border-top: 1px solid var(--border) }
.dev-services-grid {
  display: grid; grid-template-columns: repeat(2,1fr);
  gap: 12px; margin-top: 32px;
}
@media (max-width: 700px) { .dev-services-grid { grid-template-columns: 1fr } }
.dev-service-card {
  background: var(--surface); border: 1px solid var(--border);
  border-left: 3px solid var(--page-c);
  border-radius: 12px; padding: 28px 24px;
}
.service-label {
  font-family: var(--mono); font-size: .6rem;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--page-c); margin-bottom: 10px;
}
.service-desc { font-size: .88rem; color: var(--muted); line-height: 1.65 }

.contact-cta {
  margin-top: 48px; padding: 48px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px;
  display: flex; align-items: center;
  justify-content: space-between; gap: 32px; flex-wrap: wrap;
}
.cta-title {
  font-family: var(--display);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  letter-spacing: 2px; margin-bottom: 8px;
}
.cta-sub { color: var(--muted); font-size: .9rem; line-height: 1.7; max-width: 48ch }
</style>
