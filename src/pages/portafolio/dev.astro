---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const featuredProjects = [
  {
    name: 'KIOSKKO',
    tagline: 'E-commerce para negocios en Puerto Rico',
    desc: 'Plataforma SaaS con tienda online, carrito, pagos con Stripe y ATH Móvil, panel admin completo y configuración sin código.',
    href: 'https://kioskko.com',
    tags: ['Astro', 'PocketBase', 'Stripe', 'ATH Móvil', 'Docker'],
    status: 'Live',
    color: '#4a6cf7',
    year: '2025',
  },
  {
    name: 'PLAKITA',
    tagline: 'Identificación QR para mascotas',
    desc: 'Plaquitas con código QR que permiten reunir mascotas perdidas con sus dueños al instante desde cualquier teléfono.',
    href: 'https://plakita.com',
    tags: ['React', 'Supabase', 'QR', 'Netlify'],
    status: 'Live',
    color: '#f97316',
    year: '2025',
  },
  {
    name: 'FLASHEALO',
    tagline: 'Fotos colaborativas para eventos',
    desc: 'Los asistentes suben y comparten sus fotos en un espacio centralizado por evento. Sin apps, sin cuentas, solo escanear y subir.',
    href: 'https://flashealo.com',
    tags: ['React', 'Supabase', 'Storage', 'QR'],
    status: 'Beta',
    color: '#a855f7',
    year: '2025',
  },
];

const otherProjects = [
  {
    name: 'CORILLO',
    desc: 'Plataforma de streaming independiente para Puerto Rico. Canal grid en vivo, player HLS, chat en tiempo real y panel de administración.',
    href: 'https://corillo.live',
    tags: ['HTML', 'JS', 'MediaMTX', 'HLS', 'Nginx'],
    year: '2024',
  },
  {
    name: 'CORILLO CSS',
    desc: 'Framework CSS dark-first creado para Corillo. Tokens de diseño, paleta boricua (cian, oro, rojo PR) y 17 componentes — sin dependencias, ~8 KB.',
    href: 'https://corillo.live/corillo-css/',
    tags: ['CSS', 'Design System', 'Framework', 'Dark-first'],
    year: '2026',
  },
  {
    name: 'STREAMER PRO',
    desc: 'App de escritorio para streaming RTMP multi-plataforma. Soporte NVENC, highlights, logo overlay, watchdog con auto-recovery y auto-update.',
    href: 'https://corillo.live/streamer-pro/',
    tags: ['C#', 'WPF', 'FFmpeg', '.NET'],
    year: '2025',
  },
  {
    name: 'STREAMER LITE',
    desc: 'Versión ligera de Streamer Pro. Pipeline ddagrab+NVENC optimizado para bajo consumo de CPU.',
    href: 'https://corillo.live',
    tags: ['C#', 'WPF', 'NVENC', 'ddagrab'],
    year: '2025',
  },
  {
    name: 'NATCHECK',
    desc: 'Diagnóstico de NAT type, MTU y puertos para gaming. 10 perfiles de juego, fix UPnP automático.',
    href: 'https://corillo.live/natcheck/',
    tags: ['C#', 'WinForms', 'STUN', 'UPnP'],
    year: '2025',
  },
  {
    name: 'ANTI-BUFFERBLOAT PRO',
    desc: 'Optimizador de red para Windows: reduce latencia y bufferbloat con perfiles Gaming/Reset y monitoreo en tiempo real.',
    href: 'https://corillo.live/antibufferbloat-pro/',
    tags: ['C#', 'WPF', 'Windows', '.NET'],
    year: '2024',
  },
];
---
<Base title="Desarrollo — Marcos Santiago">
  <Nav />
  <main style="padding-top:120px">
    <div class="container">
      <p class="section-label">Portafolio · Desarrollo</p>
      <h1 class="section-title">Proyectos</h1>
      <p class="section-sub">Plataformas web, aplicaciones de escritorio y herramientas que la gente realmente usa — desde streaming en vivo hasta optimización de redes en Windows.</p>

      <div class="featured-grid">
        {featuredProjects.map(p => (
          <a href={p.href} target="_blank" rel="noopener" class="featured-card" style={`--c:${p.color}`}>
            <div class="featured-top">
              <div class="featured-meta">
                <span class="featured-year">{p.year}</span>
                <span class:list={['featured-status', p.status.toLowerCase()]}>{p.status}</span>
              </div>
              <span class="featured-arrow">↗</span>
            </div>
            <h2 class="featured-name">{p.name}</h2>
            <p class="featured-tagline">{p.tagline}</p>
            <p class="featured-desc">{p.desc}</p>
            <div class="dev-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>

      <p class="other-label">Más proyectos</p>
      <div class="dev-list">
        {otherProjects.map(p => (
          <a href={p.href} target="_blank" rel="noopener" class="dev-row">
            <div>
              <div class="dev-row-top">
                <span class="dev-name">{p.name}</span>
                <span class="dev-year">{p.year}</span>
              </div>
              <div class="dev-desc">{p.desc}</div>
              <div class="dev-tags">
                {p.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
            <span class="dev-arrow">↗</span>
          </a>
        ))}
      </div>

      <div class="dev-services">
        <p class="section-label">Servicios</p>
        <h2 class="section-title" style="font-size:clamp(2rem,4vw,3.2rem)">¿Necesitas algo construido?</h2>
        <div class="dev-services-grid">
          {[
            { label: 'Sitios Web', desc: 'Sitios rápidos, responsivos y bien diseñados. HTML estático, Astro o CMS según lo que necesites.' },
            { label: 'Web Apps', desc: 'Aplicaciones web con backend, autenticación, bases de datos y APIs. Desde MVPs hasta sistemas completos.' },
            { label: 'Apps de Escritorio', desc: 'Aplicaciones Windows en C# / WPF. Integración con hardware, automatización y herramientas internas.' },
            { label: 'Herramientas y Scripts', desc: 'Automatización, scripts de servidor, bots y herramientas que te ahorran tiempo y trabajo manual.' },
          ].map(s => (
            <div class="dev-service-card">
              <h3 class="service-label">{s.label}</h3>
              <p class="service-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="contact-cta">
        <div>
          <h2 class="cta-title">¿Tienes un proyecto?</h2>
          <p class="cta-sub">Escríbeme con tu idea — te doy una evaluación honesta de alcance, tiempo y costo.</p>
        </div>
        <a href="https://wa.me/17872439670" target="_blank" rel="noopener" class="btn whatsapp">
          <i class="fab fa-whatsapp"></i> (787) 243-9670
        </a>
      </div>

      <div class="github-cta">
        <p class="section-label">Código abierto</p>
        <h2 class="github-title">Ver más en GitHub</h2>
        <p class="github-sub">Repos públicos, contribuciones y experimentos.</p>
        <a href="https://github.com/marcosstgo" target="_blank" rel="noopener" class="btn primary" style="margin-top:20px">
          github.com/marcosstgo →
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
/* Featured cards */
.featured-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 16px; margin-top: 56px; margin-bottom: 48px;
}
@media (max-width: 900px) { .featured-grid { grid-template-columns: 1fr } }

.featured-card {
  display: flex; flex-direction: column;
  background: color-mix(in srgb, var(--c) 6%, var(--surface));
  border: 1px solid color-mix(in srgb, var(--c) 20%, var(--border));
  border-top: 3px solid var(--c);
  border-radius: 14px; padding: 24px;
  transition: transform .2s, box-shadow .2s;
}
.featured-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px color-mix(in srgb, var(--c) 15%, transparent);
}
.featured-top {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 20px;
}
.featured-meta { display: flex; align-items: center; gap: 8px }
.featured-year {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; color: var(--dim);
}
.featured-status {
  font-family: var(--mono); font-size: .68rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 2px 7px; border-radius: 20px;
}
.featured-status.live {
  background: color-mix(in srgb, #4ade80 12%, transparent);
  border: 1px solid color-mix(in srgb, #4ade80 30%, transparent);
  color: #4ade80;
}
.featured-status.beta {
  background: color-mix(in srgb, #facc15 10%, transparent);
  border: 1px solid color-mix(in srgb, #facc15 30%, transparent);
  color: #facc15;
}
.featured-arrow { font-size: 1.1rem; color: var(--muted); transition: color .2s }
.featured-card:hover .featured-arrow { color: var(--c) }
.featured-name {
  font-family: var(--display);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  letter-spacing: 2px; color: var(--white); margin-bottom: 4px;
}
.featured-tagline {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--c); margin-bottom: 12px;
}
.featured-desc {
  font-size: var(--text-base); color: var(--muted); line-height: 1.6;
  flex: 1; margin-bottom: 16px;
}

/* Other projects */
.other-label {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--dim); margin-bottom: 8px;
}
.dev-list { display: flex; flex-direction: column }
.dev-row {
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 16px; padding: 20px 0;
  border-bottom: 1px solid var(--border);
  transition: .2s;
}
.dev-row:first-child { border-top: 1px solid var(--border) }
.dev-row-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 4px }
.dev-name {
  font-family: var(--display);
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  letter-spacing: 2px; color: var(--white); transition: color .2s;
}
.dev-row:hover .dev-name { color: var(--accent) }
.dev-year {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; color: var(--dim);
}
.dev-desc { font-size: var(--text-base); color: var(--muted); line-height: 1.5; margin-bottom: 8px }
.dev-arrow { font-size: 1rem; color: var(--muted); padding-top: 4px; flex-shrink: 0; transition: transform .2s, color .2s }
.dev-row:hover .dev-arrow { transform: translate(3px,-3px); color: var(--white) }

.dev-tags { display: flex; flex-wrap: wrap; gap: 6px }
.tag {
  font-family: var(--mono); font-size: .68rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 2px 7px; border-radius: 4px;
  background: color-mix(in srgb, var(--white) 4%, transparent);
  border: 1px solid var(--border); color: var(--dim);
}

.github-cta {
  margin-top: 80px; padding: 48px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px;
}
.github-title {
  font-family: var(--display);
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: 2px; margin-top: 8px;
}
.github-sub { color: var(--muted); font-size: var(--text-base); margin-top: 6px }

.dev-services { margin-top: 80px; padding-top: 64px; border-top: 1px solid var(--border) }
.dev-services-grid {
  display: grid; grid-template-columns: repeat(2,1fr);
  gap: 12px; margin-top: 32px;
}
@media (max-width: 700px) { .dev-services-grid { grid-template-columns: 1fr } }
.dev-service-card {
  background: var(--surface); border: 1px solid var(--border);
  border-left: 3px solid var(--page-c);
  border-radius: 12px; padding: 28px 24px;
}
.service-label {
  font-family: var(--mono); font-size: var(--text-xs);
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--page-c); margin-bottom: 10px;
}
.service-desc { font-size: .88rem; color: var(--muted); line-height: 1.65 }

.contact-cta {
  margin-top: 48px; padding: 48px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px;
  display: flex; align-items: center;
  justify-content: space-between; gap: 32px; flex-wrap: wrap;
}
.cta-title {
  font-family: var(--display);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  letter-spacing: 2px; margin-bottom: 8px;
}
.cta-sub { color: var(--muted); font-size: var(--text-base); line-height: 1.7; max-width: 48ch }
</style>
