---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const areas = [
  { label: 'Diseño Gráfico', href: '/portafolio/diseno/', color: '#e8c84a', count: 'Behance →' },
  { label: 'Fotografía',     href: '/portafolio/foto/',   color: '#a0c4ff', count: 'Gallery →' },
  { label: 'Videografía',    href: '/portafolio/video/',  color: '#ff9f7f', count: 'Vimeo →' },
  { label: 'Desarrollo',     href: '/portafolio/dev/',    color: '#88e0b0', count: 'GitHub →' },
];

const featuredProjects = [
  {
    name: 'KIOSKKO',
    tagline: 'E-commerce para negocios en Puerto Rico',
    desc: 'Plataforma SaaS con tienda online, carrito, pagos con Stripe y ATH Móvil, panel admin completo y configuración sin código.',
    href: 'https://kioskko.com',
    tags: ['Astro', 'PocketBase', 'Stripe', 'ATH Móvil', 'Docker'],
    status: 'Live',
    color: '#4a6cf7',
    year: '2025',
  },
  {
    name: 'PLAKITA',
    tagline: 'Identificación QR para mascotas',
    desc: 'Plaquitas con código QR que permiten reunir mascotas perdidas con sus dueños al instante desde cualquier teléfono.',
    href: 'https://plakita.com',
    tags: ['React', 'Supabase', 'QR', 'Netlify'],
    status: 'Live',
    color: '#f97316',
    year: '2025',
  },
  {
    name: 'FLASHEALO',
    tagline: 'Fotos colaborativas para eventos',
    desc: 'Los asistentes suben y comparten sus fotos en un espacio centralizado por evento. Sin apps, sin cuentas, solo escanear y subir.',
    href: 'https://flashealo.com',
    tags: ['React', 'Supabase', 'Storage', 'QR'],
    status: 'Beta',
    color: '#a855f7',
    year: '2025',
  },
];

const otherProjects = [
  {
    name: 'CORILLO',
    desc: 'Plataforma de streaming en vivo independiente para Puerto Rico.',
    href: 'https://corillo.live',
    tags: ['HTML', 'JS', 'MediaMTX', 'HLS'],
    year: '2026',
  },
  {
    name: 'STREAMER PRO',
    desc: 'App de escritorio para streaming RTMP multi-plataforma con FFmpeg.',
    href: 'https://corillo.live/streamer-pro/',
    tags: ['C#', 'WPF', 'FFmpeg'],
    year: '2024',
  },
  {
    name: 'STREAMER LITE',
    desc: 'Versión ligera de Streamer Pro. Pipeline ddagrab+NVENC optimizado para bajo consumo de CPU.',
    href: 'https://corillo.live',
    tags: ['C#', 'WPF', 'NVENC', 'ddagrab'],
    year: '2025',
  },
  {
    name: 'NATCHECK',
    desc: 'Diagnóstico de NAT type, MTU y puertos para gaming. 10 perfiles de juego, fix UPnP automático.',
    href: 'https://corillo.live/natcheck/',
    tags: ['C#', 'WinForms', 'STUN', 'UPnP'],
    year: '2025',
  },
  {
    name: 'ANTI-BUFFERBLOAT PRO',
    desc: 'Optimizador de red para Windows: reduce latencia y bufferbloat en tiempo real.',
    href: 'https://corillo.live/antibufferbloat-pro/',
    tags: ['C#', 'WPF', 'Windows'],
    year: '2024',
  },
];
---
<Base title="Portafolio — Marcos Santiago">
  <Nav />
  <main style="padding-top:120px">
    <div class="container">
      <p class="section-label">Trabajo</p>
      <h1 class="section-title">Portafolio</h1>
      <p class="section-sub">Selecciona un área para explorar el trabajo.</p>

      <div class="areas-grid">
        {areas.map(a => (
          <a href={a.href} class="area-card" style={`--c:${a.color}`}>
            <span class="area-count">{a.count}</span>
            <h2 class="area-label">{a.label}</h2>
            <div class="area-bar"></div>
          </a>
        ))}
      </div>

      <!-- Dev projects -->
      <div class="dev-section">
        <div class="dev-section-header">
          <p class="section-label">Desarrollo</p>
          <a href="/portafolio/dev/" class="dev-section-link">Ver todos →</a>
        </div>

        <div class="featured-grid">
          {featuredProjects.map(p => (
            <a href={p.href} target="_blank" rel="noopener" class="featured-card" style={`--c:${p.color}`}>
              <div class="featured-top">
                <div class="featured-meta">
                  <span class="featured-year">{p.year}</span>
                  <span class:list={['featured-status', p.status.toLowerCase()]}>{p.status}</span>
                </div>
                <span class="featured-arrow">↗</span>
              </div>
              <h3 class="featured-name">{p.name}</h3>
              <p class="featured-tagline">{p.tagline}</p>
              <p class="featured-desc">{p.desc}</p>
              <div class="dev-tags">
                {p.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </a>
          ))}
        </div>

        <p class="other-label">Más proyectos</p>
        <div class="dev-list">
          {otherProjects.map(p => (
            <a href={p.href} target="_blank" rel="noopener" class="dev-row">
              <div>
                <div class="dev-row-top">
                  <span class="dev-name">{p.name}</span>
                  <span class="dev-year">{p.year}</span>
                </div>
                <div class="dev-desc">{p.desc}</div>
                <div class="dev-tags">
                  {p.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
              <span class="dev-arrow">↗</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </main>
  <Footer />
</Base>

<style>
/* ── Dev section ── */
.dev-section { margin-top: 80px }
.dev-section-header {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 32px;
}
.dev-section-link {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); transition: color .15s;
}
.dev-section-link:hover { color: var(--white) }

/* Featured cards */
.featured-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 16px; margin-bottom: 48px;
}
@media (max-width: 900px) { .featured-grid { grid-template-columns: 1fr } }

.featured-card {
  display: flex; flex-direction: column;
  background: color-mix(in srgb, var(--c) 6%, var(--surface));
  border: 1px solid color-mix(in srgb, var(--c) 20%, var(--border));
  border-top: 3px solid var(--c);
  border-radius: 14px; padding: 24px;
  transition: transform .2s, box-shadow .2s;
}
.featured-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px color-mix(in srgb, var(--c) 15%, transparent);
}
.featured-top {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 20px;
}
.featured-meta { display: flex; align-items: center; gap: 8px }
.featured-year {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; color: var(--dim);
}
.featured-status {
  font-family: var(--mono); font-size: .68rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 2px 7px; border-radius: 20px;
}
.featured-status.live {
  background: color-mix(in srgb, #4ade80 12%, transparent);
  border: 1px solid color-mix(in srgb, #4ade80 30%, transparent);
  color: #4ade80;
}
.featured-status.beta {
  background: color-mix(in srgb, #facc15 10%, transparent);
  border: 1px solid color-mix(in srgb, #facc15 30%, transparent);
  color: #facc15;
}
.featured-arrow { font-size: 1.1rem; color: var(--muted); transition: color .2s }
.featured-card:hover .featured-arrow { color: var(--c) }
.featured-name {
  font-family: var(--display);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  letter-spacing: 2px; color: var(--white);
  margin-bottom: 4px;
}
.featured-tagline {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--c); margin-bottom: 12px;
}
.featured-desc {
  font-size: var(--text-base); color: var(--muted); line-height: 1.6;
  flex: 1; margin-bottom: 16px;
}
.dev-tags { display: flex; flex-wrap: wrap; gap: 6px }
.tag {
  font-family: var(--mono); font-size: .68rem;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 2px 7px; border-radius: 4px;
  background: color-mix(in srgb, var(--white) 4%, transparent);
  border: 1px solid var(--border); color: var(--dim);
}

/* Other projects list */
.other-label {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--dim); margin-bottom: 8px;
}
.dev-list { display: flex; flex-direction: column }
.dev-row {
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 16px; padding: 20px 0;
  border-bottom: 1px solid var(--border);
  transition: .2s;
}
.dev-row:first-child { border-top: 1px solid var(--border) }
.dev-row-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 4px }
.dev-name {
  font-family: var(--display);
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  letter-spacing: 2px; color: var(--white);
  transition: color .2s;
}
.dev-row:hover .dev-name { color: var(--accent) }
.dev-year {
  font-family: var(--mono); font-size: var(--text-2xs);
  letter-spacing: 1.5px; color: var(--dim);
}
.dev-desc { font-size: var(--text-base); color: var(--muted); line-height: 1.5; margin-bottom: 8px }
.dev-arrow { font-size: 1rem; color: var(--muted); padding-top: 4px; flex-shrink: 0; transition: transform .2s, color .2s }
.dev-row:hover .dev-arrow { transform: translate(3px,-3px); color: var(--white) }

/* ── Areas grid ── */
.areas-grid {
  display: grid; grid-template-columns: repeat(2,1fr);
  gap: 12px; margin-top: 56px;
}
@media (max-width: 600px) { .areas-grid { grid-template-columns: 1fr } }

.area-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 16px; padding: 40px 32px;
  display: flex; flex-direction: column; gap: 12px;
  position: relative; overflow: hidden;
  transition: border-color .2s, transform .2s;
}
.area-card:hover { border-color: color-mix(in srgb, var(--white) 20%, transparent); transform: translateY(-3px) }
.area-card:hover .area-bar { transform: scaleX(1) }
.area-count {
  font-family: var(--mono); font-size: .65rem;
  letter-spacing: 2px; text-transform: uppercase; color: var(--c);
}
.area-label {
  font-family: var(--display);
  font-size: clamp(2rem, 4vw, 3.2rem);
  letter-spacing: 2px; color: var(--white);
}
.area-bar {
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: var(--c); transform: scaleX(0);
  transform-origin: left; transition: transform .3s ease;
}
</style>
