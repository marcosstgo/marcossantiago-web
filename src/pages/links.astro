---
// Standalone bio page — no nav, no footer
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Marcos Santiago</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      background: #000;
      overflow: hidden;
      font-family: 'Space Mono', monospace;
      color: #fff;
    }

    /* ── Intro overlay ── */
    #intro {
      position: fixed; inset: 0; z-index: 200;
      display: flex; align-items: center; justify-content: center;
      background: #000;
      cursor: pointer;
      transition: opacity 0.7s ease;
    }
    #intro.out { opacity: 0; pointer-events: none; }
    .intro-text {
      font-size: clamp(1.4rem, 5vw, 2.8rem);
      font-weight: 400;
      letter-spacing: 6px;
      color: rgba(255,255,255,0.7);
      animation: intro-pulse 2.2s ease-in-out infinite;
    }
    @keyframes intro-pulse {
      0%, 100% { opacity: 0.3; }
      50%       { opacity: 1; }
    }

    /* ── Page ── */
    #page {
      position: fixed; inset: 0; z-index: 1;
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
      overflow-y: auto;
    }
    .video-bg {
      position: fixed; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.28) saturate(1.3);
      z-index: 0;
    }
    .video-overlay {
      position: fixed; inset: 0; z-index: 1;
      background: linear-gradient(to bottom,
        rgba(0,0,0,0.55) 0%,
        rgba(0,0,0,0.15) 50%,
        rgba(0,0,0,0.65) 100%);
    }

    /* ── Card ── */
    #card {
      position: relative; z-index: 10;
      display: flex; flex-direction: column; align-items: center;
      gap: 16px;
      padding: 44px 32px;
      width: 100%; max-width: 400px;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 22px;
      background: rgba(0,0,0,0);
      transform-style: preserve-3d;
      opacity: 0;
      margin: auto;
    }
    #card.visible {
      animation: card-unfold 0.75s cubic-bezier(.16,1,.3,1) forwards;
    }
    @keyframes card-unfold {
      from { opacity: 0; transform: scaleY(0.5) translateY(50px); filter: blur(10px); }
      to   { opacity: 1; transform: scaleY(1)   translateY(0);    filter: blur(0); }
    }

    /* ── Avatar ── */
    .avatar-ring {
      width: 116px; height: 116px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.18);
      box-shadow: 0 0 40px rgba(255,255,255,0.12), 0 0 80px rgba(255,255,255,0.05);
      overflow: hidden;
      flex-shrink: 0;
    }
    .avatar-ring img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      display: block;
    }

    /* ── Name ── */
    .name {
      font-size: clamp(1.3rem, 5vw, 1.75rem);
      font-weight: 400;
      letter-spacing: 4px;
      text-align: center;
      text-shadow:
        0 0 20px rgba(255,255,255,0.6),
        0 0 60px rgba(255,255,255,0.2);
      min-height: 1.5em;
    }
    .cursor {
      display: inline-block;
      width: 2px; height: 1.1em;
      background: #fff;
      vertical-align: middle;
      margin-left: 3px;
      animation: blink 1s step-end infinite;
    }
    .cursor.hidden { display: none; }
    @keyframes blink { 50% { opacity: 0; } }

    /* ── Tagline ── */
    .tagline {
      font-size: 0.6rem;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.58);
      text-align: center;
    }

    /* ── Description ── */
    .desc {
      font-size: 0.7rem;
      letter-spacing: 0.5px;
      color: rgba(255,255,255,0.5);
      text-align: center;
      line-height: 1.7;
      max-width: 28ch;
    }

    /* ── Location ── */
    .location {
      font-size: 0.58rem;
      letter-spacing: 2px;
      color: rgba(255,255,255,0.42);
      display: flex; align-items: center; gap: 7px;
    }

    /* ── Divider ── */
    .divider {
      width: 100%;
      height: 1px;
      background: rgba(255,255,255,0.08);
    }

    /* ── CTA WhatsApp principal ── */
    .cta-wa {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      width: 100%;
      padding: 17px 24px;
      border-radius: 14px;
      background: rgba(34, 197, 94, 0.12);
      border: 1px solid rgba(34, 197, 94, 0.28);
      color: #4ade80;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      text-decoration: none;
      filter: drop-shadow(0 0 8px rgba(34, 197, 94, 0.18));
      transition: transform 0.2s ease, filter 0.2s ease,
                  background 0.2s ease, border-color 0.2s ease;
    }
    .cta-wa i { font-size: 1.1rem; }
    .cta-wa:hover {
      transform: translateY(-3px);
      background: rgba(34, 197, 94, 0.2);
      border-color: rgba(34, 197, 94, 0.5);
      filter: drop-shadow(0 0 22px rgba(34, 197, 94, 0.45));
    }
    .cta-wa:active { transform: translateY(-1px); }

    /* ── Social grid 2×2 con labels ── */
    .socials {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      width: 100%;
    }
    .soc {
      border-radius: 14px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 8px;
      padding: 20px 12px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      color: #fff;
      font-size: 1.25rem;
      text-decoration: none;
      filter: drop-shadow(0 0 4px rgba(255,255,255,0.15));
      transition: transform 0.2s ease, filter 0.2s ease,
                  background 0.2s ease, border-color 0.2s ease;
    }
    .soc span {
      font-size: 0.55rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      transition: color 0.2s ease;
    }
    .soc:hover {
      transform: translateY(-4px);
      background: rgba(255,255,255,0.1);
      border-color: rgba(255,255,255,0.2);
      filter: drop-shadow(0 0 18px rgba(255,255,255,0.6));
    }
    .soc:hover span { color: rgba(255,255,255,0.85); }
    .soc:active { transform: translateY(-1px); }

    /* ── Footer label ── */
    .page-label {
      font-size: 0.54rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.15);
    }

    /* ── Music bar ── */
    .music-bar {
      display: flex; align-items: center; gap: 10px;
      width: 100%;
      padding: 12px 16px;
      border-radius: 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      cursor: pointer;
      transition: background 0.2s ease, border-color 0.2s ease;
      user-select: none;
    }
    .music-bar:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.14);
    }
    .music-btn {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.15);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      color: rgba(255,255,255,0.7);
      font-size: 0.7rem;
      transition: background 0.2s ease;
    }
    .music-bar:hover .music-btn { background: rgba(255,255,255,0.18); }
    .music-info {
      flex: 1;
      min-width: 0;
    }
    .music-title {
      font-size: 0.58rem;
      letter-spacing: 1.5px;
      color: rgba(255,255,255,0.55);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      text-transform: uppercase;
    }
    /* Equalizer bars */
    .eq {
      display: flex; align-items: flex-end; gap: 2px;
      height: 14px; flex-shrink: 0;
    }
    .eq span {
      display: block;
      width: 3px;
      border-radius: 2px;
      background: rgba(255,255,255,0.35);
      transform-origin: bottom;
    }
    .eq span:nth-child(1) { height: 40%; }
    .eq span:nth-child(2) { height: 80%; }
    .eq span:nth-child(3) { height: 55%; }
    .eq span:nth-child(4) { height: 90%; }
    .eq.playing span:nth-child(1) { animation: eq1 0.9s ease-in-out infinite alternate; }
    .eq.playing span:nth-child(2) { animation: eq2 0.7s ease-in-out infinite alternate; }
    .eq.playing span:nth-child(3) { animation: eq3 1.1s ease-in-out infinite alternate; }
    .eq.playing span:nth-child(4) { animation: eq4 0.8s ease-in-out infinite alternate; }
    @keyframes eq1 { from { height: 20%; } to { height: 75%; } }
    @keyframes eq2 { from { height: 60%; } to { height: 100%; } }
    @keyframes eq3 { from { height: 30%; } to { height: 80%; } }
    @keyframes eq4 { from { height: 70%; } to { height: 40%; } }

    /* ── Particles canvas ── */
    #particles {
      position: fixed; inset: 0;
      pointer-events: none; z-index: 150;
    }

    /* Touch: disable parallax */
    @media (hover: none) {
      #card { transition: none !important; }
    }

    /* Scroll en mobile si el card es más alto que la pantalla */
    @media (max-height: 700px) {
      #page { align-items: flex-start; padding: 16px; }
      #card { margin: 16px auto; }
    }
  </style>
</head>
<body>

  <!-- Intro -->
  <div id="intro" role="button" aria-label="Entrar">
    <span class="intro-text">click...</span>
  </div>

  <!-- Page -->
  <div id="page">
    <video class="video-bg" id="videoBg" muted loop playsinline preload="none">
      <source src="/short-videografy.mp4" type="video/mp4" />
    </video>
    <div class="video-overlay"></div>

    <div id="card">
      <div class="avatar-ring">
        <img src="/marcos-photo.webp" alt="Marcos Santiago" loading="eager" />
      </div>

      <h1 class="name" id="nameEl"><span class="cursor" id="cursor"></span></h1>

      <p class="tagline">Fotógrafo · Videógrafo · Diseñador</p>
      <p class="desc">Disponible para tu próximo proyecto.</p>
      <p class="location"><i class="fa-solid fa-location-dot"></i> Aibonito, Puerto Rico</p>

      <div class="divider"></div>

      <a class="cta-wa"
         href="https://wa.me/17872439670?text=Hola%2C+me+interesa+cotizar+un+proyecto."
         target="_blank" rel="noopener">
        <i class="fab fa-whatsapp"></i> Cotiza tu proyecto
      </a>

      <div class="socials">
        <a class="soc" href="https://marcossantiago.com/servicios/"
           aria-label="Servicios">
          <i class="fa-solid fa-camera"></i>
          <span>Servicios</span>
        </a>
        <a class="soc" href="https://instagram.com/marcosstgo"
           target="_blank" rel="noopener" aria-label="Instagram">
          <i class="fab fa-instagram"></i>
          <span>Instagram</span>
        </a>
        <a class="soc" href="https://youtube.com/marcosstgo"
           target="_blank" rel="noopener" aria-label="YouTube">
          <i class="fab fa-youtube"></i>
          <span>YouTube</span>
        </a>
        <a class="soc" href="/portafolio/" aria-label="Portafolio">
          <i class="fa-solid fa-briefcase"></i>
          <span>Portafolio</span>
        </a>
      </div>

      <div class="music-bar" id="musicBar" role="button" aria-label="Reproducir música">
        <div class="music-btn" id="musicBtn">
          <i class="fa-solid fa-play" id="musicIcon"></i>
        </div>
        <div class="music-info">
          <div class="music-title" id="musicTitle">ambient · en pausa</div>
        </div>
        <div class="eq" id="eq">
          <span></span><span></span><span></span><span></span>
        </div>
      </div>

      <p class="page-label">marcossantiago.com</p>
    </div>
  </div>

  <!-- Audio -->
  <audio id="bgAudio" loop preload="none">
    <!-- Cambia este src por tu track: copia el mp3 a /public/ambient.mp3 -->
    <source src="/ambient.mp3" type="audio/mpeg" />
  </audio>

  <!-- Particles -->
  <canvas id="particles"></canvas>

  <script is:inline>
  (function () {
    const intro    = document.getElementById('intro');
    const card     = document.getElementById('card');
    const nameEl   = document.getElementById('nameEl');
    const cursor   = document.getElementById('cursor');
    const videoBg  = document.getElementById('videoBg');
    const bgAudio  = document.getElementById('bgAudio');
    const musicBar = document.getElementById('musicBar');
    const musicBtn = document.getElementById('musicBtn');
    const musicIcon = document.getElementById('musicIcon');
    const musicTitle = document.getElementById('musicTitle');
    const eq       = document.getElementById('eq');

    let audioReady = false;
    let playing    = false;

    function setPlaying(state) {
      playing = state;
      musicIcon.className = state ? 'fa-solid fa-pause' : 'fa-solid fa-play';
      musicTitle.textContent = state ? 'ambient · reproduciendo' : 'ambient · en pausa';
      eq.classList.toggle('playing', state);
    }

    bgAudio.addEventListener('canplaythrough', () => { audioReady = true; });
    bgAudio.addEventListener('error', () => {
      musicBar.style.display = 'none'; // oculta si no hay archivo
    });

    musicBar.addEventListener('click', () => {
      if (bgAudio.paused) {
        bgAudio.play().then(() => setPlaying(true)).catch(() => {});
      } else {
        bgAudio.pause();
        setPlaying(false);
      }
    });

    /* ── Intro dismiss + lazy video + audio ── */
    function dismiss() {
      intro.classList.add('out');
      card.classList.add('visible');
      videoBg.load();
      videoBg.play().catch(() => {});
      bgAudio.load();
      bgAudio.volume = 0.4;
      bgAudio.play().then(() => setPlaying(true)).catch(() => {});
      setTimeout(startTypewriter, 400);
    }
    intro.addEventListener('click',      dismiss);
    intro.addEventListener('touchstart', dismiss, { passive: true });

    /* ── Typewriter ── */
    function startTypewriter() {
      const text = 'Marcos Santiago';
      let i = 0;
      nameEl.textContent = '';
      nameEl.appendChild(cursor);
      function tick() {
        nameEl.insertBefore(document.createTextNode(text[i++]), cursor);
        if (i < text.length) setTimeout(tick, 72);
        else setTimeout(() => cursor.classList.add('hidden'), 800);
      }
      tick();
    }

    /* ── Parallax 3D ── */
    let tx = 0, ty = 0, cx = 0, cy = 0;
    const hasHover = window.matchMedia('(hover: hover)').matches;

    if (hasHover) {
      document.addEventListener('mousemove', (e) => {
        const { innerWidth: w, innerHeight: h } = window;
        tx = (e.clientX / w - 0.5) * 16;
        ty = (e.clientY / h - 0.5) * -16;
      });
      document.addEventListener('mouseleave', () => { tx = 0; ty = 0; });

      (function parallaxLoop() {
        cx += (tx - cx) * 0.07;
        cy += (ty - cy) * 0.07;
        card.style.transform =
          `perspective(900px) rotateY(${cx}deg) rotateX(${cy}deg)`;
        requestAnimationFrame(parallaxLoop);
      })();
    }

    /* ── Particles cursor ── */
    const canvas = document.getElementById('particles');
    const ctx    = canvas.getContext('2d');
    const pts    = [];

    function resize() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    if (hasHover) {
      document.addEventListener('mousemove', (e) => {
        for (let i = 0; i < 4; i++) {
          pts.push({
            x: e.clientX, y: e.clientY,
            vx: (Math.random() - 0.5) * 2.8,
            vy: (Math.random() - 0.5) * 2.8 - 0.6,
            r: Math.random() * 2.2 + 0.8,
            life: 1,
          });
        }
      });
    }

    (function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = pts.length - 1; i >= 0; i--) {
        const p = pts[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.07;
        p.life -= 0.026;
        if (p.life <= 0) { pts.splice(i, 1); continue; }
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * p.life, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${p.life * 0.5})`;
        ctx.fill();
      }
      requestAnimationFrame(draw);
    })();
  })();
  </script>

</body>
</html>
