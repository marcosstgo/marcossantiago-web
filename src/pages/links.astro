---
// Standalone bio page — no nav, no footer
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Marcos Santiago</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      background: #000;
      overflow: hidden;
      font-family: 'Space Mono', monospace;
      color: #fff;
    }

    /* ── Intro overlay ── */
    #intro {
      position: fixed; inset: 0; z-index: 200;
      display: flex; align-items: center; justify-content: center;
      background: #000;
      cursor: pointer;
      transition: opacity 0.7s ease;
    }
    #intro.out { opacity: 0; pointer-events: none; }
    .intro-text {
      font-size: clamp(1.4rem, 5vw, 2.8rem);
      font-weight: 400;
      letter-spacing: 6px;
      color: rgba(255,255,255,0.7);
      animation: intro-pulse 2.2s ease-in-out infinite;
    }
    @keyframes intro-pulse {
      0%, 100% { opacity: 0.3; }
      50%       { opacity: 1; }
    }

    /* ── Page ── */
    #page {
      position: fixed; inset: 0; z-index: 1;
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }
    .video-bg {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.28) saturate(1.3);
      z-index: 0;
    }
    .video-overlay {
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(to bottom,
        rgba(0,0,0,0.55) 0%,
        rgba(0,0,0,0.15) 50%,
        rgba(0,0,0,0.65) 100%);
    }

    /* ── Card ── */
    #card {
      position: relative; z-index: 10;
      display: flex; flex-direction: column; align-items: center;
      gap: 16px;
      padding: 44px 36px;
      width: 100%; max-width: 400px;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 20px;
      background: rgba(0,0,0,0);
      transform-style: preserve-3d;
      opacity: 0;
    }
    #card.visible {
      animation: card-unfold 0.75s cubic-bezier(.16,1,.3,1) forwards;
    }
    @keyframes card-unfold {
      from { opacity: 0; transform: scaleY(0.5) translateY(50px); filter: blur(10px); }
      to   { opacity: 1; transform: scaleY(1)   translateY(0);    filter: blur(0); }
    }

    /* ── Avatar ── */
    .avatar-ring {
      width: 96px; height: 96px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 0 32px rgba(255,255,255,0.1);
      overflow: hidden;
      flex-shrink: 0;
    }
    .avatar-ring img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      display: block;
    }

    /* ── Name ── */
    .name {
      font-size: clamp(1.3rem, 5vw, 1.75rem);
      font-weight: 400;
      letter-spacing: 4px;
      text-align: center;
      text-shadow: 0 0 20px rgba(255,255,255,0.35);
      min-height: 1.5em;
    }
    .cursor {
      display: inline-block;
      width: 2px; height: 1.1em;
      background: #fff;
      vertical-align: middle;
      margin-left: 3px;
      animation: blink 1s step-end infinite;
    }
    .cursor.hidden { display: none; }
    @keyframes blink { 50% { opacity: 0; } }

    /* ── Tagline ── */
    .tagline {
      font-size: 0.6rem;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      text-align: center;
    }

    /* ── Location ── */
    .location {
      font-size: 0.6rem;
      letter-spacing: 2px;
      color: rgba(255,255,255,0.28);
      display: flex; align-items: center; gap: 7px;
    }

    /* ── Divider ── */
    .divider {
      width: 100%;
      height: 1px;
      background: rgba(255,255,255,0.08);
    }

    /* ── Socials ── */
    .socials {
      display: flex; gap: 14px;
      flex-wrap: wrap; justify-content: center;
    }
    .soc {
      width: 54px; height: 54px;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      color: #fff;
      font-size: 1.2rem;
      text-decoration: none;
      filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));
      transition: transform 0.2s ease, filter 0.2s ease,
                  background 0.2s ease, border-color 0.2s ease;
    }
    .soc:hover {
      transform: translateY(-5px) scale(1.08);
      background: rgba(255,255,255,0.12);
      border-color: rgba(255,255,255,0.22);
      filter: drop-shadow(0 0 16px rgba(255,255,255,0.65));
    }
    .soc:active { transform: translateY(-2px) scale(1.03); }

    /* ── Footer label ── */
    .page-label {
      font-size: 0.56rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.18);
    }

    /* ── Particles canvas ── */
    #particles {
      position: fixed; inset: 0;
      pointer-events: none; z-index: 150;
    }

    /* Touch devices: disable parallax transition */
    @media (hover: none) {
      #card { transition: none !important; }
    }
  </style>
</head>
<body>

  <!-- Intro -->
  <div id="intro" role="button" aria-label="Entrar">
    <span class="intro-text">click...</span>
  </div>

  <!-- Page -->
  <div id="page">
    <video class="video-bg" autoplay muted loop playsinline preload="auto">
      <source src="/short-videografy.mp4" type="video/mp4" />
    </video>
    <div class="video-overlay"></div>

    <div id="card">
      <div class="avatar-ring">
        <img src="/marcos-photo.webp" alt="Marcos Santiago" loading="eager" />
      </div>

      <h1 class="name" id="nameEl"><span class="cursor" id="cursor"></span></h1>

      <p class="tagline">Fotógrafo · Videógrafo · Diseñador</p>
      <p class="location"><i class="fa-solid fa-location-dot"></i> Aibonito, Puerto Rico</p>

      <div class="divider"></div>

      <div class="socials">
        <a class="soc" href="https://wa.me/17872439670?text=Hola%2C+me+interesa+cotizar+un+proyecto."
           target="_blank" rel="noopener" aria-label="WhatsApp">
          <i class="fab fa-whatsapp"></i>
        </a>
        <a class="soc" href="https://instagram.com/marcosstgo"
           target="_blank" rel="noopener" aria-label="Instagram">
          <i class="fab fa-instagram"></i>
        </a>
        <a class="soc" href="https://youtube.com/marcosstgo"
           target="_blank" rel="noopener" aria-label="YouTube">
          <i class="fab fa-youtube"></i>
        </a>
        <a class="soc" href="/portafolio/" aria-label="Portafolio">
          <i class="fa-solid fa-briefcase"></i>
        </a>
      </div>

      <p class="page-label">marcossantiago.com</p>
    </div>
  </div>

  <!-- Particles -->
  <canvas id="particles"></canvas>

  <script is:inline>
  (function () {
    const intro  = document.getElementById('intro');
    const card   = document.getElementById('card');
    const nameEl = document.getElementById('nameEl');
    const cursor = document.getElementById('cursor');

    /* ── Intro dismiss ── */
    function dismiss() {
      intro.classList.add('out');
      card.classList.add('visible');
      setTimeout(startTypewriter, 400);
    }
    intro.addEventListener('click',      dismiss);
    intro.addEventListener('touchstart', dismiss, { passive: true });

    /* ── Typewriter ── */
    function startTypewriter() {
      const text = 'Marcos Santiago';
      let i = 0;
      nameEl.textContent = '';
      nameEl.appendChild(cursor);
      function tick() {
        nameEl.insertBefore(document.createTextNode(text[i++]), cursor);
        if (i < text.length) setTimeout(tick, 72);
        else setTimeout(() => cursor.classList.add('hidden'), 800);
      }
      tick();
    }

    /* ── Parallax 3D ── */
    let tx = 0, ty = 0, cx = 0, cy = 0;
    const hasHover = window.matchMedia('(hover: hover)').matches;

    if (hasHover) {
      document.addEventListener('mousemove', (e) => {
        const { innerWidth: w, innerHeight: h } = window;
        tx = (e.clientX / w - 0.5) * 16;
        ty = (e.clientY / h - 0.5) * -16;
      });
      document.addEventListener('mouseleave', () => { tx = 0; ty = 0; });

      (function parallaxLoop() {
        cx += (tx - cx) * 0.07;
        cy += (ty - cy) * 0.07;
        card.style.transform =
          `perspective(900px) rotateY(${cx}deg) rotateX(${cy}deg)`;
        requestAnimationFrame(parallaxLoop);
      })();
    }

    /* ── Particles cursor ── */
    const canvas = document.getElementById('particles');
    const ctx    = canvas.getContext('2d');
    const pts    = [];

    function resize() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    if (hasHover) {
      document.addEventListener('mousemove', (e) => {
        for (let i = 0; i < 4; i++) {
          pts.push({
            x: e.clientX, y: e.clientY,
            vx: (Math.random() - 0.5) * 2.8,
            vy: (Math.random() - 0.5) * 2.8 - 0.6,
            r: Math.random() * 2.2 + 0.8,
            life: 1,
          });
        }
      });
    }

    (function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = pts.length - 1; i >= 0; i--) {
        const p = pts[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.07;
        p.life -= 0.026;
        if (p.life <= 0) { pts.splice(i, 1); continue; }
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * p.life, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${p.life * 0.5})`;
        ctx.fill();
      }
      requestAnimationFrame(draw);
    })();
  })();
  </script>

</body>
</html>
